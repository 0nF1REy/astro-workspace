---
import Button from "../../../components/Button.astro";
import AboutImage from "../../../assets/images/about/alan-ryan-02.jpg";
---

<section id="about" class="about pt-section">
  <div class="content-wrapper">
    <div class="about__grid">
      <div class="about__content">
        <h2>Sobre mim</h2>
        <p>
          Olá, sou Alan Ryan — desenvolvedor de sistemas, natural de Itapeva-SP.
          Tenho interesse por tecnologia e design, buscando sempre unir o lado
          técnico e humano em meus projetos. Gosto de criar soluções práticas,
          organizadas e com propósito, explorando o aprendizado constante em
          programação e inovação digital.
        </p>
        <Button text="Saiba mais" href="/" />
      </div>

      <div class="about__image">
        <img
          src={AboutImage.src}
          alt="Foto de Alan Ryan"
          width={AboutImage.width}
          height={AboutImage.height}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    background-color: rgba(17, 24, 39, 0.4) !important;
    backdrop-filter: blur(1px);
    -webkit-backdrop-filter: blur(10px);
    overflow: hidden;
  }

  .about::before {
    content: "";
    position: absolute;
    inset: 0;

    background-size: cover;
    background-position: center;
    opacity: 0.2;
    z-index: -1;
  }

  h2 {
    margin-bottom: 1rem;
    color: #fff;
  }

  .about__content {
    margin-bottom: 2rem;
    text-align: center;
  }

  .about__content p {
    margin-bottom: 2rem;
    color: var(--secondary-clr-100);
    line-height: 1.7;
    max-width: 62ch;
  }

  .about__image {
    position: relative;
    width: min(100%, 460px);
  }

  .about__image::before {
    content: "";
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    left: -0.5rem;
    width: 25px;
    height: 100px;
    border: 1.5px solid var(--primary-clr-400);
    border-radius: 5rem;
  }

  .about__image::after {
    content: "";
    position: absolute;
    top: -2.5rem;
    right: 2rem;
    width: 20px;
    height: 80px;
    border: 1.5px solid var(--primary-clr-400);
    border-radius: 5rem;
    rotate: 90deg;
  }

  .about__image img {
    width: 100%;
    border-radius: 0.5rem;
  }

  @media (width >= 768px) {
    h2 {
      text-align: left;
    }

    .about__content {
      text-align: left;
    }

    .about__content p {
      font-size: 1.1rem;
    }

    .about__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(2rem, 5vw, 4rem);
      place-items: center;
    }
  }
</style>
