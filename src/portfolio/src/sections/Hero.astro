---
import { Image } from "astro:assets";
import Button from "../components/Button.astro";
import HeroImage from "../assets/images/hero/alan-ryan-01.png";
---

<section class="hero" id="home">
  <div class="content-wrapper">
    <div class="hero__layout">
      <div class="hero__copy">
        <p class="hero__intro">Olá, eu sou</p>
        <h1 class="hero__name">Alan Ryan <span>da Silva Domingues</span></h1>
        <h2 class="hero__subtitle">Técnico em Desenvolvimento de Sistemas</h2>
        <div class="hero__actions">
          <Button text="Ver projetos" href="#work" />
        </div>
      </div>

      <div class="hero__media">
        <Image src={HeroImage} alt="Foto de Alan Ryan" width={620} />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    align-items: center;
    padding-block: 6.5rem 3rem;
    perspective: 1000px;
  }

  .hero__layout {
    display: grid;
    gap: clamp(1.75rem, 4vw, 4rem);
    align-items: center;
    justify-items: center;
  }

  .hero__copy {
    width: min(100%, 56ch);
    text-align: left;
  }

  .hero__media {
    width: min(100%, 460px);
  }

  .hero__media img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 1.25rem;
    box-shadow: 0 22px 50px rgba(0, 0, 0, 0.35);
  }

  .hero__intro,
  .hero__name,
  .hero__subtitle,
  .hero__actions,
  .hero__media {
    opacity: 0;
    visibility: hidden;
    will-change: transform, opacity, filter;
  }

  .hero__intro {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
    color: var(--primary-clr-400);
  }

  .hero__name {
    font-size: 2.5rem;
    line-height: 1.1;
    margin-bottom: 0.5rem;
    font-weight: 800;
  }

  .hero__name span {
    display: inline-block;
    color: var(--primary-clr-400);
  }

  .hero__subtitle {
    font-size: 1.05rem;
    font-weight: 400;
    margin-bottom: 1.75rem;
    opacity: 0.9;
  }

  @media (width >= 768px) {
    .hero {
      padding-block: 7rem 4rem;
    }

    .hero__layout {
      grid-template-columns: minmax(0, 1fr) minmax(360px, 520px);
      justify-items: stretch;
    }

    .hero__intro {
      font-size: 1.25rem;
    }

    .hero__name {
      font-size: clamp(3rem, 5vw, 4.4rem);
    }

    .hero__subtitle {
      font-size: clamp(1.2rem, 2vw, 1.65rem);
    }

    .hero__media {
      justify-self: end;
      width: min(100%, 520px);
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  function initHeroAnimation() {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (prefersReducedMotion) {
      gsap.set(
        [
          ".hero__intro",
          ".hero__name",
          ".hero__subtitle",
          ".hero__actions",
          ".hero__media",
        ],
        {
          autoAlpha: 1,
          clearProps: "transform,filter,visibility,opacity",
        }
      );
      return;
    }

    gsap.set(".hero__intro", {
      autoAlpha: 0,
      y: -20,
      filter: "blur(10px)",
    });

    gsap.set(".hero__name", {
      autoAlpha: 0,
      scale: 0.9,
      rotationX: -45,
    });

    gsap.set(".hero__subtitle", {
      autoAlpha: 0,
      x: -30,
      filter: "blur(8px)",
    });

    gsap.set(".hero__actions", {
      autoAlpha: 0,
      scale: 0,
      rotation: 360,
      y: 100,
    });

    gsap.set(".hero__media", {
      autoAlpha: 0,
      x: 40,
      scale: 0.95,
      filter: "blur(8px)",
    });

    const tl = gsap.timeline({
      defaults: {
        ease: "power3.out",
      },
    });

    tl.to(".hero__intro", {
      autoAlpha: 1,
      y: 0,
      filter: "blur(0px)",
      duration: 0.8,
      delay: 0.2,
    })
      .to(
        ".hero__name",
        {
          autoAlpha: 1,
          scale: 1,
          rotationX: 0,
          duration: 1,
          ease: "back.out(1.2)",
        },
        "-=0.5"
      )
      .to(
        ".hero__name span",
        {
          scale: 1.05,
          duration: 0.3,
          yoyo: true,
          repeat: 1,
        },
        "-=0.2"
      )
      .to(
        ".hero__subtitle",
        {
          autoAlpha: 1,
          x: 0,
          filter: "blur(0px)",
          duration: 0.7,
        },
        "-=0.6"
      )
      .to(
        ".hero__actions",
        {
          autoAlpha: 1,
          scale: 1.15,
          rotation: 0,
          y: 0,
          duration: 0.45,
          ease: "back.out(4)",
        },
        "-=0.3"
      )
      .to(
        ".hero__media",
        {
          autoAlpha: 1,
          x: 0,
          scale: 1,
          filter: "blur(0px)",
          duration: 0.75,
          ease: "power3.out",
        },
        "-=0.4"
      )
      .to(".hero__actions", {
        scale: 1,
        duration: 0.2,
        ease: "elastic.out(2, 0.4)",
      })
      .to(".hero__actions .btn", {
        scale: 1.15,
        boxShadow: "0 0 30px rgba(30, 113, 183, 0.8)",
        duration: 0.3,
        repeat: 2,
        yoyo: true,
        ease: "power2.inOut",
      })
      .to(".hero__actions .btn", {
        y: -8,
        scale: 1.08,
        rotation: 2,
        duration: 1.5,
        ease: "power2.inOut",
        yoyo: true,
        repeat: -1,
      });
  }

  document.addEventListener("astro:page-load", initHeroAnimation);
</script>
