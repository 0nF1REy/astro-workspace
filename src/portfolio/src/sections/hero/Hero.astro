---
import Button from "../../components/Button.astro";
import HeroImage from "../../assets/images/hero/alan-ryan-01.png";
---

<section class="hero" id="home">
  <div class="content-wrapper">
    <div class="hero__layout">
      <div class="hero__copy">
        <p class="hero__intro">Olá, eu sou</p>
        <h1 class="hero__name">Alan Ryan <span>da Silva Domingues</span></h1>
        <h2 class="hero__subtitle" aria-live="polite">
          <span class="hero__subtitle-role">Desenvolvedor Full Stack</span>
        </h2>
        <div class="hero__actions">
          <Button text="Ver projetos" href="#work" />
          <a
            class="hero__cv"
            href="https://www.linkedin.com/in/alan-ryan-b115ba228/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Ver currículo no LinkedIn"
          >
            Baixar CV
          </a>
        </div>

        <ul class="hero__social" role="list" aria-label="Redes sociais">
          <li>
            <a
              href="https://github.com/0nF1REy"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
            >
              <i class="fa-brands fa-github" aria-hidden="true"></i>
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/alan-ryan-b115ba228/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
            </a>
          </li>
        </ul>
      </div>

      <div class="hero__media">
        <img
          src={HeroImage.src}
          alt="Foto de Alan Ryan"
          width={HeroImage.width}
          height={HeroImage.height}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    align-items: center;
    padding-block: 6.5rem 3rem;
    perspective: 1000px;
  }

  .hero__layout {
    display: grid;
    gap: clamp(1.75rem, 4vw, 4rem);
    align-items: center;
    justify-items: center;
  }

  .hero__copy {
    width: min(100%, 56ch);
    text-align: left;
  }

  .hero__media {
    width: min(100%, 460px);
  }

  .hero__media img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 1.25rem;
    box-shadow: 0 22px 50px rgba(0, 0, 0, 0.35);
  }

  .hero__intro,
  .hero__name,
  .hero__subtitle,
  .hero__actions,
  .hero__media {
    opacity: 0;
    visibility: hidden;
    will-change: transform, opacity, filter;
  }

  .hero__intro {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
    color: var(--primary-clr-400);
  }

  .hero__name {
    font-size: 2.5rem;
    line-height: 1.1;
    margin-bottom: 0.5rem;
    font-weight: 800;
  }

  .hero__name span {
    display: inline-block;
    color: var(--primary-clr-400);
  }

  .hero__subtitle {
    font-size: 1.05rem;
    font-weight: 400;
    margin-bottom: 1.75rem;
    opacity: 0.9;
    line-height: 1.45;
    min-height: 2.1rem;
    width: 100%;
    text-align: left;
  }

  .hero__subtitle-role {
    display: block;
    font-weight: 600;
    color: var(--secondary-clr-100);
    text-align: left;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.15rem;
  }

  .hero__cv {
    border: 1px solid color-mix(in srgb, var(--primary-clr-400) 70%, #fff 30%);
    color: var(--secondary-clr-100);
    padding: 0.7rem 1.25rem;
    border-radius: 5rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition:
      transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 200ms ease,
      background-color 200ms ease;
  }

  .hero__cv:hover {
    transform: translateY(-2px);
    border-color: var(--primary-clr-400);
    background-color: rgba(30, 113, 183, 0.12);
  }

  .hero__social {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.1rem;
  }

  .hero__social a {
    color: var(--secondary-clr-100);
    font-size: 1.45rem;
    transition:
      transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      color 180ms ease;
  }

  .hero__social a:hover {
    color: var(--primary-clr-400);
    transform: translateY(-3px);
  }

  @media (width >= 768px) {
    .hero {
      padding-block: 7rem 4rem;
    }

    .hero__layout {
      grid-template-columns: minmax(0, 1fr) minmax(360px, 520px);
      justify-items: stretch;
    }

    .hero__intro {
      font-size: 1.25rem;
    }

    .hero__name {
      font-size: clamp(3rem, 5vw, 4.4rem);
    }

    .hero__subtitle {
      font-size: clamp(1.2rem, 2vw, 1.65rem);
      min-height: 2.6rem;
    }

    .hero__social {
      margin-top: 1.2rem;
    }

    .hero__media {
      justify-self: end;
      width: min(100%, 520px);
    }
  }
</style>

<script>
  import { initHeroAnimation } from "./hero-animation";

  document.addEventListener("astro:page-load", initHeroAnimation);
</script>
