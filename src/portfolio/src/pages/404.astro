---
import "@fontsource/poppins";
import "../styles/global.css";
import Button from "../components/Button.astro";
import ErrorImage from "../assets/images/error/error.webp";
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="A página que você tentou acessar não foi encontrada."
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>404 | Página não encontrada!</title>
  </head>
  <body>
    <canvas id="bg-canvas"></canvas>

    <section class="error-page">
      <div class="content-wrapper">
        <div class="error-page__shell">
          <div class="error-page__card">
            <div class="error-page__content">
              <p class="error-page__code">Erro 404</p>
              <h1>Página não encontrada!</h1>
              <p>O conteúdo que você procurou não existe ou foi movido.</p>
              <Button text="Voltar para o início" href="/" />
            </div>

            <aside class="error-page__aside" aria-hidden="true">
              <img
                src={ErrorImage.src}
                width={ErrorImage.width}
                height={ErrorImage.height}
                alt=""
                loading="eager"
                decoding="async"
              />
            </aside>
          </div>
        </div>
      </div>
    </section>

    <script>
      import {
        destroyLayoutParticles,
        initLayoutParticles,
      } from "../layout/layout-particles";

      const bootParticles = () => {
        destroyLayoutParticles();
        initLayoutParticles();
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", bootParticles, {
          once: true,
        });
      } else {
        bootParticles();
      }

      document.addEventListener("astro:page-load", initLayoutParticles);
      document.addEventListener("astro:before-swap", destroyLayoutParticles);
    </script>
  </body>
</html>

<style>
  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: -1;
    background: #050505;
    pointer-events: none;
  }

  .error-page {
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding-block: clamp(1.25rem, 3vw, 2rem);
  }

  .error-page .content-wrapper {
    display: grid;
    place-items: center;
    width: 100%;
  }

  .error-page__shell {
    width: min(100%, 1040px);
    display: grid;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: center;
  }

  .error-page__card {
    width: 100%;
    max-width: 1040px;
    display: grid;
    grid-template-columns: 1fr;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--secondary-clr-400);
    border-radius: 1rem;
    background-color: rgba(17, 24, 39, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .error-page__content {
    max-width: 62ch;
  }

  .error-page__code {
    display: inline-flex;
    align-items: center;
    color: var(--primary-clr-400);
    font-weight: 700;
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.85rem;
    padding: 0.25rem 0.65rem;
    border: 1px solid
      color-mix(in srgb, var(--primary-clr-400) 55%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary-clr-400) 14%, transparent);
  }

  .error-page h1 {
    margin-bottom: 0.75rem;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.2;
    text-align: left;
  }

  .error-page p {
    color: var(--secondary-clr-200);
    margin-bottom: 1.5rem;
    max-width: 58ch;
  }

  .error-page__aside {
    display: none;
  }

  .error-page__aside img {
    width: min(100%, 460px);
    margin-inline: auto;
  }

  @media (width >= 900px) {
    .error-page__card {
      grid-template-columns: minmax(0, 1fr) minmax(300px, 460px);
      gap: clamp(1rem, 2.5vw, 1.5rem);
      align-items: center;
    }

    .error-page__aside {
      display: block;
      padding-left: clamp(1rem, 2vw, 1.5rem);
      border-left: 1px solid var(--secondary-clr-400);
    }
  }
</style>
