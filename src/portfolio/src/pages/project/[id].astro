---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layout/Layout.astro";
import { Image } from "astro:assets";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project: CollectionEntry<"projects">) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props as { project: CollectionEntry<"projects"> };

const { title, mainImage, otherImages = [], storyTitle, storyContent } =
  project.data;
---

<Layout {title}>
  <section class="project-detail pt-section">
    <div class="content-wrapper">
      <div class="project-detail__header">
        <a
          class="project-detail__back"
          href="/#work"
          aria-label="Retornar à seção de projetos"
        >
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          Retornar aos projetos
        </a>
        <h1>{title}</h1>
      </div>

      <Image
        src={mainImage}
        alt={title}
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 90vw, 1100px"
        class="project-detail__main-image"
        loading="eager"
        fetchpriority="high"
      />

      <div class="project-detail__story">
        <h3>{storyTitle}</h3>
        <p>{storyContent}</p>
      </div>

      {
        otherImages.length > 0 && (
          <div class="project-detail__gallery">
            {otherImages.map((image) => (
              <Image
                src={image}
                alt={title}
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
                class="project-detail__gallery-image"
                loading="lazy"
              />
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .project-detail {
    padding-bottom: clamp(1.25rem, 3vw, 2.5rem);
  }

  .project-detail__header {
    padding-top: clamp(1rem, 2vw, 1.5rem);
    padding-bottom: clamp(1.25rem, 2.5vw, 2rem);
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid var(--secondary-clr-400);
  }

  .project-detail__back {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1rem;
    color: var(--secondary-clr-200);
    font-weight: 500;
    transition:
      color 0.3s ease-in-out,
      transform 0.3s ease-in-out;
  }

  .project-detail__back:hover {
    color: var(--primary-clr-400);
    transform: translateX(-2px);
  }

  .project-detail h1 {
    text-align: left;
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.2;
  }

  .project-detail :global(img) {
    border-radius: 0.9rem;
    width: 100%;
    height: auto;
  }

  .project-detail__main-image {
    display: block;
    max-width: min(100%, 880px);
    max-height: clamp(260px, 58vh, 560px);
    aspect-ratio: 16 / 9;
    object-fit: cover;
    margin-inline: auto;
    margin-bottom: clamp(1.5rem, 4vw, 2.5rem);
  }

  .project-detail__story {
    max-width: 75ch;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .project-detail__story h3 {
    margin-bottom: 0.9rem;
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
    line-height: 1.25;
  }

  .project-detail__story p {
    color: var(--secondary-clr-200);
    line-height: 1.8;
    font-size: clamp(1rem, 1.2vw, 1.05rem);
  }

  .project-detail__gallery {
    display: grid;
    gap: 1rem;
    max-width: min(100%, 900px);
    margin-inline: auto;
    margin-bottom: 0;
  }

  .project-detail__gallery-image {
    aspect-ratio: 16 / 9;
    max-height: clamp(180px, 30vw, 300px);
    object-fit: cover;
  }

  @media (width >= 768px) {
    .project-detail__gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(1rem, 2vw, 1.5rem);
    }
  }
</style>
