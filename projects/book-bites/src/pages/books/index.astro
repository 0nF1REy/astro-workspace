---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BookCard from "../../components/BookCard.astro";
import Button from "../../components/Button.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const books: CollectionEntry<"books">[] = await getCollection("books");
---

<BaseLayout>
  <div class="content">
    <h2>Livros</h2>

    {books.map((book: CollectionEntry<"books">) => <BookCard book={book} />)}

    {!books.length && <p>Nenhum livro para exibir.</p>}
  </div>
</BaseLayout>

<style>
  .content {
    border-radius: 18px;
    padding: 36px 0 36px 0;
    margin-top: 32px;
    margin-bottom: 32px;
  }

  h2 {
    padding-right: 10px;
    border-right: 8px solid var(--color-border);
    border-bottom: 8px solid var(--color-bg-card);
    margin-bottom: 40px;
    text-align: right;
    color: var(--color-primary-dark);
    font-size: 2.1em;
    letter-spacing: 0.01em;
  }

  @media (max-width: 900px) {
    .content {
      padding: 18px 0 18px 0;
      border-radius: 12px;
    }
    h2 {
      font-size: 1.4em;
      padding-right: 0;
      border-right: none;
      border-bottom: 4px solid var(--color-bg-card);
    }
  }

  @media (max-width: 600px) {
    .content {
      padding: 8px 0 8px 0;
      border-radius: 8px;
    }
    h2 {
      font-size: 1.1em;
    }
  }
</style>
