---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";

// const user = { name: 'Mario', email: 'mario@bookbites.com' }

const getUser = () => {
  return Math.random() < 0.5
    ? null
    : {
        name: "mario",
        email: "mario@bookbites.com",
      };
};

let user = getUser();
---

<BaseLayout>
  <div class="content home-page">
    <section class="hero" aria-label="Apresentacao do Book Bites">
      <p class="eyebrow">Resenhas diretas para leitores curiosos</p>

      <h2>
        {user ? `Bem-vindo, ${user.name}` : "Descubra sua proxima leitura"}
      </h2>

      {user && <p class="session">Conectado como {user.email}</p>}

      <p class="lead">
        Descubra resenhas objetivas, recomendacoes diretas e novas leituras para
        escolher seu proximo livro com mais confianca.
      </p>

      <div class="hero-actions">
        <Button href="/books" variant="primary">Explorar resenhas</Button>
        <Button href="/about" variant="secondary">Conhecer o projeto</Button>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-page {
    display: grid;
    place-items: center;
  }

  .hero {
    width: min(760px, 100%);
    text-align: center;
    background-color: var(--color-bg-card);
    background:
      url("/bg-card.png") center center / cover no-repeat,
      linear-gradient(160deg, var(--color-white) 0%, var(--color-bg-card) 100%);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: 0 12px 32px rgba(122, 73, 197, 0.12);
    padding: clamp(24px, 5vw, 40px);
  }

  .eyebrow {
    margin: 0 0 10px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    line-height: 1.1;
    color: var(--color-text-dark);
  }

  .session {
    margin: 12px 0 0;
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .lead {
    margin: 16px auto 0;
    max-width: 62ch;
    color: var(--color-text-lead);
    font-size: 1.1rem;
    line-height: 1.65;
  }

  .hero-actions {
    margin-top: 26px;
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .hero {
      text-align: left;
    }

    .hero-actions {
      justify-content: flex-start;
    }
  }
</style>
