---
import BaseLayout from "../layouts/BaseLayout.astro";

// const user = { name: 'Mario', email: 'mario@bookbites.com' }

const getUser = () => {
  return Math.random() < 0.5
    ? null
    : {
        name: "mario",
        email: "mario@bookbites.com",
      };
};

let user = getUser();
---

<BaseLayout>
  <div class="content">
    {
      user && (
        <>
          <h2>Bem-vindo, {user.name}</h2>
          <p>Conectado como {user.email}</p>
        </>
      )
    }

    <p>
      Descubra resenhas objetivas, recomendações diretas e novas leituras para
      escolher seu próximo livro com mais confiança.
    </p>

    <a href="/books">Veja minhas resenhas</a>
  </div>
</BaseLayout>

<style>
  .content {
    text-align: center;
  }
  a {
    display: inline-block;
    background-color: #7a49c5;
    color: #fff;
    padding: 6px 10px;
    border-radius: 2px;
    text-decoration: none;
    margin-top: 20px;
  }
  a:hover {
    background-color: #965ee9;
  }
</style>
