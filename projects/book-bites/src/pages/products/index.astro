---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";

interface Product {
  title: string;
}

const response = await fetch("https://dummyjson.com/products");
const json = await response.json();
const products: Product[] = json.products;
---

<BaseLayout>
  <div class="content products-page">
    <h2>Produtos</h2>
    <div class="products-grid">
      {
        products.map((product) => (
          <div class="product-card">{product.title}</div>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .products-page {
    border-radius: 18px;
    padding: 36px 0 36px 0;
    margin-top: 32px;
    margin-bottom: 32px;
    transition: box-shadow 0.18s;
  }

  .products-page h2 {
    padding-right: 10px;
    border-right: 8px solid var(--color-border);
    border-bottom: 8px solid var(--color-bg-card);
    margin-bottom: 40px;
    text-align: right;
    color: var(--color-primary-dark);
    font-size: 2.1em;
    letter-spacing: 0.01em;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
  }

  .product-card {
    background: var(--color-bg-card-alt);
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    box-shadow: 8px 8px 0 var(--color-border);
    color: var(--color-text-main);
    padding: 22px 18px 20px 18px;
    font-size: 1.1em;
    font-weight: 500;
    transition:
      box-shadow 0.18s,
      transform 0.18s;
  }

  .product-card:hover {
    box-shadow:
      0 12px 32px 0 rgba(122, 73, 197, 0.1),
      12px 12px 0 var(--color-border-alt);
    transform: translateY(-2px) scale(1.012);
  }

  @media (max-width: 900px) {
    .products-page {
      padding: 18px 0 18px 0;
      border-radius: 12px;
    }
    .products-page h2 {
      font-size: 1.4em;
      padding-right: 0;
      border-right: none;
      border-bottom: 4px solid var(--color-bg-card);
    }
    .products-grid {
      gap: 14px;
    }
    .product-card {
      padding: 16px 10px 14px 10px;
    }
  }

  @media (max-width: 600px) {
    .products-page {
      padding: 8px 0 8px 0;
      border-radius: 8px;
    }
    .products-page h2 {
      font-size: 1.1em;
    }
    .product-card {
      padding: 10px 4px 10px 4px;
      border-radius: 6px;
    }
  }
</style>
