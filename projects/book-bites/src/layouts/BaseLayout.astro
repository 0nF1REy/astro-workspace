---
const currentYear = new Date().getFullYear();
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Book Bites</title>
    <link rel="stylesheet" href="/src/styles/style.css" />
    <link rel="stylesheet" href="/node_modules/@fortawesome/fontawesome-free/css/all.min.css" />
  </head>
  <body>
    <header>
      <div class="layout-container">
        <h1>
          <a class="brand-link" href="/" aria-label="Ir para a página inicial">
            <img
              class="brand-isotipo"
              src="/isotipo.png"
              alt=""
              aria-hidden="true"
              loading="eager"
              decoding="async"
            />
            <img
              class="brand-label"
              src="/label.png"
              alt="Book Bites"
              loading="eager"
              decoding="async"
            />
          </a>
        </h1>
        <nav>
          <ul>
            <li><a href="/"><i class="fa-solid fa-home" aria-hidden="true"></i> Início</a></li>
            <li><a href="/about"><i class="fa-solid fa-circle-info" aria-hidden="true"></i> Sobre</a></li>
            <li><a href="/books"><i class="fa-solid fa-book" aria-hidden="true"></i> Livros</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="layout-container">
        <div>
          <p>&#169; {currentYear} Book Bites</p>
          <p>Leituras, resenhas e descobertas literárias.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  header {
    background-color: var(--color-bg);
  }

  header .layout-container,
  footer .layout-container {
    max-width: 1200px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  header .layout-container {
    min-height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;

    h1 {
      margin: 0;

      .brand-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        color: inherit;
        text-decoration: none;
        line-height: 0;
      }

      .brand-isotipo {
        display: block;
        height: clamp(28px, 3vw, 34px);
        width: auto;
      }

      .brand-label {
        display: block;
        height: clamp(16px, 1.8vw, 20px);
        width: auto;
      }
    }

    nav {
      display: flex;
      align-items: center;
    }

    ul {
      display: flex;
      list-style-type: none;
      gap: 16px;
      margin: 0;
      padding: 0;
      align-items: center;
    }

    nav a {
      position: relative;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      color: var(--color-text-main);
      font-weight: 500;
      padding: 6px 10px;
      border-radius: 999px;
      transition:
        color 180ms ease,
        background-color 180ms ease;
    }

    nav a::after {
      content: "";
      position: absolute;
      left: 10px;
      right: 10px;
      bottom: 4px;
      height: 2px;
      background-color: var(--color-primary);
      transform: scaleX(0);
      transform-origin: center;
      transition: transform 200ms ease;
    }

    nav a:hover,
    nav a:focus-visible {
      color: var(--color-primary);
      background-color: var(--color-bg-card-alt);
      outline: none;
    }

    nav a:hover::after,
    nav a:focus-visible::after {
      transform: scaleX(1);
    }
  }
  main {
    flex: 1;
  }
  footer {
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding: 24px 0;

    .layout-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    p {
      margin: 0;
    }

    p:first-child {
      font-weight: 700;
      color: var(--color-primary);
    }

    nav {
      margin-left: auto;
    }

    ul {
      display: flex;
      flex-wrap: wrap;
      list-style-type: none;
      gap: 16px;
      margin: 0;
      padding: 0;
    }

    a {
      text-decoration: none;
      border-bottom: 1px dashed;
    }
  }
</style>

<style is:global>
  * {
    font-family: "Poppins", sans-serif;
    color: var(--color-text-main);
  }
  .content {
    width: 100%;
    max-width: 1200px;
    margin: 60px auto;
    padding: 0 20px;
    box-sizing: border-box;

    h2 {
      font-size: 1.8em;
    }
    p {
      font-size: 1.2em;
    }
  }
</style>
