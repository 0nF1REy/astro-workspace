---
const currentYear = new Date().getFullYear();
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Book Bites</title>
  </head>
  <body>
    <header>
      <div class="layout-container">
        <h1>
          <a href="/" aria-label="Ir para a página inicial">Book Bites</a>
        </h1>
        <nav>
          <ul>
            <li><a href="/">Início</a></li>
            <li><a href="/about">Sobre</a></li>
            <li><a href="/books">Livros</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="layout-container">
        <div>
          <p>&#169; {currentYear} Book Bites</p>
          <p>Leituras, resenhas e descobertas literárias.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  header {
    background-color: #f9f6fc;
  }

  header .layout-container,
  footer .layout-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  header .layout-container {
    min-height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;

    h1 {
      margin: 0;

      a {
        color: inherit;
        text-decoration: none;
      }
    }
    ul {
      display: flex;
      list-style-type: none;
      gap: 16px;
    }
    a {
      text-decoration: none;
      border-bottom: 1px dashed;
    }
  }
  main {
    flex: 1;
  }
  footer {
    background-color: #f9f6fc;
    border-top: 1px solid #ebe5f2;
    padding: 24px 0;

    .layout-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    p {
      margin: 0;
    }

    p:first-child {
      font-weight: 700;
    }

    nav {
      margin-left: auto;
    }

    ul {
      display: flex;
      flex-wrap: wrap;
      list-style-type: none;
      gap: 16px;
      margin: 0;
      padding: 0;
    }

    a {
      text-decoration: none;
      border-bottom: 1px dashed;
    }
  }
</style>

<style is:global>
  * {
    font-family: "Poppins", sans-serif;
    color: #333;
  }
  .content {
    width: 100%;
    max-width: 1200px;
    margin: 60px auto;
    padding: 0 20px;
    box-sizing: border-box;

    h2 {
      font-size: 1.8em;
    }
    p {
      font-size: 1.2em;
    }
  }
</style>
