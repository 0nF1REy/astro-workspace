---
import type { CollectionEntry } from "astro:content";
import Button from "./Button.astro";

interface Props {
  book: CollectionEntry<"books">;
}

const { book } = Astro.props;
---

<div class="book-card">
  <p class="book-title">{book.data.title}, {book.data.rating}/10</p>
  <p class="book-author">por {book.data.author}</p>
  <p class="book-summary">{book.data.summary}</p>
  <Button href={`/books/${book.id}`} variant="secondary">Ler Resenha</Button>
</div>

<style>
  .book-card {
    box-sizing: border-box;
    padding: 22px 28px 20px 28px;
    margin: 1.5rem 0;
    border-radius: 18px;
    border: 1.5px solid var(--color-border);
    box-shadow:
      0 6px 32px 0 rgba(122, 73, 197, 0.1),
      8px 8px 0 var(--color-border);
    color: var(--color-text-main);
    width: 100%;
    transition:
      box-shadow 0.18s,
      transform 0.18s;
  }
  .book-card:hover {
    box-shadow:
      0 12px 40px 0 rgba(122, 73, 197, 0.16),
      12px 12px 0 var(--color-border-alt);
    transform: translateY(-2px) scale(1.012);
  }
  .book-title {
    font-size: 1.35em;
    font-weight: 700;
    margin: 0 0 4px 0;
    color: var(--color-primary-dark);
    letter-spacing: 0.01em;
  }
  .book-author {
    margin-top: 0;
    color: var(--color-text-muted);
    font-size: 1em;
    margin-bottom: 8px;
  }
  .book-summary {
    font-size: 1.04em;
    color: var(--color-text-lead);
    margin-bottom: 18px;
  }
</style>
