---
export interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary";
  class?: string;
}
const {
  href,
  type = "button",
  variant = "primary",
  class: className = "",
  ...rest
} = Astro.props;
---

{
  href ? (
    <a href={href} class={`btn btn-${variant} ${className}`} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={`btn btn-${variant} ${className}`} {...rest}>
      <slot />
    </button>
  )
}

<style>
  .btn {
    display: inline-block;
    padding: 10px 18px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
    font-family: inherit;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    position: relative;
    transition:
      background-color 160ms ease,
      color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }
  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-white);
    box-shadow: 0 8px 20px rgba(122, 73, 197, 0.18);
  }
  .btn-primary:hover,
  .btn-primary:focus-visible {
    background-color: var(--color-primary-light);
    color: var(--color-white);
    transform: translateY(-1px);
    box-shadow: 0 12px 24px rgba(122, 73, 197, 0.22);
    outline: none;
  }
  .btn-secondary {
    background-color: var(--color-bg-card-alt);
    color: var(--color-primary);
    border: 1px solid var(--color-border-alt);
  }
  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    background-color: var(--color-bg-card-alt-hover);
    color: var(--color-primary-dark);
    transform: translateY(-1px);
    outline: none;
  }
  .btn-primary::after,
  .btn-secondary::after {
    content: "";
    display: block;
    position: absolute;
    top: -5px;
    right: -5px;
    width: 38px;
    height: 24px;
    background: url("/pt-blood.png") no-repeat center center / contain;
    opacity: 0;
    pointer-events: none;
    transform: rotate(18deg);
    transition: opacity 180ms ease;
    z-index: 2;
  }
  .btn-primary:hover::after,
  .btn-primary:focus-visible::after,
  .btn-secondary:hover::after,
  .btn-secondary:focus-visible::after {
    opacity: 1;
  }
</style>
