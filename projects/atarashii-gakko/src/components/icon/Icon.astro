---
import {
  config,
  library,
  icon as faIcon,
} from "@fortawesome/fontawesome-svg-core";
import type { IconPrefix, IconName } from "@fortawesome/fontawesome-svg-core";
import { fas } from "@fortawesome/free-solid-svg-icons";
import { fab } from "@fortawesome/free-brands-svg-icons";

config.autoAddCss = false;
library.add(fas, fab);

export interface Props {
  icon: string | readonly [string, string];
  className?: string;
}

const { icon: iconProp, className } = Astro.props;

const prefix = Array.isArray(iconProp)
  ? (iconProp[0] as IconPrefix)
  : ("fas" as IconPrefix);
const iconName = Array.isArray(iconProp)
  ? (iconProp[1] as IconName)
  : (iconProp as IconName);

const abstractIcon = faIcon({
  prefix,
  iconName,
});

const svgHtml = abstractIcon ? abstractIcon.html[0] : "";
---

<span class:list={["icon-container", className]} set:html={svgHtml} />
