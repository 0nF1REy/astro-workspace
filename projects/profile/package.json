{
  "name": "profile",
  "type": "module",
  "version": "1.0.1",
  "description": "A personal profile link hub built with Astro, featuring two UI versions and a clean, responsive layout for sharing social platforms.",
  "keywords": [
    "astro",
    "profile",
    "link-hub",
    "personal-site",
    "responsive-design",
    "scss",
    "vercel"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:secure": "npm run build && npm run csp:sync",
    "csp:sync": "node ./configs/sync-csp.mjs",
    "preview": "astro preview",
    "clean": "rimraf dist",
    "check": "astro check",
    "sync": "astro sync",
    "info": "astro info",
    "upgrade": "npx @astrojs/upgrade",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "list": "npm run"
  },
  "author": {
    "name": "Alan Ryan da Silva Domingues",
    "email": "alanryan619@gmail.com",
    "url": "https://github.com/0nF1REy"
  },
  "license": "MIT",
  "homepage": "https://alan-ryan-profile.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/0nF1REy/astro-workspace.git"
  },
  "bugs": {
    "url": "https://github.com/0nF1REy/astro-workspace/issues"
  },
  "dependencies": {
    "@astrojs/vercel": "^10.0.8",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "astro": "^6.4.6",
    "sass": "^1.97.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
