---
import "../styles/_variables.scss";
import "@fortawesome/fontawesome-free/css/all.min.css";

interface Props {
  title?: string;
  enablePageScroll?: boolean;
}

const { title = "Profile | Alan Ryan", enablePageScroll = false } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;900&family=Inter:wght@400;700;800&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class={enablePageScroll ? "allow-page-scroll" : undefined}>
    <slot />
  </body>
</html>

<style is:global lang="scss">
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    background-color: var(--gintama-bg);
    color: var(--gintama-silver);
    font-family: "Inter", sans-serif;
    overflow: hidden;
  }

  * {
    box-sizing: border-box;
  }

  body.allow-page-scroll {
    overflow-y: auto;
    overflow-x: hidden;
  }
</style>
