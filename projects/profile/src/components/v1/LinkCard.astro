---
interface Props {
  label: string;
  url: string;
  image: string;
}
const { label, url, image } = Astro.props;
---

<a href={url} target="_blank" class="link-card">
  <div class="card-inner">
    <div class="logo-wrapper">
      <img src={image} alt={label} class="service-logo" />
    </div>

    <div class="content">
      <span class="label">{label}</span>
    </div>

    <i class="fa-solid fa-arrow-up-right-from-square arrow"></i>
  </div>
</a>

<style lang="scss">
  .link-card {
    text-decoration: none;
    display: block;
    width: 100%;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 14px;
    margin-bottom: 1rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(10px);

    &:hover {
      transform: translateX(12px);
      background: rgba(76, 166, 184, 0.1);
      border-color: var(--gintama-cyan);

      .service-logo {
        filter: grayscale(0%) brightness(1.1);

      }

      .arrow {
        color: var(--gintama-cyan);
        opacity: 1;
      }
      .label {
        color: var(--gintama-silver);
      }
    }
  }

  .card-inner {
    padding: 0.8rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .logo-wrapper {
    width: 45px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .service-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: all 0.4s ease;
  }

  .content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    text-align: left;
  }

  .tech-tag {
    font-family: "Orbitron", sans-serif;
    font-size: 0.55rem;
    color: var(--gintama-cyan);
    letter-spacing: 1px;
    opacity: 0.7;
    margin-bottom: 2px;
  }

  .label {
    font-weight: 700;
    color: rgba(243, 244, 246, 0.5);
    font-size: 1rem;
    transition: color 0.3s;
  }

  .arrow {
    font-size: 0.8rem;
    color: var(--gintama-cyan);
    opacity: 0.2;
    transition: all 0.3s;
  }
</style>
