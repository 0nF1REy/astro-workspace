{
  "name": "jashin-chan-dropkick",
  "type": "module",
  "version": "1.9.0",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "description": "A modern high-fidelity fan-made port and clone of the official Jashin-chan Dropkick (Dropkick on My Devil!!) anime website, built with Astro, TypeScript, and Sass.",
  "keywords": [
    "jashin-chan",
    "dropkick-on-my-devil",
    "anime",
    "manga",
    "astro-framework",
    "typescript",
    "sass",
    "web-clone",
    "fan-site",
    "frontend-development"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "clean": "rimraf dist",
    "check": "astro check",
    "sync": "astro sync",
    "info": "astro info",
    "upgrade": "npx @astrojs/upgrade",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "list": "npm run"
  },
  "author": {
    "name": "Alan Ryan da Silva Domingues",
    "email": "alanryan619@gmail.com",
    "url": "https://github.com/0nF1REy"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0nF1REy/astro-workspace.git"
  },
  "bugs": {
    "url": "https://github.com/0nF1REy/astro-workspace/issues"
  },
  "dependencies": {
    "astro": "^7.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.97.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
