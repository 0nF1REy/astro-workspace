---
import "./jd-hero.scss";
import { menuItems } from "../../../data/menu";

const heroImage = {
  src: "/assets/images/home/pachislo-jashin-chan.png",
  alt: "Jashin-chan",
};

const heroImageLogo = {
  src: "/assets/images/home/jd-logo.svg",
  alt: "Jashin-chan Logo",
};

const heroImageTwitterBtn = {
  src: "/assets/images/home/twitter-button.png",
  alt: "Twitter Button",
};

const colLeft = menuItems.slice(0, 5);
const colRight = menuItems.slice(5);
---

<header
  id="hero-header"
  class="w-full min-h-screen flex items-center justify-center bg-white overflow-hidden py-10"
>
  <div
    class="container mx-auto px-4 max-w-5xl grid grid-cols-1 lg:grid-cols-2 items-start"
  >
    <div class="flex flex-col items-center w-full z-10">
      <div class="w-full mb-16 mt-20">
        <img
          src={heroImageLogo.src}
          alt={heroImageLogo.alt}
          class="w-full h-auto max-w-[430px]"
        />
      </div>

      <nav class="flex justify-center w-full max-w-[400px] mb-16">
        <div class="grid grid-cols-2 w-full">
          <ul class="flex flex-col space-y-4 items-center text-center">
            {
              colLeft.map((item) => (
                <li>
                  <a
                    href={item.href || "#"}
                    class="nav-img-item"
                    id={item.id}
                    aria-label={item.id}
                  >
                    <img
                      src={item.img}
                      alt={item.id}
                      class="nav-img"
                      id={`img-${item.id}`}
                      data-img={item.img}
                      data-imghover={item.imgHover}
                    />
                  </a>
                </li>
              ))
            }
          </ul>
          <ul class="flex flex-col space-y-4 items-center text-center">
            {
              colRight.map((item) => (
                <li>
                  <a
                    href={item.href || "#"}
                    class="nav-img-item"
                    id={item.id}
                    aria-label={item.id}
                  >
                    <img
                      src={item.img}
                      alt={item.id}
                      class="nav-img"
                      id={`img-${item.id}`}
                      data-img={item.img}
                      data-imghover={item.imgHover}
                    />
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>

      <div class="flex justify-center w-full">
        <a href="#" class="twitter-link">
          <img
            src={heroImageTwitterBtn.src}
            alt={heroImageTwitterBtn.alt}
            class="h-[200px]"
          />
        </a>
      </div>
    </div>

    <div class="h-full lg:-ml-5">
      <img src={heroImage.src} alt={heroImage.alt} class="character-img" />
    </div>
  </div>
</header>

<script>
  const setupHoverImages = () => {
    const navLinks = document.querySelectorAll(".nav-img-item");

    navLinks.forEach((link) => {
      const img = link.querySelector(".nav-img") as HTMLImageElement;
      if (!img) return;

      const originalSrc = img.dataset.img;
      const hoverSrc = img.dataset.imghover;

      if (hoverSrc) {
        const preload = new Image();
        preload.src = hoverSrc;
      }

      link.addEventListener("mouseenter", () => {
        if (hoverSrc) img.src = hoverSrc;
      });

      link.addEventListener("mouseleave", () => {
        if (originalSrc) img.src = originalSrc;
      });
    });
  };

  setupHoverImages();
  document.addEventListener("astro:after-swap", setupHoverImages);
</script>
