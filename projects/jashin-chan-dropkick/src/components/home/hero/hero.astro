---
import { menuItems } from "@data/menu";

const heroImage = {
  src: "/assets/images/home/hero/pachislo-jashin-chan.png",
  alt: "Jashin-chan",
};

const heroImageLogo = {
  src: "/assets/images/home/hero/jd-logo.svg",
  alt: "Jashin-chan Logo",
};

const heroImageTwitterBtn = {
  src: "/assets/images/home/hero/twitter-button.png",
  alt: "Twitter Button",
};

const colLeft = menuItems.slice(0, 5);
const colRight = menuItems.slice(5);
---

<header id="hero-header">
  <div class="hero-container">
    <div class="hero-content">
      <div class="logo-wrapper">
        <img src={heroImageLogo.src} alt={heroImageLogo.alt} class="logo-img" />
      </div>

      <nav class="nav-wrapper">
        <div class="nav-grid">
          <ul class="nav-column">
            {
              colLeft.map((item) => (
                <li>
                  <a
                    href={item.href || "#"}
                    class="nav-img-item"
                    id={item.id}
                    aria-label={item.id}
                  >
                    <img
                      src={item.img}
                      alt={item.id}
                      class="nav-img"
                      id={`img-${item.id}`}
                      data-img={item.img}
                      data-imghover={item.imgHover}
                    />
                  </a>
                </li>
              ))
            }
          </ul>
          <ul class="nav-column">
            {
              colRight.map((item) => (
                <li>
                  <a
                    href={item.href || "#"}
                    class="nav-img-item"
                    id={item.id}
                    aria-label={item.id}
                  >
                    <img
                      src={item.img}
                      alt={item.id}
                      class="nav-img"
                      id={`img-${item.id}`}
                      data-img={item.img}
                      data-imghover={item.imgHover}
                    />
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>

      <div class="twitter-wrapper">
        <a href="#" class="twitter-link">
          <img
            src={heroImageTwitterBtn.src}
            alt={heroImageTwitterBtn.alt}
            class="twitter-btn-img"
          />
        </a>
      </div>
    </div>

    <div class="hero-character">
      <img src={heroImage.src} alt={heroImage.alt} class="character-img" />
    </div>
  </div>
</header>

<style lang="scss">
  #hero-header {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: white;
    overflow: hidden;
    padding: 1rem 0;

    .hero-container {
      width: 100%;
      max-width: 1024px;
      margin: 0 auto;
      padding: 0 1rem;
      display: grid;
      grid-template-columns: 1fr;
      align-items: start;

      @media (min-width: 1024px) {
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
      }
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      z-index: 10;
    }

    .logo-wrapper {
      width: 100%;
      margin-bottom: 4rem;
      margin-top: 5rem;

      .logo-img {
        width: 100%;
        height: auto;
        max-width: 430px;
      }
    }

    .nav-wrapper {
      display: flex;
      justify-content: center;
      width: 100%;
      max-width: 400px;
      margin-bottom: 4rem;
    }

    .nav-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
    }

    .nav-column {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
      text-align: center;
    }

    .twitter-wrapper {
      display: flex;
      justify-content: center;
      width: 100%;
      margin-top: -0.8rem;
    }

    .twitter-link {
      transition: transform 0.3s ease;

      &:hover {
        opacity: 0.8;
      }

      .twitter-btn-img {
        max-width: 410px;
        min-width: 300px;
        max-height: 210px;
        min-height: 160px;
        width: 30vw;
        height: 15vw;
        transition: 0.2s all;
      }
    }

    .hero-character {
      height: 100%;
    }

    .character-img {
      width: 560px;
      height: 800px;
      max-width: none;
      vertical-align: middle;
      border-style: none;
    }
  }
</style>

<script>
  const setupHoverImages = () => {
    const navLinks = document.querySelectorAll(".nav-img-item");

    navLinks.forEach((link) => {
      const img = link.querySelector(".nav-img") as HTMLImageElement;
      if (!img) return;

      const originalSrc = img.dataset.img;
      const hoverSrc = img.dataset.imghover;

      if (hoverSrc) {
        const preload = new Image();
        preload.src = hoverSrc;
      }

      link.addEventListener("mouseenter", () => {
        if (hoverSrc) img.src = hoverSrc;
      });

      link.addEventListener("mouseleave", () => {
        if (originalSrc) img.src = originalSrc;
      });
    });
  };

  setupHoverImages();
  document.addEventListener("astro:after-swap", setupHoverImages);
</script>
