---
import { banners, snsItems, footerAssets } from "@data/footer";

const bgWaveTop = `url("${footerAssets.bgWaveTop}")`;
const bgWaveBottom = `url("${footerAssets.bgWaveBottom}")`;
---

<footer id="footer">
  <div class="bg-wave-top"></div>
  <div class="foreground">
    <div class="container"></div>
  </div>
  <div class="bg-wave-bottom"></div>
  <div class="copyright">
    ©︎ユキヲ・COMICメテオ／邪神ちゃんドロップキック製作委員会
  </div>
</footer>

<style lang="scss" define:vars={{ bgWaveTop, bgWaveBottom }}>
  @use "../styles/globals.scss" as *;

  #footer {
    background-color: #493f3e;

    .foreground {
      padding: 220px;
      background-size: 12px 12px;
      background-position:
        0 0,
        18px 18px;
      background-image:
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0),
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0);
    }

    .bg-wave-top {
      position: absolute;
      background-image: var(--bgWaveTop);
      background-repeat: repeat-x;
      background-size: 338px 120px;
      background-position: center;
      width: 100%;
      height: 120px;
    }

    .bg-wave-bottom {
      position: relative;
      background-image: var(--bgWaveBottom);
      background-repeat: repeat-x;
      background-size: 338px 120px;
      background-position: center;
      width: 100%;
      height: 120px;
      margin-top: -120px;
      z-index: 10;
    }

    .copyright {
      height: 100px;
      color: #493f3e;
      background-color: $bg-color;
      font-size: 14px;
      padding: 40px;
      text-align: center;
      font-weight: 400;
      line-height: 1.5;
    }
  }
</style>
