---
import { banners, snsItems, footerAssets } from "@data/footer";
import Button from "@components/Button.astro";

const bgWaveTop = `url("${footerAssets.bgWaveTop}")`;
const bgWaveBottom = `url("${footerAssets.bgWaveBottom}")`;
---

<footer id="footer">
  <div class="bg-wave-top"></div>
  <div class="foreground">
    <div class="container">
      <div class="banner-wrapper">
        {
          banners.map((banner) => (
            <div class="banner">
              <a href={banner.href} target="_blank">
                <img src={banner.src} alt={banner.alt} loading="lazy" />
              </a>
            </div>
          ))
        }
      </div>

      <div class="sns-wrapper">
        {
          snsItems.map((item) => (
            <a href={item.href} target="_blank" class="sns-link">
              <img src={item.img} alt="SNS Icon" />
            </a>
          ))
        }
      </div>

      <div class="contact-button-row">
        <Button href="https://forms.gle/sxVbnxsRXtrWyPXx5">
          お問い合わせはこちら
        </Button>
      </div>
    </div>
  </div>
  <div class="bg-wave-bottom"></div>
  <div class="copyright">
    ©︎ユキヲ・COMICメテオ／邪神ちゃんドロップキック製作委員会
  </div>
</footer>

<style lang="scss" define:vars={{ bgWaveTop, bgWaveBottom }}>
  @use "../styles/globals.scss" as *;

  #footer {
    background-color: #493f3e;
    position: relative;
    width: 100%;

    .foreground {
      padding: 160px 0 100px 0;
      background-size: 12px 12px;
      background-position:
        0 0,
        18px 18px;
      background-image:
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0),
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0);
    }

    .banner-wrapper {
      display: grid;
      grid-template-columns: repeat(1, 1fr);
      gap: 20px;
      padding-top: 5rem;
      padding-bottom: 2.5rem;

      @media (min-width: 768px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (min-width: 992px) {
        grid-template-columns: repeat(3, 1fr);
      }

      .banner {
        width: 100%;
        display: flex;
        justify-content: center;

        a {
          display: block;
          width: 100%;
          max-width: 300px;
          height: 94px;
        }

        img {
          width: 100%;
          height: 100%;
          max-width: 300px;
          object-fit: cover;
          vertical-align: middle;
          border-style: none;
          border-radius: 5px;
          transition: transform 0.2s ease;

          &:hover {
            opacity: 0.8;
          }
        }
      }
    }

    .sns-wrapper {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-bottom: 40px;

      img {
        width: 100%;
        height: 100%;
        vertical-align: middle;
        transition: opacity 0.2s;

        &:hover {
          opacity: 0.8;
        }
      }
    }

    .contact-button-row {
      display: flex;
      justify-content: center;
      margin-bottom: 20px;
    }

    .bg-wave-top {
      position: absolute;
      top: 0;
      left: 0;
      background-image: var(--bgWaveTop);
      background-repeat: repeat-x;
      background-size: 338px 120px;
      background-position: center;
      width: 100%;
      height: 120px;
      z-index: 1;
    }

    .bg-wave-bottom {
      position: relative;
      background-image: var(--bgWaveBottom);
      background-repeat: repeat-x;
      background-size: 338px 120px;
      background-position: center;
      width: 100%;
      height: 120px;
      margin-top: -120px;
      z-index: 10;
    }

    .copyright {
      height: 100px;
      color: #493f3e;
      background-color: #ffffff;
      font-size: 14px;
      padding: 40px;
      text-align: center;
      font-weight: 400;
      line-height: 1.5;
      position: relative;
      z-index: 11;
    }
  }
</style>
