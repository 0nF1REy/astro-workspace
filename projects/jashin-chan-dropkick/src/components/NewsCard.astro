---
import type { NewsItem } from "@data/news";

interface Props {
  item: NewsItem;
}

const { item } = Astro.props;
---

<article class="news-card">
  <a href={item.href} class="card-link">
    <div class="thumbnail">
      <img
        src={item.image.src}
        alt={item.image.alt}
        width="300"
        height="169"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="content">
      <span class="date">{item.date}</span>
      <h6 class="title">{item.title}</h6>
      <p class="description">{item.description}</p>
    </div>
  </a>
</article>

<style lang="scss">
  @use "../styles/globals.scss" as *;

  .news-card {
    max-width: 300px;
    width: 100%;
    margin: 0 auto;
    background: $primary-color;
    color: #ffffff;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;

    .card-link {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      height: 100%;
      transition: opacity 0.2s ease;

      &:hover {
        opacity: 0.9;
      }
    }

    .thumbnail {
      width: 100%;
      height: 147px;
      flex-shrink: 0;
      overflow: hidden;
      border: solid 1px #979797;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
    }

    .content {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      flex: 1;

      .date {
        font-size: 14px;
        font-weight: lighter;
        margin-bottom: 0.5rem;
      }

      .title {
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 0.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.6em;
      }

      .description {
        font-size: 14px;
        font-weight: lighter;
        line-height: 1.2;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex-grow: 1;
      }
    }
  }
</style>
