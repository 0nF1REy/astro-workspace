---
import { getLatestNews } from "@data/news";
import type { NewsItem } from "@data/news";
import Button from "@components/Button.astro";
import NewsCard from "@components/NewsCard.astro";

const displayNews = getLatestNews(6);

const titleImage = "/assets/images/home/news/titles/ttl_new.png";
const titleImageMobile = "/assets/images/home/news/titles/ttl_sp_news.png";

const bgWave = "/assets/images/home/news/backgrounds/bg_news_wave.png";
const bgStar = "/assets/images/home/news/backgrounds/bg_news_star.png";
---

<section
  id="news"
  class="news-section"
  style={`background-image: url(${bgStar});`}
>
  <div class="container content-wrapper">
    <div class="header-row">
      <h1 class="page-title">
        <picture>
          <source srcset={titleImageMobile} media="(max-width: 750px)" />
          <img src={titleImage} alt="NEWS" class="title-image" />
        </picture>
      </h1>
    </div>

    <div class="news-grid">
      {displayNews.map((item: NewsItem) => <NewsCard item={item} />)}
    </div>

    <Button href="/news">もっと読む</Button>
  </div>

  <img src={bgWave} alt="" class="bg-wave-bottom" aria-hidden="true" />
</section>

<style lang="scss">
  @use "../../../styles/globals.scss" as *;

  .news-section {
    font-family: HiraKakuPro-W3;
    position: relative;
    background-repeat: repeat;
    background-position: top center;
    padding-top: 6rem;
    padding-bottom: 120px;
    overflow: hidden;

    .content-wrapper {
      position: relative;
      z-index: 5;
      padding-bottom: 6rem;
    }

    .bg-wave-bottom {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translate(-50%, 0);
      width: 1462px;
      z-index: 1;
      pointer-events: none;
      display: block;
      height: auto;
      max-width: 100vw;
      user-select: none;
    }

    .header-row {
      display: flex;
      justify-content: center;
      margin-bottom: 3rem;

      .page-title {
        margin: 0;
        .title-image {
          max-width: 100%;
          height: auto;
          display: block;
        }
      }
    }

    .news-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.3rem;
      padding-bottom: 9.5rem;
      align-items: stretch;

      @media (min-width: 640px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media screen and (max-width: 750px) {
      padding-top: 4rem;
      padding-bottom: 4rem;

      .content-wrapper {
        padding-bottom: 2rem;
      }

      .header-row {
        margin-bottom: 2rem;
        .title-image {
          max-width: 280px;
        }
      }

      .news-grid {
        padding-bottom: 4rem;
      }

      .bg-wave-bottom {
        display: none;
      }
    }
  }
</style>
