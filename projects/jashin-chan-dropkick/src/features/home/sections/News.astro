---
import { newsItems } from "@data/news";
import type { NewsItem } from "@data/news";
import Button from "@components/Button.astro";

const titleImage = "/assets/images/home/news/ttl_new.png";
const bgWave = "/assets/images/home/news/bg_news_wave.png";
const bgStar = "/assets/images/home/news/bg_news_star.png";
---

<section
  id="news"
  class="news-section"
  style={`background-image: url(${bgStar});`}
>
  <div class="container content-wrapper">
    <div class="header-row">
      <h1 class="page-title">
        <img src={titleImage} alt="NEWS" class="title-image" />
      </h1>
    </div>

    <div class="news-grid">
      {
        newsItems.map((item: NewsItem) => (
          <article class="news-card">
            <a href={item.href} class="card-link">
              <div class="thumbnail">
                <img
                  src={item.image.src}
                  srcset={item.image.srcset}
                  alt={item.image.alt}
                  width="300"
                  height="169"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="content">
                <span class="date">{item.date}</span>
                <h6 class="title">{item.title}</h6>
                <p class="description">{item.description}</p>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <Button href="/news">もっと読む</Button>
  </div>

  <img src={bgWave} alt="" class="bg-wave-bottom" aria-hidden="true" />
</section>

<style lang="scss">
  @use "../../../styles/globals.scss" as *;

  .news-section {
    position: relative;
    background-color: #fff;
    background-repeat: repeat;
    background-position: top center;
    padding-top: 6rem;
    padding-bottom: 120px;
    overflow: hidden;

    .content-wrapper {
      position: relative;
      z-index: 5;
      padding-bottom: 6rem;
    }

    .bg-wave-bottom {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translate(-50%, 0);
      width: 100%;
      margin-top: -215px;
      margin-left: 33px;
      z-index: 1;
      pointer-events: none;
      display: block;
      height: auto;
      max-width: 100vw;
      user-select: none;
      width: 1462px;
    }

    .header-row {
      display: flex;
      justify-content: center;
      margin-bottom: 3rem;

      .page-title {
        margin: 0;

        .title-image {
          max-width: 100%;
          height: auto;
          display: block;
        }
      }
    }

    .news-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.3rem;
      padding-bottom: 9.5rem;

      @media (min-width: 640px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media (min-width: 1024px) {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .news-card {
      max-width: 300px;
      width: 100%;
      margin: auto;
      background: $primary-color;
      color: #ffffff;
      border-radius: 10px;
      overflow: hidden;

      .card-link {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        height: 100%;
        transition: transform 0.3s ease;
      }
    }

    .thumbnail {
      height: 147px;
      border: solid 1px #979797;
      overflow: hidden;

      img {
        height: auto;
        width: 100%;
      }
    }

    .content {
      padding: 1.25rem;

      .title,
      .description {
        line-height: 1.2;
      }

      .date {
        font-size: 16px;
        font-weight: lighter;
        color: #e1e0e0;
        margin-bottom: 0.5rem;
        display: block;
      }

      .title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.3s ease;
      }

      .description {
        font-size: 16px;
        font-weight: lighter;
        color: #e1e0e0;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
    }
  }
</style>
