---
import { menuItems, type MenuItem } from "../../../data/menu";

const heroImage = {
  src: "/assets/images/home/hero/pachislo-jashin-chan.png",
  alt: "Jashin-chan",
};

const heroImageLogo = {
  src: "/assets/images/home/hero/jd-logo.svg",
  alt: "Jashin-chan Logo",
};

const heroImageTwitterBtn = {
  src: "/assets/images/home/hero/twitter-button.png",
  alt: "Twitter Button",
};

const hamburgerImg = "/assets/images/global/hamburger.png";

const colLeft: MenuItem[] = menuItems.slice(0, 5);
const colRight: MenuItem[] = menuItems.slice(5);
---

<section id="hero">
  <button id="hero-menu-toggle" class="mobile-menu-trigger">
    <img src={hamburgerImg} alt="Menu" />
  </button>

  <div id="hero-mobile-overlay" class="mobile-menu-overlay">
    <div class="menu-dialog">
      <ul class="mobile-nav-list">
        {
          menuItems.map((item) => (
            <li>
              <a href={item.href}>
                <img src={item.img} alt={item.id} />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="container">
    <div class="hero-wrapper">
      <div class="hero-content">
        <div class="logo-wrapper">
          <img
            src={heroImageLogo.src}
            alt={heroImageLogo.alt}
            class="logo-img"
          />
        </div>

        <nav class="nav-wrapper pc-only-nav">
          <div class="nav-grid">
            <ul class="nav-column">
              {
                colLeft.map((item: MenuItem) => (
                  <li>
                    <a href={item.href} class="nav-img-item" id={item.id}>
                      <img
                        src={item.img}
                        alt={item.id}
                        class="nav-img"
                        data-img={item.img}
                        data-imghover={item.imgHover}
                      />
                    </a>
                  </li>
                ))
              }
            </ul>
            <ul class="nav-column">
              {
                colRight.map((item: MenuItem) => (
                  <li>
                    <a href={item.href} class="nav-img-item" id={item.id}>
                      <img
                        src={item.img}
                        alt={item.id}
                        class="nav-img"
                        data-img={item.img}
                        data-imghover={item.imgHover}
                      />
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </nav>

        <div class="twitter-wrapper">
          <a
            href="https://twitter.com/jashinchan_PJ"
            class="twitter-link"
            target="_blank"
          >
            <img
              src={heroImageTwitterBtn.src}
              alt={heroImageTwitterBtn.alt}
              class="twitter-btn-img"
            />
          </a>
        </div>
      </div>

      <div class="hero-character">
        <img src={heroImage.src} alt={heroImage.alt} class="character-img" />
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  #hero {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: white;
    overflow: hidden;
    position: relative;
    padding-top: 2rem;

    .hero-wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      z-index: 10;
    }

    .logo-wrapper {
      width: 100%;
      margin-bottom: 4rem;
      margin-top: 6.5rem;
      text-align: center;

      .logo-img {
        width: 100%;
        height: auto;
        max-width: 430px;
      }
    }

    .nav-wrapper {
      display: flex;
      justify-content: center;
      width: 100%;
      max-width: 400px;
      margin-bottom: 4rem;
    }

    .nav-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
    }

    .nav-column {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }

    .twitter-wrapper {
      text-align: center;
    }

    .twitter-btn-img {
      max-width: 410px;
      min-width: 300px;
      width: 30vw;
      height: auto;
    }

    .hero-character {
      height: 100%;
    }

    .character-img {
      width: 36vw;
      max-width: 700px;
      height: auto;
      vertical-align: middle;
      display: block;
      margin: 0 auto;
    }

    .mobile-menu-trigger {
      display: none;
      position: absolute;
      top: 15px;
      right: 15px;
      z-index: 3000;
      background: none;
      border: none;
      width: 60px;
      cursor: pointer;
    }

    .mobile-menu-overlay {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: transparent;
      z-index: 2000;
      justify-content: center;
      align-items: center;

      &.active {
        display: flex;
      }

      .menu-dialog {
        background: transparent;
        width: 85%;
        max-width: 320px;
        max-height: 80vh;
        border-radius: 0;
        padding: 40px 20px;
        position: relative;
        overflow-y: auto;
      }

      .mobile-nav-list {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
        list-style: none;

        li a img {
          height: 32px;
          width: auto;
          display: block;
        }
      }
    }

    @media screen and (max-width: 750px) {
      .hero-wrapper {
        display: flex;
        flex-direction: column;
      }

      .hero-character {
        order: 1;
        width: 100%;
        margin-top: 60px;
        margin-bottom: 2rem;

        .character-img {
          width: 100%;
          max-width: 300px;
        }
      }

      .hero-content {
        order: 2;
        width: 100%;
      }

      .logo-wrapper {
        margin-top: 0;
        margin-bottom: 2rem;

        .logo-img {
          width: 100%;
          max-width: 300px;
        }
      }

      .twitter-wrapper {
        margin-bottom: 2rem;
      }

      .twitter-btn-img {
        width: 100%;
        max-width: 300px;
      }

      .pc-only-nav {
        display: none;
      }

      .mobile-menu-trigger {
        display: block;
      }
    }
  }
</style>

<script>
  function initHeroMobileMenu() {
    const toggleBtn = document.getElementById("hero-menu-toggle");
    const overlay = document.getElementById("hero-mobile-overlay");
    const body = document.body;

    toggleBtn?.addEventListener("click", () => {
      const isActive = overlay?.classList.toggle("active");
      body.style.overflow = isActive ? "hidden" : "";
    });

    const navLinks = document.querySelectorAll(".nav-img-item");
    navLinks.forEach((link) => {
      const img = link.querySelector(".nav-img") as HTMLImageElement;
      if (!img) return;
      const originalSrc = img.dataset.img;
      const hoverSrc = img.dataset.imghover;
      if (hoverSrc) {
        const preload = new Image();
        preload.src = hoverSrc;
      }
      link.addEventListener("mouseenter", () => {
        if (hoverSrc) img.src = hoverSrc;
      });
      link.addEventListener("mouseleave", () => {
        if (originalSrc) img.src = originalSrc;
      });
    });
  }

  initHeroMobileMenu();
  document.addEventListener("astro:after-swap", initHeroMobileMenu);
</script>
