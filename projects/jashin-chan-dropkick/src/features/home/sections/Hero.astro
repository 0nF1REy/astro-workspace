---
import { menuItems, type MenuItem } from "../../../data/menu";

const heroImage = {
  src: "/assets/images/home/hero/pachislo-jashin-chan.png",
  alt: "Jashin-chan",
};

const heroImageLogo = {
  src: "/assets/images/home/hero/jd-logo.svg",
  alt: "Jashin-chan Logo",
};

const heroImageTwitterBtn = {
  src: "/assets/images/home/hero/twitter-button.png",
  alt: "Twitter Button",
};

const colLeft: MenuItem[] = menuItems.slice(0, 5);
const colRight: MenuItem[] = menuItems.slice(5);
---

<section id="hero">
  <div class="container">
    <div class="hero-wrapper">
      <div class="hero-content">
        <div class="logo-wrapper">
          <img
            src={heroImageLogo.src}
            alt={heroImageLogo.alt}
            class="logo-img"
          />
        </div>

        <nav class="nav-wrapper">
          <div class="nav-grid">
            <ul class="nav-column">
              {
                colLeft.map((item: MenuItem) => (
                  <li>
                    <a
                      href={item.href || "#"}
                      class="nav-img-item"
                      id={item.id}
                      aria-label={item.id}
                    >
                      <img
                        src={item.img}
                        alt={item.id}
                        class="nav-img"
                        id={`img-${item.id}`}
                        data-img={item.img}
                        data-imghover={item.imgHover}
                      />
                    </a>
                  </li>
                ))
              }
            </ul>
            <ul class="nav-column">
              {
                colRight.map((item: MenuItem) => (
                  <li>
                    <a
                      href={item.href || "#"}
                      class="nav-img-item"
                      id={item.id}
                      aria-label={item.id}
                    >
                      <img
                        src={item.img}
                        alt={item.id}
                        class="nav-img"
                        id={`img-${item.id}`}
                        data-img={item.img}
                        data-imghover={item.imgHover}
                      />
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </nav>

        <div class="twitter-wrapper">
          <a
            href="https://twitter.com/jashinchan_PJ"
            class="twitter-link"
            target="_blank"
          >
            <img
              src={heroImageTwitterBtn.src}
              alt={heroImageTwitterBtn.alt}
              class="twitter-btn-img"
            />
          </a>
        </div>
      </div>

      <div class="hero-character">
        <img src={heroImage.src} alt={heroImage.alt} class="character-img" />
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  #hero {
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: white;
    overflow: hidden;
    padding: 1rem 0;

    .hero-wrapper {
      display: grid;
      grid-template-columns: 1fr;
      align-items: start;

      @media (min-width: 1024px) {
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
      }
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      z-index: 10;
    }

    .logo-wrapper {
      width: 100%;
      margin-bottom: 4rem;
      margin-top: 6.5rem;

      .logo-img {
        width: 100%;
        height: auto;
        max-width: 430px;
      }
    }

    .nav-wrapper {
      display: flex;
      justify-content: center;
      width: 100%;
      max-width: 400px;
      margin-bottom: 4rem;
    }

    .nav-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
    }

    .nav-column {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }

    .twitter-link {
      transition: transform 0.3s ease;

      &:hover {
        opacity: 0.8;
      }

      .twitter-btn-img {
        max-width: 410px;
        min-width: 300px;
        width: 30vw;
        height: auto;
      }
    }

    .hero-character {
      height: 100%;
    }

    .character-img {
      width: 36vw;
      max-width: 700px;
      height: auto;
      vertical-align: middle;
    }
  }
</style>

<script>
  const setupHoverImages = () => {
    const navLinks = document.querySelectorAll(".nav-img-item");

    navLinks.forEach((link) => {
      const img = link.querySelector(".nav-img") as HTMLImageElement;
      if (!img) return;

      const originalSrc = img.dataset.img;
      const hoverSrc = img.dataset.imghover;

      if (hoverSrc) {
        const preload = new Image();
        preload.src = hoverSrc;
      }

      link.addEventListener("mouseenter", () => {
        if (hoverSrc) img.src = hoverSrc;
      });

      link.addEventListener("mouseleave", () => {
        if (originalSrc) img.src = originalSrc;
      });
    });
  };

  setupHoverImages();
  document.addEventListener("astro:after-swap", setupHoverImages);
</script>
