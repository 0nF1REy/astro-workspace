---
const titleImage = "/assets/images/home/channel/ttl_jashinch.png";
const bgWaveTop = `url("/assets/images/home/channel/bg_wave_top.png")`;
const bgWaveBottom = `url("/assets/images/home/channel/bg_wave_bottom.png")`;

const channelVideos = [
  "https://www.youtube.com/embed/tEK9HjWKjx4",
  "https://www.youtube.com/embed/GQSX6jbTw2g",
  "https://www.youtube.com/embed/9K-2Qj0s4HY",
];
---

<section id="channel">
  <div class="bg-wave-top"></div>

  <div class="foreground">
    <div class="container">
      <div class="header-row">
        <a
          href="https://www.youtube.com/channel/UChu8Yu_w9z8DGFtXzuGvDlg"
          class="title-link"
          target="_blank"
        >
          <img
            class="title-image"
            src={titleImage}
            alt="Jashin-chan Logo"
            loading="lazy"
          />
        </a>
      </div>

      <div class="video-grid">
        {
          channelVideos.map((videoUrl) => (
            <div class="iframe-wrapper">
              <iframe
                src={videoUrl}
                allow="accelerometer; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                title="YouTube video player"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="bg-wave-bottom"></div>
</section>

<style lang="scss" define:vars={{ bgWaveTop, bgWaveBottom }}>
  #channel {
    background-image: linear-gradient(#75b370, #a9d08d);

    .bg-wave-top {
      position: absolute;
      background-image: var(--bgWaveTop);
      background-repeat: repeat-x;
      background-size: 338px 120px;
      background-position: center;
      width: 100%;
      height: 120px;
    }

    .bg-wave-bottom {
      position: relative;
      background-image: var(--bgWaveBottom);
      background-repeat: repeat-x;
      background-size: 338px 120px;
      background-position: center;
      width: 100%;
      height: 120px;
      margin-top: -120px;
      z-index: 10;
    }

    .foreground {
      padding: 220px;
      background-image:
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0),
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0);
      background-size: 12px 12px;
      background-position:
        0 0,
        18px 18px;
      width: 100%;
      height: 100%;
    }

    .header-row {
      display: flex;
      justify-content: center;
      margin-bottom: 3rem;

      .title-link {
        display: inline-block;
        transition: transform 0.3s ease;

        &:hover {
          transform: scale(1.02);
        }

        .title-image {
          max-width: 100%;
          height: auto;
        }
      }
    }

    .video-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;

      @media (min-width: 992px) {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .iframe-wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;

      iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
      }
    }
  }
</style>
