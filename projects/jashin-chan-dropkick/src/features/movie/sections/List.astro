---
import { movieVideos } from "@data/movie";
---

<section class="movie-list">
  <div class="movies-container">
    {
      movieVideos.map((url: string) => (
        <div class="iframe-wrapper">
          <iframe
            src={url}
            allow="accelerometer; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      ))
    }
  </div>
</section>

<style lang="scss">
  .movies-container {
    display: flex;
    flex-flow: row wrap;
    justify-content: space-between;
    gap: 2%;

    .iframe-wrapper {
      flex: 0 1 49%;
      margin-bottom: 20px;
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;

      iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 4px solid #f6ef94;
      }
    }
  }

  @media screen and (max-width: 750px) {
    .movies-container {
      .iframe-wrapper {
        flex: 0 1 100%;
      }
    }
  }
</style>
