---
import { businessInfoAssets } from "@data/business-info";
import Hero from "./sections/Hero.astro";
import {
  Productization,
  Promotion,
  JointProject,
} from "./sections/collaboration";

const { bgPattern, bgGirl, bgWave } = businessInfoAssets;
---

<div id="info">
  <div class="bg-image-girl"></div>
  <div class="container">
    <div class="page-business">
      <Hero />
      <Productization />
      <Promotion />
      <JointProject />
    </div>
  </div>
  <div class="info-wave"></div>
</div>

<script>
  function initTabs() {
    const containers = document.querySelectorAll(".tabs-container");
    containers.forEach((container) => {
      const buttons = container.querySelectorAll(".tab-btn");
      const panels = container.querySelectorAll(".tab-panel");

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const target = btn.getAttribute("data-target");

          buttons.forEach((b) => b.classList.remove("active"));
          panels.forEach((p) => p.classList.remove("active"));

          btn.classList.add("active");
          container.querySelector(`#${target}`)?.classList.add("active");
        });
      });
    });
  }
  document.addEventListener("astro:page-load", initTabs);
</script>

<style lang="scss" is:global>
  #footer {
    background-color: transparent !important;
  }
  #footer .bg-wave-top {
    display: none !important;
  }
  #footer .foreground {
    background-color: #493f3e !important;
    position: relative;
    z-index: 5;
    padding: 0px 0 100px 0 !important;
  }
</style>

<style lang="scss" define:vars={{ bgPattern, bgGirl, bgWave }}>
  @use "../../styles/globals.scss" as *;

  #info {
    font-family: HiraKakuPro-W3;
    position: relative;
    background-image: var(--bgPattern);
    background-repeat: repeat;
    background-size: auto;
    width: 100%;
    z-index: 1;
    overflow: visible;

    .page-business {
      position: relative;
      max-width: 954px;
      margin: 0 auto;
      padding: 135px 0 185px 0;
      z-index: 3;
    }

    .bg-image-girl {
      position: absolute;
      right: 0;
      bottom: -73px;
      height: 400px;
      width: 337px;
      background-image: var(--bgGirl);
      background-repeat: no-repeat;
      background-size: contain;
      z-index: 11;
    }

    .info-wave {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 120px;
      z-index: 11;
      background-color: #493f3e;
      background-image:
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0),
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0);
      background-size: 12px 12px;
      background-position:
        0 0,
        18px 18px;
      background-repeat: repeat;
      -webkit-mask-image: var(--bgWave);
      mask-image: var(--bgWave);
      -webkit-mask-size: 338px 120px;
      mask-size: 338px 120px;
      -webkit-mask-repeat: repeat-x;
      mask-repeat: repeat-x;
      -webkit-mask-position: center bottom;
      mask-position: center bottom;
    }

    @media screen and (max-width: 750px) {
      .bg-image-girl {
        display: none;
      }
      .page-business {
        padding: 80px 15px 185px 15px;
      }
    }
  }
</style>
