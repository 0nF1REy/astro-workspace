---
interface Row {
  channel: string;
  date: string;
  schedule: string;
  isHtml?: boolean;
}

interface Props {
  title: string;
  rows: Row[];
  note?: string;
}

const { title, rows, note } = Astro.props;
---

<section class="onair-section">
  <h2>{title}</h2>
  <div class="section-content">
    <table class="onair-table onair-table-3col">
      <tbody>
        {
          rows.map((row) => (
            <tr>
              <th>{row.channel}</th>
              {row.isHtml ? (
                <>
                  <td set:html={row.date} />
                  <td set:html={row.schedule} />
                </>
              ) : (
                <>
                  <td>{row.date}</td>
                  <td>{row.schedule}</td>
                </>
              )}
            </tr>
          ))
        }
      </tbody>
    </table>
    {note && <p class="note" set:html={note} />}
  </div>
</section>

<style lang="scss">
  @use './_onair-shared-styles.scss' as *;

  .onair-table th {
    width: 35%;
  }

  .onair-table td {
    width: 32.5%;
  }

  @media screen and (max-width: 750px) {
    .onair-table th {
      width: 35%;
    }

    .onair-table td {
      width: 32.5%;
    }
  }
</style>
