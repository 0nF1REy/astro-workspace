---
interface Props {
  title: string;
  rows: Array<{
    channel: string;
    schedule: string | { main: string; repeat?: string };
  }>;
  note?: string;
}

const { title, rows, note } = Astro.props;
---

<section class="onair-section">
  <h2>{title}</h2>
  <div class="section-content">
    <table class="onair-table">
      <tbody>
        {
          rows.map((row) => (
            <tr>
              <th>{row.channel}</th>
              <td>
                {typeof row.schedule === "string" ? (
                  row.schedule
                ) : (
                  <>
                    {row.schedule.main}
                    {row.schedule.repeat && (
                      <>
                        <br />
                        {row.schedule.repeat}
                      </>
                    )}
                  </>
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
    {note && <p class="note">{note}</p>}
  </div>
</section>

<style lang="scss">
  @use "./_onair-shared-styles.scss" as *;

  .onair-table th {
    width: 30%;
  }

  @media screen and (max-width: 750px) {
    .onair-table th {
      width: 40%;
    }
  }
</style>
