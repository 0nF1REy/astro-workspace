---
const bgPattern = `url("/assets/images/goods/hero/backgrounds/bg_pattern.png")`;
const bgGirl = `url("/assets/images/goods/hero/backgrounds/bg_character01.png")`;
const ttlGoods = "/assets/images/goods/hero/titles/ttl_goods.png";
const ttlSpGoods = "/assets/images/goods/hero/titles/ttl_sp_goods.png";
---

<section id="hero">
  <div class="bg-image-girl"></div>
  <div class="container">
    <div class="page-goods">
      <h1 class="page-title">
        <picture>
          <source srcset={ttlSpGoods} media="(max-width: 750px)" />
          <img src={ttlGoods} alt="GOODS" />
        </picture>
      </h1>
      <p class="centered">COMING SOON...</p>
    </div>
  </div>
</section>

<style lang="scss" define:vars={{ bgPattern, bgGirl }}>
  @use "../../../styles/globals.scss" as *;

  #hero {
    position: relative;
    background-image: var(--bgPattern);
    background-repeat: repeat;
    background-size: auto;
    width: 100%;
    overflow: hidden;

    .bg-image-girl {
      position: absolute;
      right: 0;
      bottom: 25px;
      height: 303px;
      width: 337px;
      background-image: var(--bgGirl);
      background-repeat: no-repeat;
      background-size: contain;
      z-index: 1;
    }

    .page-goods {
      max-width: 954px;
      padding-bottom: 80px;
      text-align: center;
      margin: 0 auto;
      padding: 135px 0 80px 0;

      .page-title {
        margin-bottom: 1.5rem;
        display: flex;
        justify-content: center;

        img {
          max-width: 100%;
          height: auto;
        }
      }

      .centered {
        text-align: center;
        font-size: 1.2rem;
        font-weight: bold;
        color: #493f3e;
      }
    }

    @media screen and (max-width: 750px) {
      .bg-image-girl {
        display: none;
      }

      .page-goods {
        margin: 30px auto;

        .page-title img {
          max-width: 280px;
        }
      }
    }
  }
</style>
