---
import { characters } from "@data/characters";

const bgPattern = `url("/assets/images/global/bg_pattern.png")`;
const bgGirl = `url("/assets/images/global/bg_character01.png")`;
const bgWave = `url("/assets/images/global/bg_wave_bottom.png")`;
const ttlCharacter = "/assets/images/character/titles/ttl_character.png";
const ttlSpCharacter = "/assets/images/character/titles/ttl_sp_character.png";
---

<section id="list">
  <div class="bg-image-girl"></div>
  <div class="container">
    <div class="page-character">
      <h1 class="page-title">
        <picture>
          <source srcset={ttlSpCharacter} media="(max-width: 750px)" />
          <img src={ttlCharacter} alt="CHARACTER" />
        </picture>
      </h1>

      <ul class="section-content-item">
        {
          characters.map((char) => (
            <li>
              <img src={char.image} alt={char.id} loading="lazy" />
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  <div class="list-wave"></div>
</section>

<style lang="scss" is:global>
  #footer {
    background-color: transparent !important;
  }

  #footer .bg-wave-top {
    display: none !important;
  }

  #footer .foreground {
    background-color: #493f3e !important;
    position: relative;
    z-index: 5;
    padding: 0px 0 100px 0 !important;
  }
</style>

<style lang="scss" define:vars={{ bgPattern, bgGirl, bgWave }}>
  @use "../../../styles/globals.scss" as *;

  #list {
    position: relative;
    background-image: var(--bgPattern);
    background-repeat: repeat;
    background-size: auto;
    width: 100%;
    z-index: 1;
    overflow: visible;

    .bg-image-girl {
      position: absolute;
      right: 0;
      bottom: -73px;
      height: 400px;
      width: 337px;
      background-image: var(--bgGirl);
      background-repeat: no-repeat;
      background-size: contain;
      z-index: 11;
    }

    .list-wave {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 120px;
      z-index: 11;
      background-color: #493f3e;
      background-image:
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0),
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0);
      background-size: 12px 12px;
      background-position:
        0 0,
        18px 18px;
      background-repeat: repeat;
      -webkit-mask-image: var(--bgWave);
      mask-image: var(--bgWave);
      -webkit-mask-size: 338px 120px;
      mask-size: 338px 120px;
      -webkit-mask-repeat: repeat-x;
      mask-repeat: repeat-x;
      -webkit-mask-position: center bottom;
      mask-position: center bottom;
    }

    .page-character {
      position: relative;
      max-width: 954px;
      text-align: center;
      margin: 0 auto;
      padding: 135px 0 185px 0;
      z-index: 3;

      .page-title {
        margin-bottom: 30px;
        display: flex;
        justify-content: center;
        img {
          max-width: 100%;
          height: auto;
        }
      }

      .section-content-item {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        list-style: none;
        padding: 0;
        margin: 0;

        li {
          margin-bottom: 3.1rem;
          img {
            width: 450px;
            height: auto;
            display: block;
          }
        }
      }
    }

    @media screen and (max-width: 1024px) {
      .page-character .section-content-item {
        justify-content: center;

        li img {
          width: 100%;
          max-width: 450px;
        }
      }
    }

    @media screen and (max-width: 750px) {
      .bg-image-girl {
        display: none;
      }
      .page-character {
        padding: 80px 0 100px 0;
        .page-title img {
          max-width: 280px;
        }
      }
    }
  }
</style>
