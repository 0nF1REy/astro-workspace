          </blockquote>
        </div>
      </div>
    </div>
  </div>
  <div class="info-wave"></div>
</section>

<style lang="scss" is:global>
  #footer {
    background-color: transparent !important;
  }
  #footer .bg-wave-top {
    display: none !important;
  }
  #footer .foreground {
    background-color: #493f3e !important;
    position: relative;
    z-index: 5;
    padding: 0px 0 100px 0 !important;
  }
</style>

<style lang="scss" define:vars={{ bgPattern, bgGirl, bgWave }}>
  @use "../../../styles/globals.scss" as *;

  #info {
    font-family: HiraKakuPro-W3;
    position: relative;
    background-image: var(--bgPattern);
    background-repeat: repeat;
    background-size: auto;
    width: 100%;
    z-index: 1;
    overflow: visible;

    .bg-image-girl {
      position: absolute;
      right: 0;
      bottom: -73px;
      height: 400px;
      width: 337px;
      background-image: var(--bgGirl);
      background-repeat: no-repeat;
      background-size: contain;
      z-index: 11;
    }

    .info-wave {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 120px;
      z-index: 11;
      background-color: #493f3e;
      background-image:
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0),
        radial-gradient(rgba(255, 255, 255, 0.3) 20%, transparent 0);
      background-size: 12px 12px;
      background-position:
        0 0,
        18px 18px;
      background-repeat: repeat;
      -webkit-mask-image: var(--bgWave);
      mask-image: var(--bgWave);
      -webkit-mask-size: 338px 120px;
      mask-size: 338px 120px;
      -webkit-mask-repeat: repeat-x;
      mask-repeat: repeat-x;
      -webkit-mask-position: center bottom;
      mask-position: center bottom;
    }

    .page-disc {
      position: relative;
      max-width: 954px;
      margin: 0 auto;
      padding: 135px 0 185px 0;
      z-index: 3;

      .page-title {
        margin-bottom: 30px;
        display: flex;
        justify-content: center;
        img {
          max-width: 100%;
          height: auto;
        }
      }
    }

    .section-header.short {
      padding: 10px;
      width: 30%;
      min-width: 200px;
      font-size: 20px;
      text-align: center;
      font-weight: bold;
      font-size: 25px;
      background: linear-gradient(#61ac69, #b4d69a);
      border-top-left-radius: 8px;
      border-top-right-radius: 8px;
      color: #fff;
      margin: 0;
    }

    .section-content {
      background-color: #fffef1;
      padding: 25px;
      border: 3px solid #b4d69a;
      border-bottom-left-radius: 10px;
      border-bottom-right-radius: 10px;
      word-break: break-all;
      word-wrap: break-word;
    }

    .post-title {
      font-size: 20px;
      font-weight: bold;
      color: #fb4c69;
      border-bottom: 2px dotted #62ad6a;
      padding-bottom: 10px;
      margin-bottom: 10px;
    }

    h2 {
      text-align: center;
      font-weight: bold;
      font-size: 25px;
      background: linear-gradient(#61ac69, #b4d69a);
      border-top-left-radius: 8px;
      border-top-right-radius: 8px;
      color: #fff;
      margin: 0;
      padding: 25px;
    }

    p {
      margin: 15px 0;
    }

    figure {
      margin: 0 0 1rem;
    }

    h3 {
      font-size: 1.75rem;
    }

    ul {
      margin-top: 0;
      margin-bottom: 1rem;
    }

    .block-quote {
      margin: 0 0 1rem;
    }

    .has-text-align-center {
      text-align: center;
    }

    @media screen and (max-width: 750px) {
      .bg-image-girl {
        display: none;
      }
      .page-disc {
        padding: 80px 15px 185px 15px;
        .page-title img {
          max-width: 280px;
        }
      }
    }
  }
</style>
