              </figure>
            </div>

            <div>
              <figure>
                <img src="/assets/images/disc/info/jashin_02.jpg" />
              </figure>
            </div>

            <div>
              <figure>
                <img src="/assets/images/disc/info/jashin_03.jpg" />
              </figure>
            </div>
          </div>

          <figure>
