---
import { discAssets } from "@data/disc";

const { ttlDisc, ttlSpDisc } = discAssets;
---

<header class="hero-intro">
  <h1 class="page-title">
    <picture>
      <source srcset={ttlSpDisc} media="(max-width: 750px)" />
      <img src={ttlDisc} alt="CD & DVD & BD" />
    </picture>
  </h1>
</header>
