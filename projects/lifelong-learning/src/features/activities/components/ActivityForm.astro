---
import Button from "@ui/Button.astro";
import Checkbox from "@ui/Checkbox.astro";
import TextArea from "@ui/TextArea.astro";
import TextInput from "@ui/TextInput.astro";
---

<form class="activity-form" id="activity-form">
  <TextInput
    name="Tipo de Atividade"
    inputId={101}
    placeholder="Ex: Corrida, Musculação"
  />
  <TextInput name="Distância" inputId={102} placeholder="Ex: 5.2" />
  <TextInput name="Duração" inputId={103} placeholder="Ex: 30:00" />
  <TextArea name="Notas" id={104} />

  <Checkbox
    checked={false}
    inputId={105}
    name="isCompleted"
    label="Atividade Concluída"
  />

  <div class="form-actions">
    <Button intent="secondary" type="button" data-close-dialog>Cancelar</Button>
    <Button intent="primary" type="submit">Salvar Treino</Button>
  </div>
</form>

<style lang="scss">
  .activity-form {
    display: grid;
    gap: 1.25rem;
  }
  .form-actions {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    :global(button) {
      flex: 1;
    }
  }
</style>

<script>
  import sanitize from "sanitize-html";
  const form = document.getElementById("activity-form") as HTMLFormElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    // Lógica de fetch
    const payload = {
      type: sanitize(formData.get("tipo-de-atividade") as string),
      distance: sanitize(formData.get("distancia") as string),
      duration: sanitize(formData.get("duracao") as string),
      notes: sanitize(formData.get("notas") as string),
      isCompleted: formData.get("iscompleted") === "on",
    };

    try {
      const res = await fetch("/api/activities", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        form.reset();
        location.reload();
      } else {
        throw new Error("Erro ao salvar atividade");
      }
    } catch (error) {
      alert(error instanceof Error ? error.message : "Erro desconhecido");
    }
  });

  // Botão cancelar
  form.querySelector("[data-close-dialog]")?.addEventListener("click", () => {
    const dialog = form.closest("dialog");
    if (dialog) dialog.close();
  });
</script>
