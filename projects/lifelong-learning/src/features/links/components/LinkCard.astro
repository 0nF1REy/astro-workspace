---
import Link from "@ui/Link.astro";
import Button from "@ui/Button.astro";

export type LinkProps = {
  id: number;
  title: string;
  url: string;
  description: string;
  isRead: boolean;
};

interface Props {
  link: LinkProps;
}

const { link } = Astro.props as Props;
---

<article class="link-card" data-link-card>
  <div class="link-card__header">
    <h3 class="link-card__title">{link.title}</h3>
    <div class="link-card__status">
      {link.isRead && <span class="link-card__badge">Lido</span>}
    </div>
  </div>

  <p class="link-card__description">{link.description}</p>

  <div class="link-card__footer">
    <Link href={link.url} target="_blank" rel="noopener noreferrer">
      <i class="fa-solid fa-arrow-up-right-from-square"></i>
      <span>Abrir Link</span>
    </Link>

    <div class="link-card__actions">
      <Button
        intent="secondary"
        classes="link-card__icon-button link-card__icon-button--edit"
        data-edit
        data-id={link.id}
        data-title={link.title}
        data-description={link.description}
        data-url={link.url}
        data-is-read={String(link.isRead)}
        aria-label={`Editar link: ${link.title}`}
      >
        <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
      </Button>

      <Button
        intent="secondary"
        classes={`link-card__icon-button link-card__icon-button--${
          link.isRead ? "read" : "unread"
        }`}
        data-toggle-read
        data-id={link.id}
        aria-label={`Marcar ${link.isRead ? "como não lido" : "como lido"}: ${link.title}`}
      >
        <i
          class={`fa-solid ${link.isRead ? "fa-check" : "fa-square"}`}
          aria-hidden="true"></i>
      </Button>

      <Button
        intent="secondary"
        classes="link-card__icon-button link-card__icon-button--delete"
        data-delete
        data-id={link.id}
        aria-label={`Deletar link: ${link.title}`}
      >
        <i class="fa-solid fa-trash" aria-hidden="true"></i>
      </Button>
    </div>
  </div>
</article>

<style lang="scss">
  .link-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    height: 100%;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: all 0.3s ease;

    &:hover {
      background: var(--surface-light);
      border-color: rgba(251, 146, 60, 0.3);
      box-shadow: 0 12px 24px rgba(251, 146, 60, 0.1);
    }
  }

  .link-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.5rem;
  }

  .link-card__title {
    margin: 0;
    color: var(--cream);
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.3;
    flex: 1;
    min-width: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .link-card__status {
    flex-shrink: 0;
  }

  :global(.link-card__badge) {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(251, 146, 60, 0.15);
    color: var(--orange);
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .link-card__description {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .link-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .link-card__actions {
    display: flex;
    gap: 0.5rem;
  }

  .link-card__icon-button {
    width: 2.6rem;
    height: 2.6rem;
    padding: 0;
    border-radius: 9999px;
    border-width: 1px;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease;

    i {
      font-size: 0.95rem;
    }

    &:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.18);
    }
  }

  .link-card__icon-button--edit {
    color: #93c5fd;
    border-color: rgba(59, 130, 246, 0.35);
    background: rgba(30, 58, 138, 0.2);

    &:hover {
      color: #bfdbfe;
      border-color: rgba(59, 130, 246, 0.55);
      background: rgba(30, 64, 175, 0.3);
    }
  }

  .link-card__icon-button--delete {
    color: #fca5a5;
    border-color: rgba(248, 113, 113, 0.35);
    background: rgba(127, 29, 29, 0.18);

    &:hover {
      color: #fecaca;
      border-color: rgba(248, 113, 113, 0.55);
      background: rgba(153, 27, 27, 0.28);
    }
  }

  .link-card__icon-button--read {
    color: #86efac;
    border-color: rgba(74, 222, 128, 0.35);
    background: rgba(20, 83, 45, 0.2);

    &:hover {
      color: #bbf7d0;
      border-color: rgba(74, 222, 128, 0.55);
      background: rgba(22, 101, 52, 0.3);
    }
  }

  .link-card__icon-button--unread {
    color: #fde68a;
    border-color: rgba(251, 191, 36, 0.35);
    background: rgba(120, 53, 15, 0.2);

    &:hover {
      color: #fef3c7;
      border-color: rgba(251, 191, 36, 0.55);
      background: rgba(146, 64, 14, 0.3);
    }
  }
</style>

<script>
  const deleteButtons = document.querySelectorAll(
    "[data-delete]",
  ) as NodeListOf<HTMLButtonElement>;
  const toggleButtons = document.querySelectorAll(
    "[data-toggle-read]",
  ) as NodeListOf<HTMLButtonElement>;

  const notifyLinksChanged = () => {
    window.dispatchEvent(new Event("dev-links:changed"));
  };

  deleteButtons.forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.id;
      if (!id) return;

      try {
        const res = await fetch(`/api/links/${id}`, { method: "DELETE" });
        if (!res.ok) throw new Error("Falha ao deletar");
        btn.closest("[data-link-card]")?.remove();
        notifyLinksChanged();
      } catch (e) {
        console.error(e);
        alert("Erro ao deletar link");
      }
    });
  });

  toggleButtons.forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.id;
      if (!id) return;

      try {
        const card = btn.closest("[data-link-card]");
        const badge = card?.querySelector(".link-card__badge");
        const icon = btn.querySelector("i");
        const newStatus = !badge;

        const res = await fetch(`/api/links/${id}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ isRead: newStatus }),
        });

        if (!res.ok) throw new Error("Falha ao atualizar");

        if (card) {
          if (newStatus) {
            if (!badge) {
              const statusWrapper = card.querySelector(".link-card__status");
              if (statusWrapper) {
                statusWrapper.innerHTML =
                  '<span class="link-card__badge">Lido</span>';
              }
            }

            btn.setAttribute(
              "aria-label",
              `Marcar como não lido: ${card.querySelector(".link-card__title")?.textContent ?? "link"}`,
            );
            btn.classList.remove("link-card__icon-button--unread");
            btn.classList.add("link-card__icon-button--read");
            icon?.classList.remove("fa-square");
            icon?.classList.add("fa-check");
          } else {
            badge?.remove();
            btn.setAttribute(
              "aria-label",
              `Marcar como lido: ${card.querySelector(".link-card__title")?.textContent ?? "link"}`,
            );
            btn.classList.remove("link-card__icon-button--read");
            btn.classList.add("link-card__icon-button--unread");
            icon?.classList.remove("fa-check");
            icon?.classList.add("fa-square");
          }
        }

        notifyLinksChanged();
      } catch (e) {
        console.error(e);
        alert("Erro ao atualizar link");
      }
    });
  });
</script>
