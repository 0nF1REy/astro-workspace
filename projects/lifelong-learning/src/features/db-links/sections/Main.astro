---
import { Links, db } from "astro:db";

const links = await db.select().from(Links);

type LinkItem = (typeof links)[number];
---

<section class="page">
  <section class="hero surface-card">
    <div class="hero__content">
      <p class="hero__eyebrow">Workspace</p>

      <h1 class="hero__title title-gradient">Astro DB Links</h1>

      <p class="hero__description">Links armazenados utilizando Astro DB.</p>
    </div>
  </section>

  <section class="links-grid">
    {
      links.map((link: LinkItem) => (
        <article class="link-card surface-card">
          <div class="link-card__top">
            <div class="link-card__icon">
              <i class="fa-solid fa-link" />
            </div>

            <div class="link-card__content">
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="link-card__title"
              >
                {link.title}
              </a>

              <time class="link-card__date" datetime={link.date.toISOString()}>
                <i class="fa-regular fa-calendar" />

                {link.date.toLocaleDateString("pt-BR")}
              </time>
            </div>
          </div>

          <div class="link-card__meta">
            <div
              class:list={[
                "meta-badge",
                link.isRead ? "meta-badge--success" : "meta-badge--danger",
              ]}
            >
              <i
                class:list={[
                  "fa-solid",
                  link.isRead ? "fa-circle-check" : "fa-circle-xmark",
                ]}
              />

              <span>{link.isRead ? "Lido" : "Não lido"}</span>
            </div>

            <div class="meta-badge meta-badge--accent">
              <i class="fa-solid fa-arrow-trend-up" />

              <span>{link.upvoteNum.toLocaleString()} votos</span>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</section>

<style lang="scss">
  .page {
    display: grid;
    gap: 1.5rem;
  }

  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";

    position: absolute;
    inset: 0;

    background: radial-gradient(
      circle at top right,
      rgba(251, 146, 60, 0.14),
      transparent 30%
    );

    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;

    display: grid;
    gap: 0.75rem;
  }

  .hero__eyebrow {
    color: var(--muted);

    font-size: 0.82rem;
    font-weight: 700;

    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);

    line-height: 0.95;
    font-weight: 900;

    background: linear-gradient(135deg, var(--orange), var(--cream));

    background-clip: text;
    -webkit-background-clip: text;

    -webkit-text-fill-color: transparent;
  }

  .hero__description {
    color: var(--muted);

    max-width: 52ch;

    line-height: 1.7;
  }

  .links-grid {
    display: grid;

    gap: 1rem;

    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
  }

  .link-card {
    position: relative;

    display: grid;
    gap: 1.5rem;

    overflow: hidden;
  }

  .link-card::before {
    content: "";

    position: absolute;
    inset: 0;

    background: radial-gradient(
      circle at top right,
      rgba(251, 146, 60, 0.14),
      transparent 28%
    );

    pointer-events: none;
  }

  .link-card__top {
    position: relative;
    z-index: 1;

    display: flex;
    align-items: flex-start;

    gap: 1rem;
  }

  .link-card__icon {
    width: 3rem;
    height: 3rem;

    flex-shrink: 0;

    display: grid;
    place-items: center;

    border-radius: 18px;

    background: linear-gradient(
      135deg,
      rgba(251, 146, 60, 0.2),
      rgba(253, 230, 138, 0.08)
    );

    border: 1px solid rgba(253, 230, 138, 0.08);

    color: var(--orange);

    font-size: 1.1rem;
  }

  .link-card__content {
    display: grid;

    gap: 0.5rem;

    min-width: 0;
  }

  .link-card__title {
    color: var(--cream);

    text-decoration: none;

    font-size: 1.2rem;
    font-weight: 800;

    line-height: 1.3;

    transition: color 0.2s ease;
  }

  .link-card__title:hover {
    color: var(--orange);
  }

  .link-card__date {
    display: inline-flex;
    align-items: center;

    gap: 0.45rem;

    color: var(--muted);

    font-size: 0.92rem;
  }

  .link-card__meta {
    position: relative;
    z-index: 1;

    display: flex;
    flex-wrap: wrap;

    gap: 0.75rem;
  }

  .meta-badge {
    display: inline-flex;
    align-items: center;

    gap: 0.5rem;

    padding: 0.72rem 0.95rem;

    border-radius: 999px;

    font-size: 0.9rem;
    font-weight: 700;

    border: 1px solid transparent;
  }

  .meta-badge--success {
    background: rgba(74, 222, 128, 0.12);

    border-color: rgba(74, 222, 128, 0.18);

    color: #4ade80;
  }

  .meta-badge--danger {
    background: rgba(248, 113, 113, 0.12);

    border-color: rgba(248, 113, 113, 0.18);

    color: #f87171;
  }

  .meta-badge--accent {
    background: rgba(251, 146, 60, 0.12);

    border-color: rgba(251, 146, 60, 0.18);

    color: var(--orange);
  }

  @media (max-width: 640px) {
    .hero__title {
      line-height: 1;
    }

    .link-card__top {
      flex-direction: column;
    }

    .link-card__meta {
      flex-direction: column;
    }

    .meta-badge {
      justify-content: center;
    }
  }
</style>
