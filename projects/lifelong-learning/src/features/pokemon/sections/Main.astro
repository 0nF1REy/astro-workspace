---
import { fetchPokemon } from "@lib/pokemon/fetchPokemon";
import { POKEMON_PAGE_SIZE } from "@lib/pokemon/pagination";

const pokemonList = await fetchPokemon();
const formatId = (id: number) => `#${String(id).padStart(3, "0")}`;
const initialCount = Math.min(POKEMON_PAGE_SIZE, pokemonList.length);
---

<section class="pokemon-explorer" data-pokemon-explorer>
  <div class="pokemon-explorer__hero surface-card">
    <p class="pokemon-explorer__eyebrow">Pokédex Hub</p>
    <h1 class="title-gradient">Pokémon</h1>
    <p class="pokemon-explorer__lead">
      Exploração técnica da PokeAPI utilizando <strong>Snapshot Fallback</strong
      > e
      <strong>Resilient Fetching</strong>. Dados capturados e processados no
      servidor para máxima performance.
    </p>
    <div class="pokemon-explorer__stats">
      <span class="stat-tag">
        <i class="fa-solid fa-microchip"></i>
        <span data-count>{initialCount}</span> de {pokemonList.length} exibidos
      </span>
    </div>
  </div>

  <div class="pokemon-grid" data-grid>
    {
      pokemonList.map((pokemon, index) => (
        <a
          href={`/pokemon/${pokemon.id}`}
          class="pokemon-card-link"
          data-index={index}
          style={index >= POKEMON_PAGE_SIZE ? "display: none;" : ""}
        >
          <article class="pokemon-card surface-card">
            <header class="pokemon-card__header">
              <span class="pokemon-card__id">{formatId(pokemon.id)}</span>
              <div class="pokemon-card__types">
                {pokemon.types.map((type: string) => (
                  <span class:list={["type-badge", `type-badge--${type}`]}>
                    {type}
                  </span>
                ))}
              </div>
            </header>

            <div class="pokemon-card__image-container">
              <img
                src={pokemon.image}
                alt={pokemon.name}
                class="pokemon-card__img"
                loading={index < POKEMON_PAGE_SIZE ? "eager" : "lazy"}
                decoding="async"
              />
            </div>

            <footer class="pokemon-card__info">
              <h2 class="pokemon-card__name">{pokemon.name}</h2>
              <div class="pokemon-card__metrics">
                <div class="metric">
                  <span>Altura</span>
                  <strong>{pokemon.height / 10}m</strong>
                </div>
                <div class="metric">
                  <span>Peso</span>
                  <strong>{pokemon.weight / 10}kg</strong>
                </div>
              </div>
            </footer>
          </article>
        </a>
      ))
    }
  </div>

  {
    pokemonList.length > POKEMON_PAGE_SIZE && (
      <div class="pokemon-explorer__actions">
        <button class="load-more-btn" data-load-more>
          <i class="fa-solid fa-plus" />
          Carregar Mais
        </button>
      </div>
    )
  }
</section>

<script is:inline define:vars={{ POKEMON_PAGE_SIZE }}>
  const explorer = document.querySelector("[data-pokemon-explorer]");
  const grid = explorer?.querySelector("[data-grid]");
  const loadMoreBtn = explorer?.querySelector("[data-load-more]");
  const countDisplay = explorer?.querySelector("[data-count]");

  let currentVisible = POKEMON_PAGE_SIZE;

  loadMoreBtn?.addEventListener("click", () => {
    const cards = grid.querySelectorAll(".pokemon-card-link");
    const nextLimit = currentVisible + POKEMON_PAGE_SIZE;

    cards.forEach((card, index) => {
      if (index >= currentVisible && index < nextLimit) {
        card.style.display = "grid";
        card.classList.add("fade-in");
      }
    });

    currentVisible = nextLimit;

    if (countDisplay)
      countDisplay.textContent = Math.min(currentVisible, cards.length);
    if (currentVisible >= cards.length) loadMoreBtn.style.display = "none";
  });
</script>

<style lang="scss">
  .pokemon-explorer {
    display: grid;
    gap: 2rem;

    &__hero {
      display: grid;
      gap: 0.85rem;
      padding: 2.5rem;
    }

    &__eyebrow {
      color: var(--muted);
      font-size: 0.82rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 700;
    }

    &__lead {
      max-width: 65ch;
      color: var(--muted);
      line-height: 1.7;
      font-size: 1.05rem;
      strong {
        color: var(--cream);
      }
    }

    &__stats {
      margin-top: 0.5rem;
      .stat-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem;
        background: rgba(251, 146, 60, 0.1);
        border: 1px solid rgba(251, 146, 60, 0.2);
        border-radius: 8px;
        color: var(--orange);
        font-size: 0.85rem;
        font-weight: 700;
      }
    }

    &__actions {
      display: flex;
      justify-content: center;
      padding: 2rem 0;
    }
  }

  .pokemon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .pokemon-card-link {
    text-decoration: none;
    color: inherit;
    display: grid;
    outline: none;

    &:focus-visible .pokemon-card {
      border-color: var(--orange);
      box-shadow: 0 0 0 2px var(--orange);
    }
  }

  .pokemon-card {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    position: relative;
    height: 100%;

    &.fade-in {
      animation: fadeIn 0.5s ease forwards;
    }

    &__id {
      font-family: monospace;
      font-weight: 800;
      color: var(--muted);
      opacity: 0.5;
    }

    &__types {
      display: flex;
      gap: 0.4rem;
    }

    &__image-container {
      display: grid;
      place-items: center;
      padding: 1rem;
      background: radial-gradient(
        circle,
        rgba(251, 146, 60, 0.08) 0%,
        transparent 70%
      );
      border-radius: 20px;
    }

    &__img {
      width: 160px;
      height: 160px;
      object-fit: contain;
      filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.3));
    }

    &__name {
      margin: 0.5rem 0;
      font-size: 1.6rem;
      color: var(--cream);
      text-transform: capitalize;
      text-align: center;
    }

    &__metrics {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(253, 230, 138, 0.08);

      .metric {
        display: grid;
        text-align: center;
        span {
          font-size: 0.7rem;
          text-transform: uppercase;
          color: var(--muted);
        }
        strong {
          color: var(--text);
          font-size: 1rem;
        }
      }
    }
  }

  .load-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background: var(--orange);
    color: var(--bg);
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 800;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 10px 20px rgba(251, 146, 60, 0.2);

    &:hover {
      transform: translateY(-3px);
      filter: brightness(1.1);
      box-shadow: 0 15px 25px rgba(251, 146, 60, 0.3);
    }
  }

  .type-badge {
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    background: var(--brown);
    border: 1px solid var(--border);

    &--fire {
      border-color: #ef4444;
      color: #fca5a5;
    }
    &--water {
      border-color: #3b82f6;
      color: #93c5fd;
    }
    &--grass {
      border-color: #22c55e;
      color: #86efac;
    }
    &--electric {
      border-color: #eab308;
      color: #fde047;
    }
    &--poison {
      border-color: #a855f7;
      color: #d8b4fe;
    }
    &--bug {
      border-color: #84cc16;
      color: #bef264;
    }
    &--normal {
      border-color: #94a3b8;
      color: #cbd5e1;
    }
    &--flying {
      border-color: #60a5fa;
      color: #bae6fd;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
