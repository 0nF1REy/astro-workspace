---
import { getImage } from "astro:assets";
import dots from "@assets/images/dots.png";
import LinkCard from "@components/LinkCard.astro";
import Button from "@components/ui/Button.astro";
import Dialog from "@components/ui/Dialog.astro";

const dotsImage = await getImage({
  src: dots,
  format: "avif",
});
---

<section class="dev-links">
  <div
    class="dev-links__dots dev-links__dots--top"
    style={`background-image: url(${dotsImage.src});`}
  >
  </div>

  <div class="dev-links__wrapper">
    <header class="dev-links__header surface-card">
      <div class="dev-links__hero-copy">
        <p class="dev-links__eyebrow">Workspace</p>
        <h1 class="dev-links__title title-gradient">Dev Links</h1>
      </div>

      <Button intent="accent" id="open-dialog"> Adicionar Link </Button>
    </header>

    <div class="dev-links__content surface-card">
      <div class="dev-links__grid">
        <!-- <LinkCard link={link} /> -->
      </div>
    </div>

    <Dialog />
  </div>

  <div
    class="dev-links__dots dev-links__dots--bottom"
    style={`background-image: url(${dotsImage.src});`}
  >
  </div>
</section>

<style lang="scss">
  .dev-links {
    position: relative;

    overflow-x: hidden;

    min-height: 100vh;
    padding: clamp(1rem, 2.5vw, 2rem);

    background:
      radial-gradient(circle at top, rgba(251, 146, 60, 0.16), transparent 26%),
      radial-gradient(
        circle at bottom right,
        rgba(253, 230, 138, 0.08),
        transparent 22%
      ),
      linear-gradient(to bottom, #191612, #120f0d);

    color: var(--text);

    &__wrapper {
      position: relative;

      display: grid;
      gap: 1rem;

      width: min(100%, 1200px);
      margin-inline: auto;

      overflow: hidden;
    }

    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;

      padding: 1.25rem 1.5rem;

      @media (max-width: 640px) {
        flex-direction: column;
        align-items: stretch;
      }
    }

    &__hero-copy {
      display: grid;
      gap: 0.35rem;
    }

    &__eyebrow {
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    &__title {
      margin: 0;

      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 0.95;
      font-weight: 800;

      text-shadow: 0 10px 15px rgba(0, 0, 0, 0.25);
    }

    &__content {
      position: relative;

      padding: 1.25rem;

      &::after {
        content: "";

        position: absolute;

        left: 50%;
        bottom: -25%;

        width: 75%;
        height: 24rem;

        border-radius: 9999px;

        background-color: var(--orange);

        opacity: 0.18;

        transform: translateX(-50%);

        filter: blur(70px);

        mix-blend-mode: screen;

        z-index: -1;
      }
    }

    &__grid {
      display: grid;
      gap: 1rem;

      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));

      align-items: start;
    }

    &__dots {
      position: absolute;

      left: 0;
      right: 0;

      height: 15rem;

      background-repeat: repeat;

      mix-blend-mode: screen;

      z-index: -10;

      &--top {
        top: 0;

        opacity: 0.2;

        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 1),
          rgba(0, 0, 0, 0)
        );

        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 1),
          rgba(0, 0, 0, 0)
        );
      }

      &--bottom {
        bottom: 0;

        opacity: 0.18;

        -webkit-mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1),
          rgba(0, 0, 0, 0)
        );

        mask-image: linear-gradient(to top, rgba(0, 0, 0, 1), rgba(0, 0, 0, 0));
      }
    }
  }
</style>
