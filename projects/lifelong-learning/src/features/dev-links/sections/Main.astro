---
import LinkCard, { type LinkProps } from "@components/LinkCard.astro";
import Button from "@components/ui/Button.astro";
import Dialog from "@components/ui/Dialog.astro";

const req = await fetch(`${Astro.url.origin}/api/links`);

const res = await req.json();

const links = res.data ?? [];
---

<section class="dev-links">
  <div class="dev-links__wrapper">
    <header class="dev-links__header surface-card">
      <div class="dev-links__hero-copy">
        <p class="dev-links__eyebrow">Workspace</p>

        <h1 class="dev-links__title title-gradient">Dev Links</h1>
      </div>

      {
        links.length > 0 && (
          <Button intent="accent" data-open-dialog>
            <i class="fa-solid fa-plus" />
            Adicionar Link
          </Button>
        )
      }
    </header>

    <div class="dev-links__content surface-card">
      <div class="dev-links__grid">
        {
          links.length > 0 ? (
            links.map((link: LinkProps) => <LinkCard link={link} />)
          ) : (
            <div class="dev-links__empty">
              <div class="dev-links__empty-icon">
                <i class="fa-solid fa-link" />
              </div>
              <h3 class="dev-links__empty-title">Nenhum link salvo ainda</h3>
              <p class="dev-links__empty-text">
                Comece adicionando seu primeiro link. Você pode salvar links
                úteis e organizá-los para referência futura.
              </p>
              <Button
                intent="accent"
                data-open-dialog
                class="dev-links__empty-cta"
              >
                <i class="fa-solid fa-plus" />
                Adicionar Primeiro Link
              </Button>
            </div>
          )
        }
      </div>
    </div>

    <Dialog />
  </div>
</section>

<style lang="scss">
  .dev-links {
    position: relative;

    overflow-x: hidden;

    min-height: 100vh;

    color: var(--text);

    &__empty {
      grid-column: 1 / -1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 3rem 1.5rem;
      text-align: center;
    }

    &__empty-icon {
      font-size: 3.5rem;
      color: var(--orange);
      margin-bottom: 1rem;
      opacity: 0.8;
    }

    &__empty-title {
      margin: 0 0 0.75rem 0;
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--cream);
    }

    &__empty-text {
      margin: 0 0 1.75rem 0;
      color: var(--muted);
      max-width: 35ch;
      line-height: 1.6;
    }

    &__empty-cta {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    &__wrapper {
      position: relative;

      display: grid;
      gap: 1rem;

      width: min(100%, 1200px);

      margin-inline: auto;

      overflow: hidden;
    }

    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;

      gap: 1rem;

      padding: 1.25rem 1.5rem;

      @media (max-width: 640px) {
        flex-direction: column;
        align-items: stretch;
      }
    }

    &__hero-copy {
      display: grid;
      gap: 0.35rem;
    }

    &__eyebrow {
      margin: 0;

      color: var(--muted);

      font-size: 0.82rem;
      font-weight: 700;

      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    &__title {
      margin: 0;

      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 0.95;
      font-weight: 800;

      text-shadow: 0 10px 15px rgba(0, 0, 0, 0.25);
    }

    &__content {
      position: relative;

      padding: 1.25rem;

      &::after {
        content: "";

        position: absolute;

        left: 50%;
        bottom: -25%;

        width: 75%;
        height: 24rem;

        border-radius: 9999px;

        background-color: var(--orange);

        opacity: 0.18;

        transform: translateX(-50%);

        filter: blur(70px);

        mix-blend-mode: screen;

        z-index: -1;
      }
    }

    &__grid {
      display: grid;

      gap: 1rem;

      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));

      align-items: start;
    }
  }
</style>
