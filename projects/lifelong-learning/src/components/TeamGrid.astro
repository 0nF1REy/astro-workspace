---
interface TeamMember {
  id?: number;
  name: string;
  role: string;
  email: string;
  department: string;
  avatar?: string;
}

const { members } = Astro.props as { members: TeamMember[] };
---

<div class="team-grid">
  {members.map((member) => (
    <article class="team-card">
      <img
        class="team-card__avatar"
        src={member.avatar ?? "https://i.pravatar.cc/300?u=default"}
        alt={member.name}
        loading="lazy"
        decoding="async"
      />
      <div class="team-card__info">
        <p class="team-card__department">{member.department}</p>
        <h3 class="team-card__name">{member.name}</h3>
        <p class="team-card__role">{member.role}</p>
        <a class="team-card__email" href={`mailto:${member.email}`}>
          {member.email}
        </a>
      </div>
    </article>
  ))}
</div>

<style lang="scss">
  .team-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    align-items: stretch;
  }

  .team-card {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    padding: 1rem;
    border-radius: 20px;
    border: 1px solid rgba(253, 230, 138, 0.08);
    background: linear-gradient(180deg, rgba(38, 33, 29, 0.92), rgba(20, 17, 14, 0.92));
    height: 100%;
  }

  .team-card__avatar {
    width: 64px;
    height: 64px;
    border-radius: 999px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .team-card__info {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  .team-card__department {
    margin: 0;
    color: var(--cream);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 2.1em;
  }

  .team-card__name {
    margin: 0;
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .team-card__role,
  .team-card__email {
    margin: 0;
    color: var(--muted);
    font-size: 0.92rem;
    word-break: break-word;
  }

  .team-card__email {
    text-decoration: none;
    color: var(--cream);
  }

  .team-card__email:hover {
    text-decoration: underline;
  }
</style>
