---
import Link from "./ui/Link.astro";
import Checkbox from "./ui/Checkbox.astro";
import Button from "./ui/Button.astro";

type Props = {
  link: {
    id: number;
    title: string;
    url: string;
    description: string;
    isRead: boolean;
  };
};

const { link } = Astro.props;
---

<article class="link-card surface-card">
  <div class="link-card__content">
    <Checkbox
      checked={link.isRead}
      inputId={link.id}
      data-id={link.id}
      data-isRead
    />

    <h2 class="link-card__title">{link.title}</h2>

    <p class="link-card__description">
      {link.description}
    </p>
  </div>

  <Link href={link.url} intent="primary"> Abrir Link </Link>

  <Button
    intent="accent"
    size="square"
    data-delete
    data-id={link.id}
    classes="link-card__delete"
    aria-label={`Excluir Link: ${link.title}`}
  >
    <i class="fa-solid fa-trash"></i>
  </Button>
</article>

<style lang="scss">
  .link-card {
    position: relative;
    display: grid;
    gap: 1.25rem;
    overflow: hidden;
    align-content: start;

    padding: 1.25rem;

    color: var(--text);
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.96),
      rgba(20, 17, 14, 0.92)
    );
    border-color: rgba(251, 146, 60, 0.12);

    @media (min-width: 640px) {
      padding: 1.5rem;
    }

    &__content {
      display: grid;
      gap: 0.75rem;
      padding-right: 2.5rem;
    }

    &__title {
      font-size: 1.35rem;
      font-weight: 800;
      line-height: 1.15;

      color: var(--cream);

      text-wrap: balance;
    }

    &__description {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
    }

    &__delete {
      position: absolute;
      top: 1rem;
      right: 1rem;

      border: 1px solid rgba(253, 230, 138, 0.12);
      box-shadow:
        0 10px 24px rgba(0, 0, 0, 0.24),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
      background: linear-gradient(
        135deg,
        var(--orange),
        rgba(251, 146, 60, 0.86)
      );

      transition: transform 0.2s ease;
    }

    &__delete:hover {
      transform: translateY(-1px) scale(1.05);
    }

    &__delete:active {
      transform: scale(0.95);
    }
  }
</style>
