---
import Link from "./ui/Link.astro";
import Checkbox from "./ui/Checkbox.astro";
import Button from "./ui/Button.astro";

type LinkData = {
  id: string;
  title: string;
  url: string;
  description: string;
  isRead: boolean;
};

type Props = {
  link: LinkData;
};

const { link } = Astro.props;
---

<article class="link-card surface-card">
  <div class="link-card__content">
    <Checkbox
      checked={link.isRead}
      inputId={link.id}
      data-id={link.id}
      data-isread
    />

    <h2 class="link-card__title">
      {link.title}
    </h2>

    <p class="link-card__description">
      {link.description}
    </p>
  </div>

  <Link
    href={link.url}
    intent="primary"
    target="_blank"
    rel="noopener noreferrer"
  >
    Abrir Link
  </Link>

  <Button
    intent="accent"
    size="square"
    data-delete
    data-id={link.id}
    classes="link-card__delete"
    aria-label={`Excluir link: ${link.title}`}
  >
    <i class="fa-solid fa-trash" aria-hidden="true"></i>
  </Button>
</article>

<style lang="scss">
  .link-card {
    position: relative;

    display: grid;
    align-content: start;
    gap: 1.25rem;

    overflow: hidden;

    padding: 1.25rem;

    color: var(--text);

    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.96),
      rgba(20, 17, 14, 0.92)
    );

    border-color: rgba(251, 146, 60, 0.12);

    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;

    @media (min-width: 640px) {
      padding: 1.5rem;
    }

    &:hover {
      border-color: rgba(251, 146, 60, 0.28);

      transform: translateY(-2px);

      box-shadow:
        0 18px 40px rgba(0, 0, 0, 0.28),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    &__content {
      display: grid;
      gap: 0.75rem;

      padding-right: 3rem;
    }

    &__title {
      margin: 0;

      font-size: 1.35rem;
      font-weight: 800;
      line-height: 1.15;

      color: var(--cream);

      text-wrap: balance;

      overflow-wrap: break-word;
    }

    &__description {
      margin: 0;

      color: var(--muted);

      line-height: 1.7;

      overflow-wrap: break-word;
    }

    &__delete {
      position: absolute;

      top: 1rem;
      right: 1rem;

      border: 1px solid rgba(253, 230, 138, 0.12);

      background: linear-gradient(
        135deg,
        var(--orange),
        rgba(251, 146, 60, 0.86)
      );

      box-shadow:
        0 10px 24px rgba(0, 0, 0, 0.24),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);

      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease;
    }

    &__delete:hover {
      transform: translateY(-1px) scale(1.05);

      box-shadow:
        0 14px 28px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    &__delete:active {
      transform: scale(0.95);
    }

    &__delete:focus-visible {
      outline: 2px solid var(--cream);
      outline-offset: 2px;
    }
  }
</style>
