---
import Link from "./ui/Link.astro";
import Checkbox from "./ui/Checkbox.astro";
import Button from "./ui/Button.astro";

type Props = {
  link: {
    id: number;
    title: string;
    url: string;
    description: string;
    isRead: boolean;
  };
};

const { link } = Astro.props;
---

<article class="link-card">
  <div class="link-card__content">
    <Checkbox
      checked={link.isRead}
      inputId={link.id}
      data-id={link.id}
      data-isRead
    />

    <h2 class="link-card__title">{link.title}</h2>

    <p class="link-card__description">
      {link.description}
    </p>
  </div>

  <Link href={link.url} intent="primary"> Abrir Link </Link>

  <Button
    intent="accent"
    size="square"
    data-delete
    data-id={link.id}
    classes="link-card__delete"
    aria-label={`Excluir Link: ${link.title}`}
  >
    <i class="fa-solid fa-trash"></i>
  </Button>
</article>

<style lang="scss">
  .link-card {
    position: relative;
    display: grid;
    gap: 1.5rem;

    padding: 1rem;

    background-color: var(--theme-base);
    color: var(--theme-text);

    border-radius: 0.375rem;

    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.6);

    @media (min-width: 640px) {
      padding: 1.5rem;
    }

    &__content {
      display: grid;
      gap: 0.5rem;
    }

    &__title {
      font-size: 1.25rem;
      font-weight: 700;
      line-height: 1.25;

      color: var(--theme-accent);

      text-wrap: balance;
    }

    &__description {
      margin: 0;
    }

    &__delete {
      position: absolute;
      top: -0.5rem;
      right: -0.5rem;

      border-radius: 9999px;
      border: 4px solid var(--theme-base);

      transition: transform 0.2s ease;
    }

    &__delete:hover {
      transform: scale(1.05);
    }

    &__delete:active {
      transform: scale(0.95);
    }
  }
</style>
