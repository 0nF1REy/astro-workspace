---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"input"> {
  checked: boolean;
  inputId: string;
}

const { inputId, checked, ...rest } = Astro.props;
---

<div class="checkbox">
  <input
    type="checkbox"
    checked={checked}
    class="checkbox__input"
    id={`check-${inputId}`}
    {...rest}
  />

  <div class="checkbox__box" aria-hidden="true">
    <i class="fa-solid fa-check"></i>
  </div>

  <label class="checkbox__label" for={`check-${inputId}`}> Foi Lido? </label>
</div>

<style lang="scss">
  .checkbox {
    position: relative;

    display: flex;
    align-items: center;
    gap: 0.7rem;

    max-width: fit-content;

    &__input {
      position: absolute;
      inset: 0;

      opacity: 0;

      cursor: pointer;
    }

    &__box {
      display: grid;
      place-items: center;

      width: 1.35rem;
      height: 1.35rem;

      border: 1px solid rgba(253, 230, 138, 0.18);
      border-radius: 0.45rem;

      background: rgba(25, 22, 18, 0.72);
      color: var(--bg);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);

      transition:
        background-color 0.2s ease,
        transform 0.2s ease,
        box-shadow 0.2s ease,
        border-color 0.2s ease;

      i {
        font-size: 0.875rem;

        opacity: 0;

        transition: opacity 0.2s ease;
      }
    }

    &__label {
      cursor: pointer;
      user-select: none;
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 600;
    }

    &__input:checked + &__box {
      background: linear-gradient(135deg, var(--orange), var(--cream));
      border-color: rgba(251, 146, 60, 0.45);
      box-shadow: 0 8px 18px rgba(251, 146, 60, 0.18);

      i {
        opacity: 1;
      }
    }

    &__box:hover {
      transform: translateY(-1px);
      border-color: rgba(251, 146, 60, 0.3);
    }

    &__input:focus-visible + &__box {
      outline: 3px solid rgba(253, 230, 138, 0.65);
      outline-offset: 3px;
    }
  }
</style>
