---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"input"> {
  checked: boolean;
  inputId: number;
}

const { inputId, checked, ...rest } = Astro.props;
---

<div class="checkbox">
  <input
    type="checkbox"
    checked={checked}
    class="checkbox__input"
    id={`check-${inputId}`}
    {...rest}
  />

  <div class="checkbox__box" aria-hidden="true">
    <i class="fa-solid fa-check"></i>
  </div>

  <label class="checkbox__label" for={`check-${inputId}`}> Foi Lido? </label>
</div>

<style lang="scss">
  .checkbox {
    position: relative;

    display: flex;
    align-items: center;
    gap: 0.5rem;

    max-width: fit-content;

    &__input {
      position: absolute;
      inset: 0;

      opacity: 0;

      cursor: pointer;
    }

    &__box {
      display: grid;
      place-items: center;

      width: 1.5rem;
      height: 1.5rem;

      border: 2px solid var(--theme-accent);
      border-radius: 0.375rem;

      background-color: transparent;
      color: var(--theme-base);

      transition:
        background-color 0.2s ease,
        transform 0.2s ease,
        box-shadow 0.2s ease;

      i {
        font-size: 0.875rem;

        opacity: 0;

        transition: opacity 0.2s ease;
      }
    }

    &__label {
      cursor: pointer;
      user-select: none;
    }

    &__input:checked + &__box {
      background-color: var(--theme-accent);

      i {
        opacity: 1;
      }
    }

    &__input:focus-visible + &__box {
      outline: 2px solid var(--theme-accent);
      outline-offset: 2px;
    }
  }
</style>
