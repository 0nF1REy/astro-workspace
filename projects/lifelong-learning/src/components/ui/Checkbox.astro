---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"input"> {
  checked: boolean;
  inputId: number;
  label: string;
}

const { inputId, checked, label = "Selecionar", ...rest } = Astro.props;
---

<div class="checkbox">
  <input
    type="checkbox"
    checked={checked}
    class="checkbox__input"
    id={`check-${inputId}`}
    {...rest}
  />
  <div class="checkbox__indicator" aria-hidden="true">
    <i class="fa-solid fa-check"></i>
  </div>
  <label class="checkbox__label" for={`check-${inputId}`}>
    {label}
  </label>
</div>

<style lang="scss">
  .checkbox {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: fit-content;
  }

  .checkbox__input {
    position: absolute;
    inset: 0;
    cursor: pointer;
    opacity: 0;
  }

  .checkbox__indicator {
    display: grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    color: transparent;
    border: 2px solid var(--border);
    border-radius: 6px;
    background: transparent;
    transition: all 0.2s ease;
  }

  .checkbox__label {
    cursor: pointer;
    color: var(--text);
    font-size: 0.95rem;
    font-weight: 500;
    user-select: none;
  }

  .checkbox__input:checked + .checkbox__indicator {
    color: #fff;
    background: linear-gradient(135deg, var(--orange), #ea580c);
    border-color: var(--orange);
  }

  .checkbox__input:focus-visible + .checkbox__indicator {
    outline: 2px solid var(--orange);
    outline-offset: 2px;
  }
</style>
