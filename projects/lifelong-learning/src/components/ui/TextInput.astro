---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"input"> {
  name: string;
  inputId: number;
}

const { inputId, name, ...rest } = Astro.props;
---

<div class="input-field">
  <label for={`input-${inputId}`} class="input-field__label">
    {name}
  </label>

  <input
    type="text"
    required
    id={`input-${inputId}`}
    {...rest}
    name={name
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .replace(/\s+/g, "-")}
    class="input-field__input"
  />
</div>

<style lang="scss">
  .input-field {
    display: grid;
    gap: 0.45rem;

    &__label {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
    }

    &__input {
      min-height: 2.75rem;
      padding: 0.85rem 1rem;

      border: 1px solid rgba(253, 230, 138, 0.12);
      border-radius: 18px;

      background: rgba(25, 22, 18, 0.72);
      color: var(--text);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
      transition:
        border-color 0.2s ease,
        box-shadow 0.2s ease,
        background 0.2s ease;

      &::placeholder {
        color: var(--muted);
      }

      &:hover {
        border-color: rgba(251, 146, 60, 0.22);
      }

      &:focus {
        outline: none;
      }

      &:focus-visible {
        border-color: rgba(251, 146, 60, 0.45);
        box-shadow: 0 0 0 3px rgba(251, 146, 60, 0.14);
      }
    }
  }
</style>
