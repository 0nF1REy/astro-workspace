---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"input"> {
  name: string;
  inputId: number;
}

const { inputId, name, ...rest } = Astro.props;
---

<div class="input-field">
  <label for={`input-${inputId}`} class="input-field__label">
    {name}
  </label>

  <input
    type="text"
    required
    id={`input-${inputId}`}
    {...rest}
    name={name.toLowerCase().replace(" ", "-")}
    class="input-field__input"
  />
</div>

<style lang="scss">
  .input-field {
    display: grid;
    gap: 0.25rem;

    &__label {
      font-size: 0.875rem;
      text-transform: uppercase;
    }

    &__input {
      padding: 0.5rem;

      border: none;
      border-radius: 0.375rem;

      background-color: var(--theme-text);
      color: var(--theme-base);

      &:focus {
        outline: none;
      }

      &:focus-visible {
        outline: 2px solid var(--theme-accent);
        outline-offset: 4px;
      }
    }
  }
</style>
