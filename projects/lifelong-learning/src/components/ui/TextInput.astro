---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"input"> {
  name: string;
  inputId: number;
}

const { inputId, name, ...rest } = Astro.props;
const inputName = name.toLowerCase().replaceAll(" ", "-");
---

<div class="text-input">
  <label class="text-input__label" for={`input-${inputId}`}>
    {name}
  </label>
  <input
    type="text"
    required
    id={`input-${inputId}`}
    name={inputName}
    class="text-input__field"
    {...rest}
  />
</div>

<style lang="scss">
  .text-input {
    display: grid;
    gap: 0.5rem;
  }

  .text-input__label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .text-input__field {
    width: 100%;
    padding: 0.85rem 1rem;
    color: var(--text);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 1rem;
    transition: all 0.2s ease;

    &::placeholder {
      color: var(--muted);
    }

    &:hover {
      border-color: var(--orange);
    }

    &:focus {
      outline: none;
      border-color: var(--orange);
      background: rgba(251, 146, 60, 0.05);
      box-shadow: 0 0 0 3px rgba(251, 146, 60, 0.1);
    }
  }
</style>
