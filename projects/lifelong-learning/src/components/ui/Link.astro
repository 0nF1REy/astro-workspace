---
import type { HTMLAttributes } from "astro/types";

export interface Props extends HTMLAttributes<"a"> {
  href: string;
  intent?: "primary" | "accent";
  size?: "small" | "medium" | "large";
}

const { href, intent = "primary", size = "medium", ...rest } = Astro.props;
---

<a
  href={href}
  class:list={["link", `link--${intent}`, `link--${size}`]}
  {...rest}
>
  <slot />
</a>

<style lang="scss">
  .link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;

    max-width: fit-content;

    min-height: 2.75rem;
    padding: 0.85rem 1.2rem;
    border: 1px solid rgba(253, 230, 138, 0.12);
    border-radius: 999px;

    background: linear-gradient(
      135deg,
      var(--surface),
      rgba(251, 146, 60, 0.18)
    );
    color: var(--text);
    box-shadow:
      0 10px 24px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    text-decoration: none;

    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      filter 0.2s ease;

    &:hover {
      transform: translateY(-2px);
      border-color: rgba(251, 146, 60, 0.28);
      box-shadow:
        0 14px 28px rgba(0, 0, 0, 0.3),
        0 0 0 1px rgba(251, 146, 60, 0.08);
    }

    &:focus {
      outline: none;
    }

    &:focus-visible {
      outline: 3px solid rgba(253, 230, 138, 0.65);
      outline-offset: 3px;
    }

    &--primary {
      background: linear-gradient(
        135deg,
        var(--surface),
        rgba(251, 146, 60, 0.18)
      );
      color: var(--text);

      &:hover {
        background: linear-gradient(
          135deg,
          var(--surface-light),
          rgba(251, 146, 60, 0.24)
        );
      }
    }

    &--accent {
      background: linear-gradient(
        135deg,
        var(--orange),
        rgba(251, 146, 60, 0.82)
      );
      color: var(--bg);

      &:hover {
        border-color: rgba(253, 230, 138, 0.24);
        box-shadow:
          0 16px 30px rgba(251, 146, 60, 0.22),
          0 0 0 1px rgba(253, 230, 138, 0.08);
      }
    }

    &--small {
      min-height: 2.25rem;
      padding: 0.5rem 0.85rem;
      font-size: 0.875rem;
    }

    &--medium {
      padding: 0.85rem 1.2rem;
      font-size: 1rem;
    }

    &--large {
      min-height: 3.25rem;
      padding: 1rem 1.4rem;
      font-size: 1.05rem;
    }
  }
</style>
