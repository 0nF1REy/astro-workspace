---
type Props = {
  name: string;
  id: number;
};

const { id, name } = Astro.props;
const inputName = name.toLowerCase().replaceAll(" ", "-");
---

<div class="textarea-field">
  <label class="textarea-field__label" for={`input-${id}`}>
    {name}
  </label>
  <textarea
    required
    id={`input-${id}`}
    name={inputName}
    class="textarea-field__input"
  ></textarea>
</div>

<style lang="scss">
  .textarea-field {
    display: grid;
    gap: 0.5rem;
  }

  .textarea-field__label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .textarea-field__input {
    min-height: 100px;
    padding: 0.85rem 1rem;
    color: var(--text);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    resize: vertical;
    transition: all 0.2s ease;

    &::placeholder {
      color: var(--muted);
    }

    &:hover {
      border-color: var(--orange);
    }

    &:focus {
      outline: none;
      border-color: var(--orange);
      background: rgba(251, 146, 60, 0.05);
      box-shadow: 0 0 0 3px rgba(251, 146, 60, 0.1);
    }
  }
</style>
