---
import type { HTMLAttributes } from "astro/types";

type Intent = "primary" | "secondary" | "accent";

export interface Props extends HTMLAttributes<"button"> {
  intent?: Intent;
  classes?: string;
}

const { intent = "primary", classes = "", ...rest } = Astro.props;
---

<button class={`button button--${intent} ${classes}`.trim()} {...rest}>
  <slot />
</button>

<style lang="scss">
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s ease;
    white-space: nowrap;

    &:focus {
      outline: none;
    }

    &:focus-visible {
      outline: 2px solid var(--orange);
      outline-offset: 2px;
    }

    &--primary {
      background: linear-gradient(135deg, var(--orange), #ea580c);
      color: #fff;
      border-color: transparent;

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(251, 146, 60, 0.3);
      }

      &:active {
        transform: translateY(0);
      }
    }

    &--secondary {
      background: transparent;
      color: var(--text);
      border-color: var(--border);

      &:hover {
        background: var(--surface);
        border-color: var(--orange);
      }

      &:active {
        background: var(--brown);
      }
    }

    &--accent {
      background: transparent;
      color: var(--orange);
      border-color: var(--orange);

      &:hover {
        background: rgba(251, 146, 60, 0.1);
        border-color: #fb923c;
      }
    }
  }
</style>
