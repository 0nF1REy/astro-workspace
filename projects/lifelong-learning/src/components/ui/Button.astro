---
import type { HTMLAttributes } from "astro/types";

type Intent = "primary" | "secondary" | "accent";
type Size = "small" | "medium" | "large" | "square";

export interface Props extends HTMLAttributes<"button"> {
  intent?: Intent;
  size?: Size;
  classes?: string;
}

const {
  intent = "primary",
  size = "medium",
  classes = "",
  ...rest
} = Astro.props;
---

<button
  class:list={["button", `button--${intent}`, `button--${size}`, classes]}
  {...rest}
>
  <slot />
</button>

<style lang="scss">
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 1px solid transparent;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s ease;
    white-space: nowrap;

    &:focus {
      outline: none;
    }

    &:focus-visible {
      outline: 2px solid var(--orange);
      outline-offset: 2px;
    }

    &--small {
      padding: 0.4rem 0.8rem;
      font-size: 0.875rem;
    }

    &--medium {
      padding: 0.75rem 1.5rem;
      font-size: 1rem;
    }

    &--large {
      padding: 1rem 2rem;
      font-size: 1.1rem;
    }

    &--square {
      padding: 0.75rem;
      aspect-ratio: 1 / 1;
      border-radius: 10px;
    }

    &--primary {
      background: linear-gradient(135deg, var(--orange), #ea580c);
      color: #fff;
      border-color: transparent;

      &:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(251, 146, 60, 0.3);
      }

      &:active {
        transform: translateY(0);
      }
    }

    &--secondary {
      background: transparent;
      color: var(--text);
      border-color: var(--border);

      &:hover {
        background: var(--surface);
        border-color: var(--orange);
      }

      &:active {
        background: var(--brown);
      }
    }

    &--accent {
      background: transparent;
      color: var(--orange);
      border-color: var(--orange);

      &:hover {
        background: rgba(251, 146, 60, 0.1);
        border-color: #fb923c;
      }
    }
  }
</style>
