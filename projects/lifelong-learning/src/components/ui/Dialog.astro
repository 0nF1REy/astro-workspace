---
import Button from "./Button.astro";
import Checkbox from "./Checkbox.astro";
import TextArea from "./TextArea.astro";
import TextInput from "./TextInput.astro";
---

<dialog class="dialog" aria-labelledby="dialog-title">
  <div class="dialog__content">
    <form class="dialog__form" id="add-form">
      <h2 class="dialog__title" id="dialog-title">Adicionar Novo Link</h2>

      <TextInput name="Título do Link" inputId={Math.random()} />
      <TextArea name="Descrição do Link" id={Math.random()} />
      <TextInput
        name="URL do Link"
        inputId={Math.random()}
        title="Deve começar com https://"
        pattern="https?://.*"
      />
      <Checkbox checked={false} inputId={Math.random()} name="isRead" />

      <div class="dialog__actions">
        <Button intent="secondary" id="close-dialog" type="button">
          Cancelar
        </Button>
        <Button intent="primary" type="submit">
          <i class="fa-solid fa-plus"></i>
          Adicionar Link
        </Button>
      </div>
    </form>
  </div>
</dialog>

<style lang="scss">
  .dialog {
    width: min(100%, 32rem);
    max-width: 90vw;
    max-height: 90vh;
    padding: 0;
    color: var(--text);
    background: var(--surface-light);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.8);
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;

    &::backdrop {
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(4px);
    }

    &[open] {
      animation: slideIn 0.3s ease;
    }
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
    }
  }

  .dialog__content {
    width: 100%;
    padding: 2rem;
    overflow-y: auto;
  }

  .dialog__form {
    display: grid;
    gap: 1.25rem;
  }

  .dialog__title {
    margin: 0;
    color: var(--cream);
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .dialog__actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;

    :global(button) {
      flex: 1;
    }
  }
</style>

<script>
  import sanitize from "sanitize-html";

  const addForm = document.querySelector("#add-form");
  const openDialogBtns = document.querySelectorAll("[data-open-dialog]");
  const closeDialogBtn = document.getElementById("close-dialog");
  const dialog = document.querySelector("dialog");

  openDialogBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      dialog?.showModal();
    });
  });

  closeDialogBtn?.addEventListener("click", () => {
    dialog?.close();
  });

  dialog?.addEventListener("click", (e) => {
    if (e.target === e.currentTarget) {
      dialog.close();
    }
  });

  dialog?.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      dialog.close();
    }
  });

  addForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    try {
      const formData = new FormData(addForm as HTMLFormElement);
      const title = sanitize(formData.get("título-do-link") as string);
      const description = sanitize(formData.get("descrição-do-link") as string);
      const url = sanitize(formData.get("url-do-link") as string);
      const isRead = formData.get("isread") === "on";

      if (!title || !description || !url) {
        throw new Error("Por favor, preencha todos os campos");
      }

      const req = await fetch("/api/links", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ title, description, url, isRead }),
      });

      if (!req.ok) throw new Error("Falha ao adicionar link");

      const res = await req.json();
      if (!res.success) throw new Error(res.message);

      (addForm as HTMLFormElement).reset();
      (dialog as HTMLDialogElement).close();
      location.reload();
    } catch (e) {
      if (e instanceof Error) alert(e.message);
      console.error(e);
    }
  });
</script>
