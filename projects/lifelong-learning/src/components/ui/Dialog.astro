---
import Button from "./Button.astro";
import Checkbox from "./Checkbox.astro";
import TextArea from "./TextArea.astro";
import TextInput from "./TextInput.astro";
---

<dialog class="dialog">
  <div class="dialog__content">
    <form class="dialog__form" id="add-form">
      <h2 class="dialog__title">Adicionar um Link</h2>

      <TextInput name="Título do Link" inputId={Math.random()} />

      <TextArea name="Descrição do Link" id={Math.random()} />

      <TextInput
        name="URL do Link"
        inputId={Math.random()}
        title="Deve começar com https://"
        pattern="https?://.*"
      />

      <Checkbox checked={false} inputId={Math.random()} name="isRead" />

      <div class="dialog__actions">
        <Button intent="primary" id="close-dialog" type="button">
          Fechar
        </Button>

        <Button intent="accent" type="submit"> Adicionar Link </Button>
      </div>
    </form>
  </div>
</dialog>

<style lang="scss">
  .dialog {
    width: 100%;
    max-width: 32rem;

    position: fixed;
    left: 50%;
    top: 50%;

    transform: translate(-50%, -50%);

    z-index: 10000;

    max-height: 90vh;
    overflow: auto;

    border: 1px solid rgba(253, 230, 138, 0.1);
    border-radius: 28px;

    background: linear-gradient(180deg, var(--surface), rgba(20, 17, 14, 0.96));

    color: var(--text);

    box-shadow:
      0 24px 48px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);

    &::backdrop {
      background:
        radial-gradient(
          circle at top,
          rgba(251, 146, 60, 0.2),
          transparent 35%
        ),
        rgba(0, 0, 0, 0.7);

      backdrop-filter: blur(6px);
    }

    &__content {
      padding: 1.25rem;

      @media (min-width: 640px) {
        padding: 1.75rem;
      }
    }

    &__form {
      display: grid;
      gap: 1.1rem;
    }

    &__title {
      margin: 0;

      font-size: 1.35rem;
      font-weight: 800;
      line-height: 1.15;

      color: var(--cream);
    }

    &__actions {
      display: flex;
      flex-wrap: wrap;

      gap: 1rem;

      justify-content: flex-end;

      @media (max-width: 640px) {
        justify-content: stretch;

        > * {
          flex: 1 1 100%;
        }
      }
    }
  }
</style>

<script>
  const addForm = document.querySelector("#add-form") as HTMLFormElement;

  const openDialogBtn = document.getElementById(
    "open-dialog",
  ) as HTMLButtonElement;

  const closeDialogBtn = document.getElementById(
    "close-dialog",
  ) as HTMLButtonElement;

  const dialog = document.querySelector("dialog") as HTMLDialogElement;

  openDialogBtn.addEventListener("click", () => {
    dialog.showModal();
  });

  closeDialogBtn.addEventListener("click", () => {
    dialog.close();
  });

  dialog.addEventListener("click", (e) => {
    if (e.target === e.currentTarget) {
      dialog.close();
    }
  });

  addForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    try {
      const formData = new FormData(addForm);

      const title = formData.get("titulo-do-link");

      const description = formData.get("descricao-do-link");

      const url = formData.get("url-do-link");

      const isRead = formData.get("isRead") === "on";

      const req = await fetch("/api/links", {
        method: "POST",

        headers: {
          "Content-Type": "application/json",
        },

        body: JSON.stringify({
          title,
          description,
          url,
          isRead,
        }),
      });

      const res = await req.json();

      if (!req.ok || !res.success) {
        throw new Error(res.message || "Erro ao adicionar link.");
      }

      addForm.reset();

      dialog.close();

      location.reload();
    } catch (e) {
      console.error(e);

      if (e instanceof Error) {
        alert(e.message);
      }
    }
  });
</script>

