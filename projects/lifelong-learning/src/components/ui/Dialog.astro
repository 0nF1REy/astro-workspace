---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<dialog class="ui-dialog" id={id} aria-labelledby={`${id}-title`}>
  <div class="ui-dialog__content">
    <h2 class="ui-dialog__title" id={`${id}-title`}>{title}</h2>
    <slot />
  </div>
</dialog>

<style lang="scss">
  .ui-dialog {
    width: min(100%, 32rem);
    max-width: 90vw;
    background: var(--surface-light);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;

    &::backdrop {
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(4px);
    }
  }

  .ui-dialog__content {
    padding: 2rem;
  }

  .ui-dialog__title {
    margin-bottom: 1.5rem;
    color: var(--cream);
    font-size: 1.5rem;
    font-weight: 800;
  }
</style>

<script define:vars={{ id }} is:inline>
  const dialog = document.getElementById(id);
  dialog?.addEventListener("click", (e) => {
    if (e.target === e.currentTarget) dialog.close();
  });
</script>
