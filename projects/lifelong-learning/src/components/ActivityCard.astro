<!-- ---
import Link from "./ui/Link.astro";
import Checkbox from "./ui/Checkbox.astro";
import Button from "./ui/Button.astro";

export type ActivityProps = {
  id: string;
  type: string;
  distance: string;
  duration: string;
  isCompleted: boolean;
  notes: string;
};

type Props = {
  activity: ActivityProps;
};

const { activity } = Astro.props;

const isStrength =
  activity.type.toLowerCase().includes("musculação") ||
  activity.type.toLowerCase().includes("força");
const iconClass = isStrength ? "fa-dumbbell" : "fa-person-running";
---

<article class="activity-card surface-card" data-activity-card>
  <div class="activity-card__content">
    <div class="activity-card__header">
      <div class="activity-card__icon-wrap">
        <i class:list={["fa-solid", iconClass]} aria-hidden="true"></i>
      </div>
      <div class="activity-card__title-area">
        <h2 class="activity-card__type">{activity.type}</h2>
        <p class="activity-card__stats">
          {activity.distance !== "0" && <span>{activity.distance}km • </span>}
          <span>{activity.duration}</span>
        </p>
      </div>
    </div>

    <p class="activity-card__notes">
      {activity.notes}
    </p>

    <div class="activity-card__status">
      <Checkbox
        checked={activity.isCompleted}
        inputId={activity.id}
        data-id={activity.id}
        data-iscompleted
      />
    </div>
  </div>

  <Button
    intent="accent"
    size="square"
    data-delete
    data-id={activity.id}
    classes="activity-card__delete"
    aria-label={`Excluir atividade: ${activity.type}`}
  >
    <i class="fa-solid fa-trash" aria-hidden="true"></i>
  </Button>
</article>

<style lang="scss">
  .activity-card {
    position: relative;
    display: grid;
    align-content: start;
    gap: 1.25rem;
    padding: 1.5rem;
    color: var(--text);
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.96),
      rgba(20, 17, 14, 0.92)
    );
    border-color: rgba(251, 146, 60, 0.12);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;

    &:hover {
      border-color: rgba(251, 146, 60, 0.28);
      transform: translateY(-3px);
      box-shadow:
        0 18px 40px rgba(0, 0, 0, 0.35),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    &__header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    &__icon-wrap {
      width: 3rem;
      height: 3rem;
      display: grid;
      place-items: center;
      background: rgba(251, 146, 60, 0.1);
      border: 1px solid rgba(251, 146, 60, 0.2);
      border-radius: 14px;
      color: var(--orange);
      font-size: 1.2rem;
    }

    &__title-area {
      display: grid;
      gap: 0.15rem;
    }

    &__type {
      margin: 0;
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--cream);
      line-height: 1.1;
    }

    &__stats {
      margin: 0;
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    &__notes {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 0.95rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    &__status {
      margin-top: 0.5rem;
    }

    &__delete {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: linear-gradient(135deg, var(--orange), #f97316);
      border: 1px solid rgba(253, 230, 138, 0.2);
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3);

      &:hover {
        transform: scale(1.1);
      }
    }
  }
</style>

<script>
  const deleteButtons = document.querySelectorAll(
    "[data-delete]",
  ) as NodeListOf<HTMLButtonElement>;

  deleteButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const id = button.dataset.id;
      if (!id) return;

      try {
        const response = await fetch(`/api/activities/${id}`, {
          method: "DELETE",
        });
        if (!response.ok) throw new Error("Erro ao excluir");

        button.closest("[data-activity-card]")?.remove();
        window.dispatchEvent(new CustomEvent("activities:changed"));
      } catch (error) {
        console.error(error);
      }
    });
  });

  const statusInputs = document.querySelectorAll(
    "[data-iscompleted]",
  ) as NodeListOf<HTMLInputElement>;

  statusInputs.forEach((input) => {
    input.addEventListener("change", async (e) => {
      const el = e.currentTarget as HTMLInputElement;
      const id = el.dataset.id;
      if (!id) return;

      try {
        const res = await fetch(`/api/activities/${id}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ isCompleted: el.checked }),
        });

        if (!res.ok) throw new Error("Erro ao atualizar");
        window.dispatchEvent(new CustomEvent("activities:changed"));
      } catch (err) {
        console.error(err);
        el.checked = !el.checked;
      }
    });
  });
</script> -->
