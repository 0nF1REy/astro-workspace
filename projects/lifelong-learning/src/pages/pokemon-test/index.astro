---
import Layout from "@layouts/Layout.astro";
import type { PokemonRes } from "../../types/PokeType";

const res = await fetch("https://pokeapi.co/api/v2/pokemon?limit=100");
const data: PokemonRes = await res.json();
---

<Layout title="Pokémon 02">
  <section class="pokemon-page">
    <div class="pokemon-page__hero surface-card">
      <p class="pokemon-page__eyebrow">Pokémon / Teste</p>
      <h1 class="title-gradient">Lista de Pokémon</h1>
      <p class="pokemon-page__lead">
        Versão de teste com rotas de conflito para demonstração didática.
      </p>
    </div>

    <ul class="pokemon-page__grid" role="list">
      {
        data.results.map((p) => (
          <li class="pokemon-page__card surface-card">
            <p class="pokemon-page__label">Pokémon</p>
            <h2>{p.name}</h2>
            <a class="pokemon-page__link" href={`/pokemon-test/${p.name}`}>
              Ver detalhe
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style lang="scss">
  .pokemon-page {
    display: grid;
    gap: 1.5rem;
  }

  .pokemon-page__hero {
    display: grid;
    gap: 0.85rem;
    padding: 2rem;
  }

  .pokemon-page__eyebrow,
  .pokemon-page__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pokemon-page__lead {
    max-width: 60ch;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .pokemon-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    padding: 0;
    margin: 0;
  }

  .pokemon-page__card {
    display: grid;
    gap: 0.85rem;
    padding: 1.5rem;
    align-content: start;
    list-style: none;
  }

  .pokemon-page__card h2 {
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    line-height: 1.1;
    text-transform: capitalize;
  }

  .pokemon-page__link {
    width: fit-content;
    color: var(--cream);
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .pokemon-page__link:hover {
    color: var(--orange);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .pokemon-page__hero,
    .pokemon-page__card {
      padding: 1.25rem;
    }
  }
</style>
