---
import Layout from "@layouts/Layout.astro";
import Link from "@components/Link.astro";

const routes = [
  {
    title: "Módulo Blog",
    href: "blog",
    description:
      "Evolução de conteúdo: de arquivos Markdown simples (v1) para Content Collections robustas (v2).",
    icon: "fa-solid fa-newspaper",
  },
  {
    title: "Pokédex Hub",
    href: "pokemon",
    description:
      "O coração técnico: comparação prática entre Static Site Generation (SSG) e Server-Side Rendering (SSR).",
    icon: "fa-solid fa-bolt",
  },
  {
    title: "Anime Catalog",
    href: "anime",
    description:
      "Consumo de APIs externas (Jikan API) com paginação e rotas dinâmicas detalhadas.",
    icon: "fa-solid fa-tv",
  },
  {
    title: "Data Collections",
    href: "api/anime",
    description:
      "Exploração de múltiplos loaders: processamento de YAML, JSON, CSV e TOML via Astro.",
    icon: "fa-solid fa-layer-group",
  },
  {
    title: "Component Gallery",
    href: "components",
    description:
      "Showcase de UI: botões, cards, grids e integração de ilhas interativas com React.",
    icon: "fa-solid fa-cubes",
  },
  {
    title: "Asset Intelligence",
    href: "images",
    description:
      "Gestão de assets: densidade de pixels, formatos modernos (AVIF/WebP) e otimização programática.",
    icon: "fa-solid fa-image",
  },
];
---

<Layout title="Home">
  <section class="home-page">
    <div class="home-page__hero surface-card">
      <p class="home-page__eyebrow">Lifelong Learning</p>
      <h1 class="title-gradient">Aprendizado Contínuo</h1>
      <p class="home-page__lead">
        Um ecossistema técnico projetado para explorar as capacidades do Astro
        6, documentando a evolução de padrões arquiteturais e boas práticas em
        tempo real.
      </p>
    </div>

    <section class="home-page__about surface-card">
      <p class="home-page__eyebrow">A Proposta</p>
      <h2>Sobre o Projeto</h2>
      <p class="home-page__lead">
        Este projeto documenta a evolução de <strong
          >padrões arquiteturais</strong
        >. Cada diretório representa um marco no domínio de ferramentas modernas
        de desenvolvimento web, priorizando performance, experiência do
        desenvolvedor e design system resiliente.
      </p>
      <div class="home-page__about-grid">
        <article class="home-page__about-panel surface-card">
          <h3>Arquitetura Híbrida</h3>
          <p>
            Implementação real de rotas estáticas e dinâmicas no mesmo projeto,
            testando os limites do roteamento e do pré-render do Astro.
          </p>
          <p>
            Foco em <strong>Islands Architecture</strong> para manter o bundle JS
            mínimo enquanto usamos o poder do React onde necessário.
          </p>
        </article>

        <article
          class="home-page__about-panel home-page__about-panel--accent surface-card"
        >
          <p class="home-page__about-kicker">Pilares Técnicos</p>
          <ul class="home-page__about-list">
            <li>Content Collections & Custom Loaders</li>
            <li>Integração Multi-Framework (Astro + React)</li>
            <li>Otimização Nativa de Assets</li>
            <li>CSS Moderno com Variáveis e Scoped SCSS</li>
          </ul>
        </article>
      </div>

      <div class="home-page__stats">
        <article class="home-page__stat surface-card">
          <p class="home-page__stat-value">SSG/SSR</p>
          <p class="home-page__stat-label">Modos de Renderização</p>
        </article>

        <article class="home-page__stat surface-card">
          <p class="home-page__stat-value">10+</p>
          <p class="home-page__stat-label">Formatos de Dados</p>
        </article>

        <article class="home-page__stat surface-card">
          <p class="home-page__stat-value">React</p>
          <p class="home-page__stat-label">Ilhas de Interatividade</p>
        </article>
      </div>
    </section>

    <div class="home-page__grid">
      {
        routes.map((route) => (
          <article class="home-page__panel surface-card">
            <div class="home-page__panel-header">
              <i class={`${route.icon} home-page__panel-icon`} />
              <h2>{route.title}</h2>
            </div>
            <p>{route.description}</p>
            <Link class="home-page__panel-link" href={route.href}>
              Explorar Módulo <i class="fa-solid fa-arrow-right" />
            </Link>
          </article>
        ))
      }
    </div>

    <div class="home-page__footer surface-card">
      <p>
        Este espaço é mantido como parte de um processo de estudo contínuo.
        Sinta-se à vontade para inspecionar o código e ver como os módulos se
        conectam.
      </p>
    </div>
  </section>
</Layout>

<style lang="scss">
  .home-page {
    display: grid;
    gap: 1.5rem;
  }

  .home-page__hero {
    display: grid;
    gap: 0.9rem;
    padding: 2.5rem;
  }

  .home-page__about {
    display: grid;
    gap: 1rem;
    padding: 2.5rem;
  }

  .home-page__eyebrow {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .home-page h1 {
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    line-height: 0.95;
    max-width: 15ch;
  }

  .home-page h2 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    line-height: 1.05;
  }

  .home-page h3 {
    font-size: clamp(1.2rem, 2.8vw, 1.5rem);
    line-height: 1.1;
    color: var(--cream);
  }

  .home-page__lead,
  .home-page__panel p,
  .home-page__footer p {
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .home-page__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .home-page__panel-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--orange);
  }

  .home-page__panel-icon {
    font-size: 1.25rem;
  }

  .home-page__about-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .home-page__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .home-page__panel {
    display: grid;
    gap: 1rem;
    padding: 1.8rem;
    align-content: start;
  }

  .home-page__about-panel {
    display: grid;
    gap: 0.85rem;
    padding: 1.8rem;
    background: rgba(25, 22, 18, 0.4);
  }

  .home-page__about-panel p {
    color: var(--muted);
    line-height: 1.6;
  }

  .home-page__about-panel .home-page__about-kicker {
    color: var(--orange);
  }

  .home-page__about-panel--accent {
    background: linear-gradient(
      180deg,
      rgba(51, 43, 38, 0.96),
      rgba(20, 17, 14, 0.92)
    );
    border-color: rgba(251, 146, 60, 0.2);
  }

  .home-page__about-kicker {
    color: var(--orange);
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
  }

  .home-page__about-list {
    display: grid;
    gap: 0.8rem;
    padding-left: 1.2rem;
    font-size: 0.95rem;

    li::marker {
      color: var(--orange);
    }
  }

  .home-page__about-list li {
    color: var(--muted);
  }

  .home-page__stat {
    display: grid;
    gap: 0.25rem;
    padding: 1.5rem;
    text-align: center;
  }

  .home-page__stat-value {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--cream);
    line-height: 1;
  }

  .home-page__stat-label {
    color: var(--muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global(a.home-page__panel-link) {
    color: var(--orange);
    font-weight: 700;
    text-decoration: none;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    transition: transform 0.2s ease;

    &:hover {
      transform: translateX(5px);
      text-decoration: underline;
    }
  }

  .home-page__footer {
    padding: 2rem;
    text-align: center;
    border-style: dashed;
    border-color: rgba(253, 230, 138, 0.1);
  }

  @media (max-width: 1024px) {
    .home-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .home-page__grid,
    .home-page__about-grid,
    .home-page__stats {
      grid-template-columns: 1fr;
    }

    .home-page__hero,
    .home-page__about {
      padding: 1.5rem;
    }
  }
</style>
