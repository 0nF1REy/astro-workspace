---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Pokémon Oficial">
  <section class="pokemon-hub">
    <div class="pokemon-hub__hero surface-card">
      <p class="pokemon-hub__eyebrow">Pokémon</p>
      <h1 class="title-gradient">Escolha a versão</h1>
      <p class="pokemon-hub__lead">
        Abaixo estão as duas abordagens do exemplo: uma com SSG e outra com SSR.
        Selecione a que você quer explorar.
      </p>
    </div>

    <div class="pokemon-hub__grid">
      <a class="pokemon-hub__card surface-card" href="/pokemon/ssg">
        <p class="pokemon-hub__label">SSG</p>
        <h2>Static Site Generation</h2>
        <p>
          A página é gerada no build com `getStaticPaths()` e publicada como
          HTML estático.
        </p>
        <span class="pokemon-hub__link">Abrir versão SSG</span>
      </a>

      <a class="pokemon-hub__card surface-card" href="/pokemon/ssr">
        <p class="pokemon-hub__label">SSR</p>
        <h2>Server-Side Rendering</h2>
        <p>
          A página é renderizada na requisição e funciona com `prerender =
          false`.
        </p>
        <span class="pokemon-hub__link">Abrir versão SSR</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  .pokemon-hub {
    display: grid;
    gap: 1.5rem;
  }

  .pokemon-hub__hero {
    display: grid;
    gap: 0.85rem;
    padding: 2rem;
  }

  .pokemon-hub__eyebrow,
  .pokemon-hub__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pokemon-hub__lead {
    max-width: 60ch;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .pokemon-hub__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .pokemon-hub__card {
    display: grid;
    gap: 0.85rem;
    padding: 1.5rem;
    align-content: start;
    text-decoration: none;
    color: inherit;
  }

  .pokemon-hub__card h2 {
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    line-height: 1.1;
  }

  .pokemon-hub__card p {
    color: var(--muted);
    line-height: 1.7;
  }

  .pokemon-hub__link {
    width: fit-content;
    color: var(--cream);
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .pokemon-hub__card:hover .pokemon-hub__link {
    color: var(--orange);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .pokemon-hub__hero,
    .pokemon-hub__card {
      padding: 1.25rem;
    }
  }
</style>
