---
import type { GetStaticPaths } from "astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import type { PokemonRes } from "../../../types/PokeType";

export const getStaticPaths = (async () => {
  const res = await fetch("https://pokeapi.co/api/v2/pokemon?limit=100");
  const data: PokemonRes = await res.json();

  return data.results.map((p) => ({
    params: { slug: p.name },
    props: { ...p },
  }));
}) satisfies GetStaticPaths;

const { name, url } = Astro.props;
---

<BaseLayout title={name}>
  <section class="pokemon-detail">
    <div class="pokemon-detail__hero surface-card">
      <p class="pokemon-detail__eyebrow">Pokémon / SSG</p>
      <h1 class="title-gradient pokemon-detail__title">{name}</h1>
      <p class="pokemon-detail__lead">
        Detalhes gerados no build com `getStaticPaths()`.
      </p>
    </div>

    <article class="pokemon-detail__card surface-card">
      <p class="pokemon-detail__label">Link oficial</p>
      <a
        class="pokemon-detail__link"
        href={url}
        target="_blank"
        rel="noreferrer"
      >
        Saber mais
      </a>
      <a class="pokemon-detail__back" href="/pokemon/ssg"
        >Voltar para a lista SSG</a
      >
    </article>
  </section>
</BaseLayout>

<style lang="scss">
  .pokemon-detail {
    display: grid;
    gap: 1rem;
    max-width: 52rem;
    margin: 0 auto;
  }

  .pokemon-detail__hero {
    display: grid;
    gap: 0.85rem;
    padding: 2rem;
  }

  .pokemon-detail__card {
    display: grid;
    gap: 0.9rem;
    padding: 1.5rem;
  }

  .pokemon-detail__eyebrow,
  .pokemon-detail__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pokemon-detail__title {
    text-transform: capitalize;
  }

  .pokemon-detail__lead {
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .pokemon-detail__link,
  .pokemon-detail__back {
    width: fit-content;
    color: var(--cream);
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .pokemon-detail__link:hover,
  .pokemon-detail__back:hover {
    color: var(--orange);
    transform: translateX(3px);
  }

  .pokemon-detail__back {
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .pokemon-detail__hero,
    .pokemon-detail__card {
      padding: 1.25rem;
    }
  }
</style>
