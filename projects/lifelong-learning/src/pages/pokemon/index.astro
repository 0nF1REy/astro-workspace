---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Pokémon - Seleção">
  <section class="pokemon-selector">
    <div class="pokemon-selector__hero surface-card">
      <p class="pokemon-selector__eyebrow">Pokémon</p>
      <h1 class="title-gradient">Escolha o ambiente</h1>
      <p class="pokemon-selector__lead">
        Selecione entre o exemplo principal (produção/didático) e o ambiente de
        testes experimentais.
      </p>
    </div>

    <div class="pokemon-selector__grid">
      <a class="pokemon-selector__card surface-card" href="/pokemon/oficial">
        <p class="pokemon-selector__label">Recomendado</p>
        <h2>Pokémon (Oficial)</h2>
        <p>
          Versão organizada com rotas separadas para SSG e SSR, seguindo
          estrutura mais escalável.
        </p>
        <span class="pokemon-selector__link">Abrir Pokémon oficial</span>
      </a>

      <a class="pokemon-selector__card surface-card" href="/pokemon-test">
        <p class="pokemon-selector__label">Experimental</p>
        <h2>Pokémon Test</h2>
        <p>
          Ambiente de laboratório para validar cenários e comportamentos antes
          de aplicar no exemplo principal.
        </p>
        <span class="pokemon-selector__link">Abrir Pokémon test</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  .pokemon-selector {
    display: grid;
    gap: 1.5rem;
  }

  .pokemon-selector__hero {
    display: grid;
    gap: 0.85rem;
    padding: 2rem;
  }

  .pokemon-selector__eyebrow,
  .pokemon-selector__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pokemon-selector__lead {
    max-width: 60ch;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .pokemon-selector__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .pokemon-selector__card {
    display: grid;
    gap: 0.85rem;
    padding: 1.5rem;
    align-content: start;
    text-decoration: none;
    color: inherit;
  }

  .pokemon-selector__card h2 {
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    line-height: 1.1;
  }

  .pokemon-selector__card p {
    color: var(--muted);
    line-height: 1.7;
  }

  .pokemon-selector__link {
    width: fit-content;
    color: var(--cream);
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .pokemon-selector__card:hover .pokemon-selector__link {
    color: var(--orange);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .pokemon-selector__hero,
    .pokemon-selector__card {
      padding: 1.25rem;
    }
  }
</style>
