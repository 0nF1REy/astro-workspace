---
import "../styles/global.scss";
import Link from "../components/Link.astro";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Curso | Aprendendo Astro</title>
  </head>

  <body class="not-found-body">
    <main class="not-found-page">
      <div class="not-found-page__orb not-found-page__orb--one"></div>
      <div class="not-found-page__orb not-found-page__orb--two"></div>

      <section class="not-found-card">
        <p class="not-found-page__eyebrow">Astro course</p>
        <h1 class="not-found-page__code title-gradient">404</h1>
        <h2 class="not-found-page__title">Página não encontrada</h2>
        <p class="not-found-page__lead">
          A página que você tentou acessar não existe, foi movida ou digitada de
          forma incorreta.
        </p>

        <Link class="not-found-page__action" href="/">
          Voltar para a home
        </Link>
      </section>
    </main>
  </body>
</html>

<style lang="scss">
  :global(body.not-found-body) {
    height: 100vh;
    overflow: hidden;
    display: block;
    background:
      radial-gradient(circle at top, rgba(251, 146, 60, 0.16), transparent 30%),
      radial-gradient(
        circle at bottom,
        rgba(253, 230, 138, 0.08),
        transparent 26%
      ),
      linear-gradient(to bottom, #191612, #120f0d);
  }

  .not-found-page {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    isolation: isolate;
  }

  .not-found-card {
    display: grid;
    gap: 0.85rem;
    place-items: center;
    text-align: center;
    max-width: 44rem;
    padding: 3.25rem 3rem;
    position: relative;
    z-index: 1;
    overflow: visible;
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.92),
      rgba(20, 17, 14, 0.96)
    );
    border: 1px solid rgba(253, 230, 138, 0.08);
    border-radius: 32px;
    box-shadow:
      0 28px 60px rgba(0, 0, 0, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .not-found-page__orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(8px);
    opacity: 0.75;
    pointer-events: none;
  }

  .not-found-page__orb--one {
    width: 18rem;
    height: 18rem;
    background: radial-gradient(
      circle,
      rgba(251, 146, 60, 0.22),
      transparent 68%
    );
    top: 8%;
    right: 8%;
  }

  .not-found-page__orb--two {
    width: 14rem;
    height: 14rem;
    background: radial-gradient(
      circle,
      rgba(253, 230, 138, 0.12),
      transparent 70%
    );
    left: 6%;
    bottom: 10%;
  }

  .not-found-page__eyebrow {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .not-found-page__code {
    font-size: clamp(5rem, 14vw, 9rem);
    line-height: 0.9;
    margin-left: 0;
    letter-spacing: -0.04em;
  }

  .not-found-page__title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .not-found-page__lead {
    max-width: 42rem;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.05rem;
    margin-top: 0.35rem;
  }

  :global(a.not-found-page__action) {
    margin-top: 0.6rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.9rem 1.35rem;
    border-radius: 999px;
    border: 1px solid rgba(253, 230, 138, 0.16);
    background: linear-gradient(
      135deg,
      var(--surface),
      rgba(251, 146, 60, 0.18)
    );
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
    box-shadow:
      0 12px 26px rgba(0, 0, 0, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  :global(a.not-found-page__action:hover) {
    transform: translateY(-2px);
    border-color: rgba(251, 146, 60, 0.34);
    background: linear-gradient(
      135deg,
      var(--surface-light),
      rgba(251, 146, 60, 0.24)
    );
    box-shadow:
      0 16px 32px rgba(0, 0, 0, 0.32),
      0 0 0 1px rgba(251, 146, 60, 0.1);
  }

  :global(a.not-found-page__action:active) {
    transform: translateY(0);
  }

  .not-found-page__hint {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
    max-width: 42rem;
  }

  @media (max-width: 640px) {
    .not-found-page {
      padding: 1rem;
    }

    .not-found-card {
      padding: 2rem 1.25rem;
      border-radius: 24px;
    }

    :global(a.not-found-page__action) {
      width: 100%;
    }
  }
</style>
