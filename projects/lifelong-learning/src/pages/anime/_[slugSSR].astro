---
export const prerender = false;
import Layout from "@layouts/Layout.astro";

const { slugSSR } = Astro.params;

const res = await fetch(`https://api.jikan.moe/v4/anime/${slugSSR}`);
if (res.status === 404) return Astro.redirect("/404");

const { data } = await res.json();
---

<Layout title={data.title}>
  <section class="anime-detail">
    <article class="anime-detail__card surface-card">
      <img
        src={data.images.webp.large_image_url}
        alt={data.title}
        class="anime-img"
      />
      <div class="anime-detail__info">
        <p class="anime-detail__eyebrow">Anime Detail</p>
        <h1 class="title-gradient anime-detail__title">{data.title}</h1>
        <p class="anime-detail__lead">
          Gerado via SSR (Server‑Side Rendering).
        </p>
        <p>
          Sinopse indisponível neste modo, porque este detalhe é carregado via
          SSR.
        </p>

        <a class="anime-detail__back" href="/anime">Voltar para a lista</a>
      </div>
    </article>
  </section>
</Layout>

<style lang="scss">
  .anime-detail {
    display: grid;
    gap: 1rem;
  }

  .anime-detail__card {
    display: grid;
    grid-template-columns: minmax(220px, 280px) 1fr;
    gap: 1.25rem;
    padding: 1.5rem;
    align-items: start;
  }

  .anime-detail__info {
    display: grid;
    gap: 0.85rem;
    align-content: start;
  }

  .anime-detail__eyebrow,
  .anime-detail__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .anime-detail__title {
    line-height: 1.1;
  }

  .anime-detail__lead,
  .anime-desc {
    color: var(--cream);
    line-height: 1.75;
    font-weight: 700;
    background: rgba(251, 146, 60, 0.06);
    padding: 0.45rem 0.65rem;
    border-radius: 8px;
    display: inline-block;
    font-size: 1.02rem;
  }

  .anime-img {
    width: 100%;
    height: auto;
    aspect-ratio: 2 / 3;
    border-radius: 14px;
    display: block;
    object-fit: cover;
    max-height: 460px;
    justify-self: stretch;
  }

  .anime-detail__back {
    width: fit-content;
    color: var(--cream);
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .anime-detail__back:hover {
    color: var(--orange);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .anime-detail__card {
      padding: 1.25rem;
      grid-template-columns: 1fr;
    }

    .anime-img {
      max-width: 240px;
      justify-self: start;
    }
  }
</style>
