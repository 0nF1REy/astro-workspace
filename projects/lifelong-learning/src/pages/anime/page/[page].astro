---
import type { GetStaticPaths } from "astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import AnimePage from "@components/AnimePage.astro";
import { fetchTopAnime } from "../../../lib/anime/fetchTopAnime.ts";
import { ANIME_PAGE_SIZE } from "../../../lib/anime/pagination.ts";
import type { AnimeRes } from "../../../types/AnimeType";

export const getStaticPaths = (async () => {
  const animeList = await fetchTopAnime();
  const lastPage = Math.max(1, Math.ceil(animeList.length / ANIME_PAGE_SIZE));

  return Array.from({ length: Math.max(0, lastPage - 1) }, (_, index) => {
    const currentPage = index + 2;
    const start = (currentPage - 1) * ANIME_PAGE_SIZE;
    const end = currentPage * ANIME_PAGE_SIZE;

    return {
      params: { page: currentPage.toString() },
      props: {
        data: animeList.slice(start, end),
        currentPage,
        lastPage,
      },
    };
  });
}) satisfies GetStaticPaths;

const { data, currentPage, lastPage } = Astro.props as {
  data: AnimeRes["data"];
  currentPage: number;
  lastPage: number;
};
---

<BaseLayout title="Animes">
  <AnimePage data={data} currentPage={currentPage} lastPage={lastPage} />
</BaseLayout>
