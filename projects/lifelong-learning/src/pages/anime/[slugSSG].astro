---
import type { GetStaticPaths } from "astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { fetchTopAnime } from "../../lib/anime/fetchTopAnime.ts";

export const getStaticPaths = (async () => {
  const animeList = await fetchTopAnime();

  return animeList.map((anime) => ({
    params: { slugSSG: anime.mal_id.toString() },
    props: { anime },
  }));
}) satisfies GetStaticPaths;

const { anime } = Astro.props;

const _rawTrailerEmbed =
  anime.trailer?.embed_url ??
  (anime.trailer?.youtube_id
    ? `https://www.youtube.com/embed/${anime.trailer.youtube_id}`
    : null);

const trailerEmbedUrl = _rawTrailerEmbed
  ? (() => {
      try {
        const u = new URL(_rawTrailerEmbed);
        u.searchParams.delete("autoplay");
        return u.toString();
      } catch (e) {
        return _rawTrailerEmbed.replace(/([?&])autoplay=\d+(&|$)/, (...a) =>
          a[2] ? a[1] : "",
        );
      }
    })()
  : null;
---

<BaseLayout title={anime.title}>
  <section class="anime-detail">
    <article class="anime-detail__card surface-card">
      <div class="anime-detail__hero">
        <p class="anime-detail__eyebrow">Anime Detail</p>
        <h1 class="title-gradient anime-detail__title">{anime.title}</h1>
        <p class="anime-detail__lead">
          Gerado via SSG (Static Site Generation).
        </p>
      </div>

      <div class="anime-detail__body">
        <img
          src={anime.images.webp.large_image_url}
          alt={anime.title}
          class="anime-img"
        />

        <div class="anime-info">
          {/* Primary Stats */}
          <div class="primary-stats">
            <div class="stat-item">
              <i class="fas fa-star" aria-hidden="true"></i>
              <span class="stat-label">Nota</span>
              <span class="stat-value">{anime.score}</span>
            </div>
            <div class="stat-item">
              <i class="fas fa-tv" aria-hidden="true"></i>
              <span class="stat-label">Episódios</span>
              <span class="stat-value">{anime.episodes}</span>
            </div>
            {
              anime.rank && (
                <div class="stat-item">
                  <i class="fas fa-crown" aria-hidden="true" />
                  <span class="stat-label">Ranking</span>
                  <span class="stat-value">#{anime.rank}</span>
                </div>
              )
            }
            {
              anime.popularity && (
                <div class="stat-item">
                  <i class="fas fa-fire" aria-hidden="true" />
                  <span class="stat-label">Popular.</span>
                  <span class="stat-value">#{anime.popularity}</span>
                </div>
              )
            }
          </div>

          {/* Type, Status, Year */}
          <div class="meta-row">
            {
              anime.type && (
                <div class="meta-item">
                  <span class="meta-label">Tipo</span>
                  <span class="meta-value">{anime.type}</span>
                </div>
              )
            }
            {
              anime.status && (
                <div class="meta-item">
                  <span class="meta-label">Status</span>
                  <span class="meta-value">{anime.status}</span>
                </div>
              )
            }
            {
              anime.source && (
                <div class="meta-item">
                  <span class="meta-label">Fonte</span>
                  <span class="meta-value">{anime.source}</span>
                </div>
              )
            }
            {
              anime.season && (
                <div class="meta-item">
                  <span class="meta-label">Temporada</span>
                  <span class="meta-value">{anime.season}</span>
                </div>
              )
            }
            {
              anime.duration && (
                <div class="meta-item">
                  <span class="meta-label">Duração</span>
                  <span class="meta-value">{anime.duration}</span>
                </div>
              )
            }
            {
              anime.aired?.from && (
                <div class="meta-item">
                  <span class="meta-label">Lançamento</span>
                  <span class="meta-value">
                    {new Date(anime.aired.from).toLocaleDateString("pt-BR")}
                  </span>
                </div>
              )
            }
            {
              anime.rating && (
                <div class="meta-item">
                  <span class="meta-label">Classificação</span>
                  <span class="meta-value">{anime.rating}</span>
                </div>
              )
            }
          </div>

          {/* Gêneros */}
          {
            anime.genres && anime.genres.length > 0 && (
              <div class="genres-section">
                <p class="anime-detail__label">Gêneros</p>
                <div class="genres-grid">
                  {anime.genres.map((genre: any) => (
                    <span class="genre-tag">{genre.name}</span>
                  ))}
                </div>
              </div>
            )
          }

          {/* Studios */}
          {
            anime.studios && anime.studios.length > 0 && (
              <div class="studios-section">
                <p class="anime-detail__label">Estúdios</p>
                <ul class="studios-list">
                  {anime.studios.map((studio: any) => (
                    <li>{studio.name}</li>
                  ))}
                </ul>
              </div>
            )
          }
        </div>
      </div>

      <div class="detail-footer">
        {/* Sinopse */}
        {
          anime.synopsis && (
            <div class="synopsis-section">
              <p class="anime-detail__label">Sinopse</p>
              <p class="anime-desc">{anime.synopsis}</p>
            </div>
          )
        }

        <aside class="trailer-section">
          <p class="anime-detail__label">Trailer / Promo</p>

          {
            trailerEmbedUrl ? (
              <div class="trailer-frame">
                <iframe
                  src={trailerEmbedUrl}
                  title={`Trailer de ${anime.title}`}
                  loading="lazy"
                  allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                />
              </div>
            ) : (
              <a
                class="trailer-placeholder"
                href={anime.trailer?.url ?? anime.images.webp.large_image_url}
                target="_blank"
                rel="noreferrer"
              >
                <img
                  src={anime.images.webp.large_image_url}
                  alt={anime.title}
                  class="trailer-placeholder__image"
                />
                <span class="trailer-placeholder__text">
                  Abrir material promocional externo
                </span>
              </a>
            )
          }

          <a class="anime-detail__back" href="/anime">
            <i class="fas fa-arrow-left" aria-hidden="true"></i>
            Voltar para a lista
          </a>
        </aside>
      </div>
    </article>
  </section>
</BaseLayout>

<style lang="scss">
  .anime-detail {
    display: grid;
    gap: 1rem;
  }

  .anime-detail__hero {
    display: grid;
    gap: 0.85rem;
  }

  .anime-detail__body {
    display: grid;
    grid-template-columns: minmax(220px, 320px) 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .anime-detail__eyebrow,
  .anime-detail__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .anime-detail__title {
    line-height: 1.1;
  }

  .anime-detail__lead {
    color: var(--cream);
    line-height: 1.7;
    font-weight: 700;
    background: rgba(251, 146, 60, 0.08);
    padding: 0.45rem 0.65rem;
    border-radius: 8px;
    display: inline-block;
    font-size: 1.02rem;
  }

  .anime-detail__card {
    display: grid;
    gap: 1.25rem;
    padding: 1.5rem;
  }

  .anime-img {
    width: 100%;
    border-radius: 14px;
    display: block;
    object-fit: cover;
    max-height: 460px;
  }

  .anime-info {
    display: grid;
    gap: 1.25rem;
  }

  .detail-footer {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.95fr);
    gap: 1rem;
    align-items: start;
  }

  .synopsis-section {
    display: grid;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(251, 146, 60, 0.15);
    max-width: 72ch;
  }

  .trailer-section {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 14px;
    background: rgba(251, 146, 60, 0.05);
    border: 1px solid rgba(251, 146, 60, 0.12);
  }

  .trailer-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
  }

  .trailer-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .trailer-placeholder {
    display: grid;
    gap: 0.75rem;
    color: inherit;
    text-decoration: none;
  }

  .trailer-placeholder__image {
    width: 100%;
    display: block;
    border-radius: 12px;
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  .trailer-placeholder__text {
    color: var(--cream);
    font-weight: 600;
  }

  .trailer-section .anime-detail__back {
    width: 100%;
    justify-content: center;
    text-align: center;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }

  .primary-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 0.75rem;
  }

  .stat-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem;
    align-items: center;
    padding: 0.75rem;
    background: rgba(251, 146, 60, 0.05);
    border-radius: 8px;
    border-left: 3px solid var(--orange);
  }

  .stat-item i {
    color: var(--orange);
    font-size: 1.25rem;
    grid-column: 1;
    grid-row: 1 / -1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    grid-column: 2;
    grid-row: 1;
  }

  .stat-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--cream);
    grid-column: 2;
    grid-row: 2;
  }

  /* Meta Information Row */
  .meta-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.75rem;
  }

  .meta-item {
    display: grid;
    gap: 0.35rem;
  }

  .meta-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-value {
    font-size: 0.95rem;
    color: var(--cream);
    font-weight: 600;
  }

  /* Gêneros */
  .genres-section {
    display: grid;
    gap: 0.5rem;
  }

  .genres-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .genre-tag {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    background: linear-gradient(135deg, var(--orange), rgba(251, 146, 60, 0.6));
    color: var(--bg);
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
  }

  /* Estúdios */
  .studios-section {
    display: grid;
    gap: 0.5rem;
  }

  .studios-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.4rem;
  }

  .studios-list li {
    padding-left: 1.5rem;
    position: relative;
    color: var(--cream);
    font-weight: 500;
  }

  .studios-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    background: var(--orange);
    border-radius: 50%;
  }

  .anime-desc {
    color: var(--cream);
    line-height: 1.75;
    font-weight: 400;
    text-wrap: pretty;
  }

  /* Back Link */
  .anime-detail__back {
    width: fit-content;
    color: var(--bg);
    background: linear-gradient(135deg, var(--orange), rgba(251, 146, 60, 0.8));
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.25rem;
    border-radius: 8px;
    box-shadow: 0 4px 12px rgba(251, 146, 60, 0.2);
  }

  .anime-detail__back:hover {
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.9), var(--orange));
    box-shadow: 0 6px 20px rgba(251, 146, 60, 0.35);
    transform: translateX(-4px);
  }

  .anime-detail__back:active {
    transform: translateX(-2px);
  }

  /* Responsive Design */
  @media (max-width: 860px) {
    .anime-detail__body {
      grid-template-columns: 1fr;
    }

    .primary-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .detail-footer {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .anime-detail__card {
      padding: 1.25rem;
    }

    .primary-stats {
      grid-template-columns: 1fr;
    }

    .meta-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .synopsis-section {
      max-width: none;
    }

    .trailer-section {
      padding: 0.9rem;
    }

    .genre-tag {
      font-size: 0.8rem;
      padding: 0.35rem 0.7rem;
    }
  }
</style>
