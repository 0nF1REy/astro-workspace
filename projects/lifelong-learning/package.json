{
  "name": "lifelong-learning",
  "type": "module",
  "version": "3.1.0",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "description": "The Lifelong Learning ecosystem: an advanced technical workspace demonstrating Astro 6 with hybrid SSG/SSR rendering, server-side APIs, islands UI, React integration, MDX content collections, TypeScript support, and modular component patterns for continuous learning and examples.",
  "keywords": [
    "astro",
    "astro-6",
    "astro-islands",
    "islands-architecture",
    "hybrid-rendering",
    "ssg",
    "ssr",
    "static-site",
    "static-site-generator",
    "api-routes",
    "server-endpoints",
    "serverless",
    "edge",
    "content-collections",
    "mdx",
    "markdown",
    "react",
    "react-integration",
    "typescript",
    "components",
    "design-system",
    "starter",
    "boilerplate",
    "performance",
    "seo",
    "rss",
    "sitemap",
    "scss",
    "web-performance",
    "education",
    "tutorial",
    "example",
    "accessibility"
  ],
  "scripts": {
    "dev": "astro dev",
    "dev:remote": "astro dev --remote",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "npm run clean && astro build --remote",
    "preview": "astro preview",
    "clean": "rimraf dist",
    "check": "astro check",
    "sync": "astro sync",
    "info": "astro info",
    "upgrade": "npx @astrojs/upgrade",
    "astro": "astro",
    "db:push": "astro db push --remote",
    "db:seed": "astro db execute db/seed.ts --remote",
    "server": "json-server mock/db.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "help": "cat docs/help.txt",
    "list": "npm run"
  },
  "author": {
    "name": "Alan Ryan da Silva Domingues",
    "email": "alanryan619@gmail.com",
    "url": "https://github.com/0nF1REy"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0nF1REy/astro-workspace.git"
  },
  "bugs": {
    "url": "https://github.com/0nF1REy/astro-workspace/issues"
  },
  "dependencies": {
    "@astrojs/db": "^0.21.2",
    "@astrojs/vercel": "^10.0.7",
    "astro": "^6.3.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/compiler-rs": "^0.2.1",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.5",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@eslint/js": "^10.0.1",
    "@fortawesome/fontawesome-free": "^6.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "concurrently": "^9.2.1",
    "csv-parse": "^6.2.1",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "json-server": "^1.0.0-beta.15",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "sass-embedded": "^1.99.0",
    "toml": "^4.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
