---
const { avatar, name, time } = Astro.props;
---

<div class="author">
  <img class="author__avatar" src={avatar} alt={name} />
  <div class="author__content">
    <p class="author__name">{name}</p>
    <p class="author__time">{time}</p>
  </div>
</div>

<style lang="scss">
  .author {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding-top: 1rem;
    margin-top: 1rem;
    border-top: 1px solid rgba(253, 230, 138, 0.08);
  }

  .author__avatar {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid rgba(253, 230, 138, 0.16);
    box-shadow: 0 10px 18px rgba(0, 0, 0, 0.24);
  }

  .author__content {
    display: grid;
    gap: 0.2rem;
  }

  .author__name {
    color: var(--text);
    font-weight: 700;
    font-size: 0.98rem;
  }

  .author__time {
    color: var(--muted);
    font-size: 0.88rem;
  }
</style>
