---
import Button from "../components/Button.astro";

interface FeatureItem {
  checked: boolean;
  title: string;
}

interface PricingCardData {
  tier: string;
  most_popular: boolean;
  amount_per_month: number;
  title: string;
  description: string;
  btn_text: string;
  features: FeatureItem[];
}

interface Props {
  cardData: PricingCardData;
}

const { cardData } = Astro.props;

const {
  tier,
  most_popular,
  amount_per_month,
  title,
  description,
  btn_text,
  features,
} = cardData;
---

<article class:list={["pricing-card", { "pricing-card--popular": most_popular }]}>
  <div class="pricing-card__header">
    <div class="pricing-card__tier">{tier}</div>
    {most_popular && <div class="pricing-card__badge">Mais Popular</div>}
  </div>

  <div class="pricing-card__price">
    <div class="pricing-card__amount">
      <span class="pricing-card__currency">R$</span>
      <span class="pricing-card__number">{amount_per_month}</span>
      {amount_per_month > 0 && <span class="pricing-card__period">/mês</span>}
    </div>
  </div>

  <div class="pricing-card__info">
    <h3 class="pricing-card__title">{title}</h3>
    <p class="pricing-card__description">{description}</p>
  </div>

  <Button class="pricing-card__button" id={tier.toLowerCase()}>
    {btn_text}
  </Button>

  <div class="pricing-card__features">
    {
      features.map((f) => (
        <div class="pricing-card__feature">
          <div class="pricing-card__feature-icon" aria-hidden="true">
            {f.checked ? (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 15 15"
              >
                <path
                  fill="currentColor"
                  fill-rule="evenodd"
                  d="M11.467 3.727c.289.189.37.576.181.865l-4.25 6.5a.625.625 0 0 1-.944.12l-2.75-2.5a.625.625 0 0 1 .841-.925l2.208 2.007l3.849-5.886a.625.625 0 0 1 .865-.181"
                  clip-rule="evenodd"
                />
              </svg>
            ) : (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 15 15"
              >
                <path
                  fill="currentColor"
                  fill-rule="evenodd"
                  d="M11.782 4.032a.575.575 0 1 0-.813-.814L7.5 6.687L4.032 3.218a.575.575 0 0 0-.814.814L6.687 7.5l-3.469 3.468a.575.575 0 0 0 .814.814L7.5 8.313l3.469 3.469a.575.575 0 0 0 .813-.814L8.313 7.5z"
                  clip-rule="evenodd"
                />
              </svg>
            )}
          </div>
          <p class="pricing-card__feature-text">{f.title}</p>
        </div>
      ))
    }
  </div>
</article>

<style lang="scss">
  .pricing-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    border-radius: 20px;
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.88),
      rgba(20, 17, 14, 0.86)
    );
    border: 1px solid rgba(251, 146, 60, 0.12);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(10px);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      background 0.3s ease;
  }

  .pricing-card--popular {
    border-color: rgba(251, 146, 60, 0.28);
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.96),
      rgba(20, 17, 14, 0.94)
    );
    box-shadow:
      0 20px 40px rgba(251, 146, 60, 0.12),
      0 16px 32px rgba(0, 0, 0, 0.28);
    transform: scale(1.02);
  }

  .pricing-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .pricing-card__tier {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .pricing-card__badge {
    padding: 6px 12px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(251, 146, 60, 0.18);
    color: var(--orange);
    border-radius: 999px;
    border: 1px solid rgba(251, 146, 60, 0.3);
  }

  .pricing-card__price {
    border-bottom: 1px solid rgba(253, 230, 138, 0.08);
    padding-bottom: 1.5rem;
  }

  .pricing-card__amount {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .pricing-card__currency {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--orange);
  }

  .pricing-card__number {
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1;
    color: var(--text);
  }

  .pricing-card__period {
    font-size: 0.95rem;
    color: var(--muted);
    margin-left: 0.4rem;
  }

  .pricing-card__info {
    display: grid;
    gap: 0.7rem;
  }

  .pricing-card__title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }

  .pricing-card__description {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .pricing-card__button {
    width: 100%;
    padding: 12px 16px;
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: 999px;
    background: var(--orange);
    color: var(--bg);
    border: none;
    cursor: pointer;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;

    &:hover {
      background: var(--cream);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(251, 146, 60, 0.24);
    }

    &:active {
      transform: translateY(0);
    }
  }

  .pricing-card__features {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid rgba(253, 230, 138, 0.08);
    padding-top: 1.5rem;
  }

  .pricing-card__feature {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .pricing-card__feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--orange);

    svg {
      width: 100%;
      height: 100%;
    }
  }

  .pricing-card__feature-icon svg {
    color: var(--orange);
  }

  .pricing-card__feature:has(.pricing-card__feature-icon svg path[fill="currentColor"]:not([fill-rule])) {
    .pricing-card__feature-icon {
      color: var(--muted);
    }
  }

  .pricing-card__feature-text {
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.5;
    margin-top: 2px;
  }

  @media (max-width: 640px) {
    .pricing-card {
      padding: 1.5rem;
      gap: 1.2rem;
    }

    .pricing-card--popular {
      transform: scale(1);
    }

    .pricing-card__price {
      padding-bottom: 1.2rem;
    }

    .pricing-card__features {
      padding-top: 1.2rem;
      gap: 0.8rem;
    }
  }
</style>
