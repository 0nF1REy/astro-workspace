---
import Author from "./Author.astro";

const { data } = Astro.props;
---

<article class="card">
  <img
    class="card__image"
    src={data.hero}
    alt={data.title}
    loading="lazy"
    decoding="async"
  />
  <div class="card__content">
    <p class="card__badge">{data.category}</p>
    <h2 class="card__title">{data.title}</h2>
    <p class="card__description">{data.description}</p>
    <Author
      name={data.author.name}
      avatar={data.author.avatar}
      time={data.time}
    />
  </div>
</article>

<style lang="scss">
  .card {
    overflow: hidden;
    display: grid;
    gap: 0;
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.92),
      rgba(20, 17, 14, 0.92)
    );
    border: 1px solid rgba(253, 230, 138, 0.08);
    border-radius: 30px;
    box-shadow:
      0 24px 48px rgba(0, 0, 0, 0.36),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: rgba(251, 146, 60, 0.18);
    box-shadow:
      0 28px 60px rgba(0, 0, 0, 0.46),
      0 0 0 1px rgba(251, 146, 60, 0.06);
  }

  .card__image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }

  .card__content {
    display: grid;
    gap: 0.85rem;
    padding: 1.4rem;
  }

  .card__badge {
    width: fit-content;
    padding: 0.38rem 0.8rem;
    border-radius: 999px;
    background: rgba(251, 146, 60, 0.12);
    border: 1px solid rgba(251, 146, 60, 0.22);
    color: var(--cream);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card__title {
    color: var(--text);
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    line-height: 1.15;
  }

  .card__description {
    color: var(--muted);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .card {
      border-radius: 22px;
    }

    .card__content {
      padding: 1.1rem;
    }
  }
</style>
