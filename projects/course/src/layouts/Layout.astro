---
import "@styles/global.scss";
import Link from "@components/Link.astro";
import menu, { type MenuItem } from "@data/menu";

const { title = "default" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Curso | Aprendendo Astro</title>
  </head>

  <body>
    <header class="site-header">
      <div class="site-shell">
        <nav class="site-nav">
          {
            menu.map((item: MenuItem) => (
              <Link
                class={
                  item.href === "/" ? "nav-link nav-link-home" : "nav-link"
                }
                href={item.href}
              >
                {item.label}
              </Link>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="site-shell">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-shell">
        <div class="site-footer-inner">
          <p class="site-footer-text">
            © {new Date().getFullYear()} Curso | Aprendendo Astro
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style lang="scss">
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    padding: 18px 24px;
    backdrop-filter: blur(12px);
    background: rgba(25, 22, 18, 0.82);
    border-bottom: 1px solid rgba(253, 230, 138, 0.08);
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      backdrop-filter 0.3s ease;
  }

  .site-shell {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
  }

  .site-nav {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-link {
    text-decoration: none;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid transparent;
    padding: 12px 20px;
    border-radius: 999px;
    font-weight: 700;
    letter-spacing: 0.4px;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: 0 8px 20px var(--shadow);
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--surface-light);
    border-color: rgba(251, 146, 60, 0.3);
    transform: translateY(-3px);
    box-shadow: 0 12px 24px rgba(251, 146, 60, 0.14);
  }

  .nav-link-home {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 1.25rem;
    border: 1px solid rgba(253, 230, 138, 0.16);
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      var(--surface),
      rgba(251, 146, 60, 0.22)
    );
    color: var(--text);
    box-shadow:
      0 10px 24px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      filter 0.2s ease,
      background 0.2s ease;
  }

  .nav-link-home:hover {
    transform: translateY(-2px);
    border-color: rgba(251, 146, 60, 0.34);
    background: linear-gradient(
      135deg,
      var(--surface-light),
      rgba(251, 146, 60, 0.28)
    );
    box-shadow:
      0 14px 28px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(251, 146, 60, 0.08);
  }

  .nav-link-home:active {
    transform: translateY(0);
    filter: brightness(0.98);
  }

  .nav-link-home:focus-visible {
    outline: 3px solid rgba(253, 230, 138, 0.65);
    outline-offset: 3px;
  }

  .site-main {
    flex: 1;
    width: 100%;
    padding: 56px 24px;
  }

  .site-footer {
    width: 100%;
    display: flex;
    justify-content: center;
    border-top: 1px solid rgba(253, 230, 138, 0.08);
    background: rgba(20, 17, 14, 0.92);
    backdrop-filter: blur(8px);
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      backdrop-filter 0.3s ease;
  }

  .site-footer-inner {
    width: 100%;
    padding: 30px 0;
    text-align: center;
  }

  .site-footer-text {
    color: var(--muted);
    font-size: 0.92rem;
    letter-spacing: 0.4px;
    transition: color 0.2s ease;
  }

  .surface-card {
    background: var(--surface);
    border: 1px solid rgba(253, 230, 138, 0.06);
    border-radius: 28px;
    padding: 28px;
    box-shadow: 0 20px 40px var(--shadow);
    backdrop-filter: blur(10px);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease;
  }

  .surface-card:hover {
    transform: translateY(-4px);
    border-color: rgba(251, 146, 60, 0.18);
    box-shadow: 0 26px 50px rgba(0, 0, 0, 0.5);
  }

  .title-gradient {
    background: linear-gradient(135deg, var(--orange), var(--cream));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: filter 0.2s ease;
  }

  .title-gradient:hover {
    filter: brightness(1.08);
  }

  @media (max-width: 640px) {
    .site-nav {
      flex-wrap: wrap;
    }

    .nav-link {
      width: 100%;
      text-align: center;
    }

    .site-main {
      padding: 38px 18px;
    }

    .surface-card {
      padding: 22px;
      border-radius: 22px;
    }
  }
</style>
