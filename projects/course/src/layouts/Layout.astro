---
const { title = "default" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Curso | Aprendendo astro</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a class="nav-link nav-link-home" href="/">Inicio</a>
        <a class="nav-link" href="about">Sobre</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="site-footer-inner">
        <p class="site-footer-text">
          © {new Date().getFullYear()} Curso | Aprendendo Astro
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  :root {
    --bg: #0f172a;
    --card: #0b1220;
    --accent: #7dd3fc;
    --muted: #94a3b8;
    --success: #34d399;
    --danger: #fb7185;
    --text: #e6eef8;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .site-header {
    width: 100%;
    background: var(--bg);
    border-bottom: 1px solid rgba(125, 211, 252, 0.06);
    backdrop-filter: blur(6px);
    display: flex;
    justify-content: center;
    padding: 0.75rem 1rem;
  }

  .site-nav {
    width: 100%;
    max-width: 720px;
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .nav-link {
    color: var(--text);
    text-decoration: none;
    padding: 0.45rem 0.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition:
      background 0.12s ease,
      color 0.12s ease,
      transform 0.12s ease;
    border: 1px solid transparent;
  }

  .nav-link:hover {
    background: rgba(125, 211, 252, 0.06);
    transform: translateY(-2px);
  }

  .nav-link.active,
  .nav-link-home {
    background: linear-gradient(
      90deg,
      rgba(125, 211, 252, 0.08),
      rgba(125, 211, 252, 0.03)
    );
    color: var(--accent);
    border: 1px solid rgba(125, 211, 252, 0.12);
  }

  .site-footer {
    width: 100%;
    margin-top: 2rem;
    border-top: 1px solid rgba(125, 211, 252, 0.06);
    background: var(--bg);
    display: flex;
    justify-content: center;
    padding: 1rem;
  }

  .site-footer-inner {
    width: 100%;
    max-width: 720px;
  }

  .site-footer-text {
    color: var(--muted);
    font-size: 0.9rem;
    text-align: center;
  }

  @media (max-width: 520px) {
    .site-nav {
      gap: 0.5rem;
    }

    .nav-link {
      padding: 0.35rem 0.5rem;
      font-size: 0.9rem;
    }

    .site-footer-text {
      font-size: 0.82rem;
    }
  }
</style>
