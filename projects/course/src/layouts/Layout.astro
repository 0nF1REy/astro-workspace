---
import "../styles/global.scss";
import Link from "../components/Link.astro";

const { title = "default" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Curso | Aprendendo Astro</title>
  </head>

  <body>
    <header class="site-header">
      <div class="site-shell">
        <nav class="site-nav">
          <Link class="nav-link nav-link-home" href="/">Inicio</Link>
          <Link class="nav-link" href="about">Sobre</Link>
          <Link class="nav-link" href="card">Card</Link>
          <Link class="nav-link" href="button">Button</Link>
          <Link class="nav-link" href="heading">Heading</Link>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="site-shell">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-shell">
        <div class="site-footer-inner">
          <p class="site-footer-text">
            © {new Date().getFullYear()} Curso | Aprendendo Astro
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
