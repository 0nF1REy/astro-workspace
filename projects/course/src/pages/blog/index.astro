---
import Layout from "../../layouts/Layout.astro";

type Frontmatter = {
  title: string;
};

type PostEntry = {
  url: string;
  frontmatter: Frontmatter;
};

const posts = Object.values(
  (import.meta as any).glob("./*.{md,mdx}", { eager: true }),
) as PostEntry[];
---

<Layout title="Blog">
  <h1>Blog Page</h1>
  <ul>
    {
      posts.map((p: PostEntry) => (
        <li>
          <a href={p.url}>{p.frontmatter.title}</a>
        </li>
      ))
    }
  </ul>
</Layout>
