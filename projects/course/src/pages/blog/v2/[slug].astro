---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params as { slug: string };

const posts = await getCollection("posts");
const match = posts.find((post) => post.id === slug);

if (!match) {
  throw new Error(`Post not found: ${slug}`);
}

const data = match.data;
const { Content } = await render(match);

const coverImages = import.meta.glob(
  "/src/content/post/images/*.{jpg,jpeg,png,webp,avif,gif}",
  {
    eager: true,
    import: "default",
  },
) as Record<string, any>;

const coverImage = Object.entries(coverImages).find(([path]) => {
  const fileName = path.split("/").pop() || path;
  const fileSlug = fileName.replace(/\.[^.]+$/, "");
  return fileSlug === slug;
})?.[1];
---

<Layout title={data.title ?? slug}>
  <article class="post-page surface-card">
    {coverImage && (
      <Image
        class="post-cover"
        src={coverImage}
        alt={data.coverAlt ?? data.title ?? slug}
        loading="lazy"
      />
    )}
    <header>
      <p class="post-eyebrow">Post</p>
      <h1 class="post-title">{data.title ?? slug}</h1>
    </header>
    <section class="post-content">
      <Content />
    </section>
  </article>
</Layout>

<style lang="scss">
  .post-page {
    padding: 1.5rem;
    display: grid;
    gap: 1rem;
  }
  .post-cover {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }
  .post-title {
    margin: 0 0 0.5rem 0;
  }
  .post-content {
    margin-top: 1rem;
  }
</style>
