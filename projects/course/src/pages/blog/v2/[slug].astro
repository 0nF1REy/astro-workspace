---
import Layout from "@layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection, render, type CollectionEntry } from "astro:content";

type PostEntry = CollectionEntry<"posts">;

export async function getStaticPaths() {
  const posts: PostEntry[] = await getCollection("posts");
  return posts.map((post: PostEntry) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params as { slug: string };

const posts: PostEntry[] = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const match = posts.find((post: PostEntry) => post.id === slug);

if (!match) {
  throw new Error(`Post not found: ${slug}`);
}

const currentIndex = posts.findIndex((post: PostEntry) => post.id === slug);
const previousPost = currentIndex > 0 ? posts[currentIndex - 1] : null;
const nextPost =
  currentIndex >= 0 && currentIndex < posts.length - 1
    ? posts[currentIndex + 1]
    : null;

const data = match.data;
const { Content } = await render(match);

const coverImages = import.meta.glob(
  "/src/content/post/images/*.{jpg,jpeg,png,webp,avif,gif}",
  {
    eager: true,
    import: "default",
  },
) as Record<string, any>;

const coverImage = Object.entries(coverImages).find(([path]) => {
  const fileName = path.split("/").pop() || path;
  const fileSlug = fileName.replace(/\.[^.]+$/, "");
  return fileSlug === slug;
})?.[1];
---

<Layout title={data.title ?? slug}>
  <article class="post-page surface-card">
    {
      coverImage && (
        <Image
          class="post-cover"
          src={coverImage}
          alt={data.coverAlt ?? data.title ?? slug}
          loading="lazy"
        />
      )
    }
    <header>
      <p class="post-eyebrow">Post</p>
      <h1 class="post-title">{data.title ?? slug}</h1>
    </header>
    <section class="post-content">
      <Content />
    </section>

    <nav class="post-navigation" aria-label="Navegação entre posts">
      {
        previousPost ? (
          <a class="post-navigation__link" href={`/blog/v2/${previousPost.id}`}>
            <span class="post-navigation__eyebrow">Anterior</span>
            <strong>{previousPost.data.title}</strong>
          </a>
        ) : (
          <span class="post-navigation__link post-navigation__link--disabled">
            <span class="post-navigation__eyebrow">Anterior</span>
            <strong>Sem post anterior</strong>
          </span>
        )
      }

      {
        nextPost ? (
          <a
            class="post-navigation__link post-navigation__link--next"
            href={`/blog/v2/${nextPost.id}`}
          >
            <span class="post-navigation__eyebrow">Próximo</span>
            <strong>{nextPost.data.title}</strong>
          </a>
        ) : (
          <span class="post-navigation__link post-navigation__link--disabled post-navigation__link--next">
            <span class="post-navigation__eyebrow">Próximo</span>
            <strong>Sem próximo post</strong>
          </span>
        )
      }
    </nav>
  </article>
</Layout>

<style lang="scss">
  .post-page {
    padding: 1.5rem;
    display: grid;
    gap: 1rem;
  }
  .post-cover {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }
  .post-title {
    margin: 0 0 0.5rem 0;
  }
  .post-content {
    margin-top: 1rem;
  }

  .post-navigation {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .post-navigation__link {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border-radius: 14px;
    background: var(--surface);
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .post-navigation__link:hover {
    transform: translateY(-2px);
    background: var(--surface-light);
    color: var(--orange);
  }

  .post-navigation__link--next {
    text-align: right;
  }

  .post-navigation__link--disabled {
    opacity: 0.45;
    pointer-events: none;
  }

  .post-navigation__eyebrow {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
  }
</style>
