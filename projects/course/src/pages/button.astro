---
import Layout from "../layouts/Layout.astro";
import ButtonComponent from "../components/Button.astro";
---

<Layout title="Botão">
  <section class="button-page">
    <div class="button-page__copy">
      <p class="button-page__eyebrow">Component</p>
      <h1>Button</h1>
      <p class="button-page__lead">
        Uma página de exemplo para testar o botão.
      </p>
    </div>

    <div class="button-page__preview">
      <p class="button-page__label">Preview</p>
      <ButtonComponent aria-label="click me btn">Btn Text</ButtonComponent>
    </div>
  </section>
</Layout>

<style lang="scss">
  .button-page {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 1.5rem;
    align-items: center;
  }

  .button-page__copy,
  .button-page__preview {
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.88),
      rgba(20, 17, 14, 0.92)
    );
    border: 1px solid rgba(253, 230, 138, 0.08);
    border-radius: 28px;
    padding: 2rem;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(10px);
  }

  .button-page__eyebrow,
  .button-page__label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.9rem;
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .button-page h1 {
    font-size: clamp(2.2rem, 4vw, 4.2rem);
    line-height: 0.95;
    margin-bottom: 1rem;
    max-width: 10ch;
  }

  .button-page__lead {
    max-width: 55ch;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .button-page__preview {
    display: grid;
    gap: 1rem;
    justify-items: start;
    position: relative;
    overflow: hidden;
  }

  .button-page__preview::before {
    content: "";
    position: absolute;
    inset: auto -20% -35% auto;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(42, 20, 4, 0.701),
      transparent 70%
    );
    pointer-events: none;
  }

  @media (max-width: 820px) {
    .button-page {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .button-page__copy,
    .button-page__preview {
      padding: 1.4rem;
      border-radius: 22px;
    }
  }
</style>
