---
import type { GetStaticPaths } from "astro";
import Layout from "@layouts/Layout.astro";
import type { AnimeRes } from "../../types/AnimeType";

export const getStaticPaths = (async () => {
  const res = await fetch("https://api.jikan.moe/v4/top/anime?limit=25");
  const { data }: AnimeRes = await res.json();

  return data.map((anime) => ({
    params: { slugSSG: anime.mal_id.toString() },
    props: { anime },
  }));
}) satisfies GetStaticPaths;

const { anime } = Astro.props;
---

<Layout title={anime.title}>
  <section class="anime-detail">
    <div class="anime-detail__hero surface-card">
      <p class="anime-detail__eyebrow">Anime Detail</p>
      <h1 class="title-gradient anime-detail__title">{anime.title}</h1>
      <p class="anime-detail__lead">Gerado via SSG (Static Site Generation).</p>
    </div>

    <article class="anime-detail__card surface-card">
      <img
        src={anime.images.webp.large_image_url}
        alt={anime.title}
        class="anime-img"
      />
      <div class="anime-info">
        <p class="anime-detail__label">Sinopse</p>
        <p class="anime-desc">{anime.synopsis}</p>
        <div class="stats">
          <span
            ><i class="fas fa-star" aria-hidden="true"></i> {anime.score}</span
          >
          <span
            ><i class="fas fa-tv" aria-hidden="true"></i>
            {anime.episodes} episódios</span
          >
        </div>
        <a class="anime-detail__back" href="/anime">Voltar para a lista</a>
      </div>
    </article>
  </section>
</Layout>

<style lang="scss">
  .anime-detail {
    display: grid;
    gap: 1rem;
  }

  .anime-detail__hero {
    display: grid;
    gap: 0.85rem;
    padding: 2rem;
  }

  .anime-detail__eyebrow,
  .anime-detail__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .anime-detail__title {
    line-height: 1.1;
  }

  .anime-detail__lead {
    color: var(--muted);
    line-height: 1.7;
  }

  .anime-detail__card {
    display: grid;
    grid-template-columns: minmax(220px, 320px) 1fr;
    gap: 1.25rem;
    padding: 1.5rem;
    align-items: start;
  }

  .anime-img {
    width: 100%;
    border-radius: 14px;
    display: block;
    object-fit: cover;
    max-height: 460px;
  }

  .anime-info {
    display: grid;
    gap: 0.85rem;
  }

  .anime-desc {
    color: var(--muted);
    line-height: 1.75;
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    color: var(--text);
    font-weight: 700;
  }

  .anime-detail__back {
    width: fit-content;
    color: var(--cream);
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .anime-detail__back:hover {
    color: var(--orange);
    transform: translateX(3px);
  }

  .stats i {
    margin-right: 0.5rem;
    color: var(--orange);
  }

  @media (max-width: 860px) {
    .anime-detail__card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .anime-detail__hero,
    .anime-detail__card {
      padding: 1.25rem;
    }
  }
</style>
