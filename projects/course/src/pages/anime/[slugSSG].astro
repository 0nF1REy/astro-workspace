---
import type { GetStaticPaths } from "astro";
import Layout from "@layouts/Layout.astro";
import { fetchTopAnime } from "../../lib/anime/fetchTopAnime.ts";

export const getStaticPaths = (async () => {
  const animeList = await fetchTopAnime();

  return animeList.map((anime) => ({
    params: { slugSSG: anime.mal_id.toString() },
    props: { anime },
  }));
}) satisfies GetStaticPaths;

const { anime } = Astro.props;
---

<Layout title={anime.title}>
  <section class="anime-detail">
    <article class="anime-detail__card surface-card">
      <div class="anime-detail__hero">
        <p class="anime-detail__eyebrow">Anime Detail</p>
        <h1 class="title-gradient anime-detail__title">{anime.title}</h1>
        <p class="anime-detail__lead">
          Gerado via SSG (Static Site Generation).
        </p>
      </div>

      <div class="anime-detail__body">
        <img
          src={anime.images.webp.large_image_url}
          alt={anime.title}
          class="anime-img"
        />

        <div class="anime-info">
          <p class="anime-detail__label">Sinopse</p>
          <p class="anime-desc">{anime.synopsis}</p>
          <div class="stats">
            <span
              ><i class="fas fa-star" aria-hidden="true"></i>
              {anime.score}</span
            >
            <span
              ><i class="fas fa-tv" aria-hidden="true"></i>
              {anime.episodes} episódios</span
            >
          </div>
          <a class="anime-detail__back" href="/anime">Voltar para a lista</a>
        </div>
      </div>
    </article>
  </section>
</Layout>

<style lang="scss">
  .anime-detail {
    display: grid;
    gap: 1rem;
  }

  .anime-detail__hero {
    display: grid;
    gap: 0.85rem;
  }

  .anime-detail__body {
    display: grid;
    grid-template-columns: minmax(220px, 320px) 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .anime-detail__eyebrow,
  .anime-detail__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .anime-detail__title {
    line-height: 1.1;
  }

  .anime-detail__lead {
    color: var(--cream);
    line-height: 1.7;
    font-weight: 700;
    background: rgba(251, 146, 60, 0.08);
    padding: 0.45rem 0.65rem;
    border-radius: 8px;
    display: inline-block;
    font-size: 1.02rem;
  }

  .anime-detail__card {
    display: grid;
    gap: 1.25rem;
    padding: 1.5rem;
  }

  .anime-img {
    width: 100%;
    border-radius: 14px;
    display: block;
    object-fit: cover;
    max-height: 460px;
  }

  .anime-info {
    display: grid;
    gap: 0.85rem;
  }

  .anime-desc {
    color: var(--muted);
    line-height: 1.75;
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    color: var(--text);
    font-weight: 700;
  }

  .anime-detail__back {
    width: fit-content;
    color: var(--cream);
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .anime-detail__back:hover {
    color: var(--orange);
    transform: translateX(3px);
  }

  .stats i {
    margin-right: 0.5rem;
    color: var(--orange);
  }

  @media (max-width: 860px) {
    .anime-detail__body {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .anime-detail__card {
      padding: 1.25rem;
    }
  }
</style>
