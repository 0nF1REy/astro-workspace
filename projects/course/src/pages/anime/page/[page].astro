---
import type { GetStaticPaths } from "astro";
import Layout from "@layouts/Layout.astro";
import AnimePage from "@components/AnimePage.astro";
import type { AnimeRes } from "../../../types/AnimeType";

export const getStaticPaths = (async () => {
  const pageSize = 10;
  const res = await fetch("https://api.jikan.moe/v4/top/anime?limit=25");
  const { data }: AnimeRes = await res.json();
  const lastPage = Math.max(1, Math.ceil(data.length / pageSize));

  return Array.from({ length: Math.max(0, lastPage - 1) }, (_, index) => {
    const currentPage = index + 2;
    const start = (currentPage - 1) * pageSize;
    const end = currentPage * pageSize;

    return {
      params: { page: currentPage.toString() },
      props: {
        data: data.slice(start, end),
        currentPage,
        lastPage,
      },
    };
  });
}) satisfies GetStaticPaths;

const { data, currentPage, lastPage } = Astro.props as {
  data: AnimeRes["data"];
  currentPage: number;
  lastPage: number;
};
---

<Layout title="Animes">
  <AnimePage data={data} currentPage={currentPage} lastPage={lastPage} />
</Layout>
