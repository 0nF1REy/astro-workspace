---
import Layout from "@layouts/Layout.astro";
import type { AnimeRes } from "../../types/AnimeType";

const res = await fetch("https://api.jikan.moe/v4/top/anime?limit=25");
const { data }: AnimeRes = await res.json();
---

<Layout title="Animes">
  <section class="anime-page">
    <div class="anime-page__hero surface-card">
      <p class="anime-page__eyebrow">MyAnimeList</p>
      <h1 class="title-gradient">Top Animes</h1>
      <p class="anime-page__lead">
        Explore os animes mais populares da atualidade consumindo a API Jikan.
      </p>
    </div>

    <ul class="anime-page__grid" role="list">
      {
        data.map((anime) => (
          <li class="anime-page__card surface-card">
            <p class="anime-page__label">Anime ID: {anime.mal_id}</p>
            <h2>{anime.title}</h2>
            <a class="anime-page__link" href={`/anime/${anime.mal_id}`}>
              Ver detalhes
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style lang="scss">
  .anime-page {
    display: grid;
    gap: 1.5rem;
  }

  .anime-page__hero {
    display: grid;
    gap: 0.85rem;
    padding: 2rem;
  }

  .anime-page__eyebrow,
  .anime-page__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .anime-page__lead {
    max-width: 60ch;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .anime-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    padding: 0;
    margin: 0;
  }

  .anime-page__card {
    display: grid;
    gap: 0.9rem;
    padding: 1.5rem;
    align-content: start;
    list-style: none;
  }

  .anime-page__card h2 {
    font-size: clamp(1.2rem, 3vw, 1.65rem);
    line-height: 1.2;
  }

  .anime-page__link {
    width: fit-content;
    color: var(--cream);
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .anime-page__link:hover {
    color: var(--orange);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .anime-page__hero,
    .anime-page__card {
      padding: 1.25rem;
    }
  }
</style>
