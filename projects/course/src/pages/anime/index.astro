---
import Layout from "@layouts/Layout.astro";
import AnimePage from "@components/AnimePage.astro";
import type { AnimeRes } from "../../types/AnimeType";

const res = await fetch("https://api.jikan.moe/v4/top/anime?limit=25");
const { data }: AnimeRes = await res.json();

const pageSize = 10;
const lastPage = Math.max(1, Math.ceil(data.length / pageSize));
const firstPage = data.slice(0, pageSize);
---

<Layout title="Animes">
  <AnimePage data={firstPage} currentPage={1} lastPage={lastPage} />
</Layout>
