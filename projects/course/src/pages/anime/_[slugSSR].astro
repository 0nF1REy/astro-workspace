---
export const prerender = false;
import Layout from "@layouts/Layout.astro";

const { slugSSR } = Astro.params;

const res = await fetch(`https://api.jikan.moe/v4/anime/${slugSSR}`);
if (res.status === 404) return Astro.redirect("/404");

const { data } = await res.json();
---

<Layout title={data.title}>
  <section class="anime-detail">
    <div class="anime-detail__hero surface-card">
      <p class="anime-detail__eyebrow">Anime Detail</p>
      <h1 class="title-gradient anime-detail__title">{data.title}</h1>
      <p class="anime-detail__lead">Carregado em tempo real via SSR.</p>
    </div>

    <article class="anime-detail__card surface-card">
      <p class="anime-detail__label">Modo</p>
      <p>SSR habilitado para este ID específico: <code>{slugSSR}</code>.</p>
      <p class="anime-desc">{data.synopsis}</p>
      <a class="anime-detail__back" href="/anime">Voltar para a lista</a>
    </article>
  </section>
</Layout>

<style lang="scss">
  .anime-detail {
    display: grid;
    gap: 1rem;
  }

  .anime-detail__hero {
    display: grid;
    gap: 0.85rem;
    padding: 2rem;
  }

  .anime-detail__eyebrow,
  .anime-detail__label {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .anime-detail__title {
    line-height: 1.1;
  }

  .anime-detail__lead,
  .anime-desc {
    color: var(--muted);
    line-height: 1.75;
  }

  .anime-detail__card {
    display: grid;
    gap: 0.85rem;
    padding: 1.5rem;
  }

  .anime-detail__back {
    width: fit-content;
    color: var(--cream);
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .anime-detail__back:hover {
    color: var(--orange);
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .anime-detail__hero,
    .anime-detail__card {
      padding: 1.25rem;
    }
  }
</style>
