---
import Layout from "../layouts/Layout.astro";
import CounterComponent from "../components/Counter";
---

<Layout title="Counter">
  <section class="counter-page">
    <div class="counter-page__hero card">
      <p class="counter-page__eyebrow">React + Astro</p>
      <h1 class="title-gradient">Counter</h1>
      <p class="counter-page__lead">
        Essa página demonstra o componente React funcionando dentro do Astro,
        com uma composição visual alinhada ao restante do projeto.
      </p>
    </div>

    <div class="counter-page__panel card">
      <CounterComponent client:load />
    </div>
  </section>
</Layout>

<style lang="scss">
  .counter-page {
    display: grid;
    gap: 1.5rem;
  }

  .counter-page__hero,
  .counter-page__panel {
    padding: 2rem;
  }

  .counter-page__hero {
    display: grid;
    gap: 0.85rem;
  }

  .counter-page__eyebrow {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .counter-page h1 {
    font-size: clamp(2.6rem, 7vw, 5rem);
    line-height: 0.95;
  }

  .counter-page__lead {
    max-width: 52rem;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .counter-page__panel {
    display: grid;
  }

  @media (max-width: 640px) {
    .counter-page__hero,
    .counter-page__panel {
      padding: 1.25rem;
    }
  }
</style>
