---
export const prerender = false;
import Layout from "@layouts/Layout.astro";

const { slugSSR } = Astro.params;

if (!slugSSR) {
  return Astro.redirect("404");
}

const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${slugSSR}`);
const data = await res.json();
---

<Layout>
  <h1>{data.name}</h1>
</Layout>
