---
interface Todo {
  title: string;
  completed: boolean;
}

const res = await fetch("https://jsonplaceholder.typicode.com/todos");
const todos: Todo[] = await res.json();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HOME</title>
  </head>

  <body>
    <main class="container">
      <h1 class="heading">Lista de Todos</h1>

      <ul class="todo-list" role="list">
        {
          todos.slice(0, 10).map((todo: Todo) => (
            <li class={`todo-item ${todo.completed ? "completed" : "pending"}`}>
              <div class="todo-content">
                <strong class="todo-title">{todo.title}</strong>
                <span class="todo-status">
                  {todo.completed ? "Concluído" : "Pendente"}
                </span>
              </div>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #0f172a;
    --card: #0b1220;
    --accent: #7dd3fc;
    --muted: #94a3b8;
    --success: #34d399;
    --danger: #fb7185;
    --text: #e6eef8;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      "Segoe UI",
      Roboto,
      "Helvetica Neue",
      Arial;
    background: linear-gradient(180deg, #071026 0%, #071834 100%);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .container {
    width: 100%;
    max-width: 720px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.02),
      rgba(255, 255, 255, 0.01)
    );
    border: 1px solid rgba(125, 211, 252, 0.08);
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: 0 10px 30px rgba(2, 6, 23, 0.6);
  }

  .heading {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .todo-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .todo-item {
    display: flex;
    align-items: center;
    padding: 0.75rem;
    border-radius: 8px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.01),
      rgba(255, 255, 255, 0.005)
    );
    border: 1px solid rgba(255, 255, 255, 0.03);
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
  }

  .todo-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(2, 6, 23, 0.5);
  }

  .todo-content {
    display: flex;
    justify-content: space-between;
    width: 100%;
    gap: 1rem;
    align-items: center;
  }

  .todo-title {
    font-size: 0.98rem;
    color: var(--text);
    flex: 1;
    margin-right: 0.5rem;
  }

  .todo-status {
    font-size: 0.85rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    color: #031025;
    font-weight: 600;
  }

  .todo-item.completed .todo-status {
    background: linear-gradient(
      90deg,
      rgba(52, 211, 153, 0.12),
      rgba(52, 211, 153, 0.08)
    );
    color: var(--success);
    border: 1px solid rgba(52, 211, 153, 0.12);
  }

  .todo-item.pending .todo-status {
    background: linear-gradient(
      90deg,
      rgba(251, 113, 133, 0.06),
      rgba(251, 113, 133, 0.03)
    );
    color: var(--danger);
    border: 1px solid rgba(251, 113, 133, 0.06);
  }

  @media (max-width: 520px) {
    .container {
      padding: 1rem;
    }
    .heading {
      font-size: 1.15rem;
    }
    .todo-title {
      font-size: 0.95rem;
    }
    .todo-status {
      font-size: 0.8rem;
      padding: 0.2rem 0.5rem;
    }
  }
</style>
