---
import Layout from "@layouts/Layout.astro";
import { getCollection } from "astro:content";
import { ListProducts } from "@components/ListProducts";

const products = await getCollection("products", ({ data }) => data.in_stock);
---

<Layout title="Catálogo de Produtos">
  <section class="products-container">
    <aside class="products-catalog">
      <header class="products-catalog__header">
        <p class="products-catalog__eyebrow">Collection</p>
        <h1 class="products-catalog__title">Catálogo de Produtos</h1>
        <p class="products-catalog__subtitle">
          Lista de produtos renderizados a partir da coleção `products`.
        </p>
      </header>

      <ul class="products-grid">
        {
          products.map(({ data }) => (
            <li class="product-card">
              <div class="product-card__top">
                <span class="product-card__status">
                  {data.in_stock ? "Em estoque" : "Esgotado"}
                </span>
              </div>

              <h3 class="product-card__title">{data.product_name}</h3>

              <div class="product-card__meta">
                <div class="product-card__price">R$ {data.price}</div>
                <div class="product-card__brand">
                  {data.details.brand} — {data.details.model}
                </div>
                <div class="product-card__colors">
                  Cores: {data.colors.join(", ")}
                </div>
              </div>
            </li>
          ))
        }
      </ul>
    </aside>

    <aside class="products-dynamic">
      <header class="products-dynamic__header">
        <h2 class="products-catalog__title">Lista de Produtos (React)</h2>
        <p class="products-catalog__subtitle">
          Lista de produtos carregados dinamicamente via API `product.json`.
        </p>
      </header>
      <ListProducts client:load />
    </aside>
  </section>
</Layout>

<style lang="scss">
  .products-container {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
    gap: 2.5rem;
    padding: 1.5rem 0;
    position: relative;
  }

  .products-container::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 1px;
    background: rgba(253, 230, 138, 0.12);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .products-catalog,
  .products-dynamic {
    display: grid;
    gap: 1.5rem;
  }

  /* Catalog Section */
  .products-catalog__header,
  .products-dynamic__header {
    display: grid;
    gap: 0.75rem;
  }

  .products-catalog__eyebrow {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .products-catalog__title {
    font-size: clamp(2.3rem, 6vw, 4.3rem);
    line-height: 0.96;
    max-width: 15ch;
    background: linear-gradient(135deg, var(--orange), var(--cream));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .products-catalog__subtitle {
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
    max-width: 58ch;
  }

  /* Product Grid */
  .products-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 0;
    padding: 0;
  }

  .product-card {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid rgba(253, 230, 138, 0.06);
    border-radius: 28px;
    box-shadow: 0 20px 40px var(--shadow);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(251, 146, 60, 0.18);
    box-shadow: 0 26px 50px rgba(0, 0, 0, 0.5);
  }

  .product-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .product-card__status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(251, 146, 60, 0.14);
    border: 1px solid rgba(251, 146, 60, 0.22);
    color: var(--cream);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .product-card__title {
    font-size: clamp(1.35rem, 3vw, 1.8rem);
    line-height: 1.1;
    color: var(--cream);
  }

  .product-card__meta {
    display: grid;
    gap: 0.5rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .product-card__price {
    color: var(--text);
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1;
  }

  .product-card__brand,
  .product-card__colors {
    font-size: 0.98rem;
  }

  /* Responsive */
  @media (max-width: 920px) {
    .products-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .products-container::before {
      display: none;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .products-container {
      padding: 1rem 0;
    }

    .products-catalog,
    .products-dynamic {
      gap: 1.25rem;
    }

    .products-catalog__title {
      max-width: none;
    }

    .product-card {
      padding: 1.25rem;
      border-radius: 22px;
    }
  }
</style>
