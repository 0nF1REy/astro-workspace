---
import Layout from "../layouts/Layout.astro";
import data from "../data/data.json";
import CardComponent from "../components/Card.astro";
---

<Layout title="Card">
  <section class="cards-page">
    <div class="cards-page__hero">
      <p class="cards-page__eyebrow">Content cards</p>
      <h1>Cards</h1>
      <p class="cards-page__lead">
        Um conjunto de cards com visual glass, bordas quentes e hierarquia
        limpa, seguindo o padrão do projeto.
      </p>
    </div>

    <div class="cards-page__grid">
      {data.map((card) => <CardComponent data={card} />)}
    </div>
  </section>
</Layout>

<style lang="scss">
  .cards-page {
    display: grid;
    gap: 2rem;
  }

  .cards-page__hero {
    display: grid;
    gap: 0.85rem;
    max-width: 58rem;
    padding: 2rem;
    border-radius: 28px;
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.9),
      rgba(20, 17, 14, 0.88)
    );
    border: 1px solid rgba(253, 230, 138, 0.08);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(10px);
  }

  .cards-page__eyebrow {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .cards-page h1 {
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    line-height: 0.95;
  }

  .cards-page__lead {
    max-width: 60ch;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .cards-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }

  @media (max-width: 640px) {
    .cards-page__hero {
      padding: 1.4rem;
      border-radius: 22px;
    }
  }
</style>
