---
import Layout from "../layouts/Layout.astro";
import pricings from "../data/pricing.json";
import PricingCard from "../components/PricingCard.astro";
---

<Layout title="Preços">
  <section class="pricing-page">
    <div class="pricing-page__hero">
      <p class="pricing-page__eyebrow">Planos e preços</p>
      <h1>Escolha seu plano</h1>
      <p class="pricing-page__lead">
        Selecione o plano ideal para suas necessidades. Todos incluem suporte
        por email e acesso à comunidade.
      </p>
    </div>

    <div class="pricing-page__grid">
      {pricings.map((card) => <PricingCard cardData={card} />)}
    </div>

    <div class="pricing-page__footer">
      <p class="pricing-page__footer-text">
        Precisa de mais? Entre em contato para soluções personalizadas.
      </p>
    </div>
  </section>
</Layout>

<style lang="scss">
  .pricing-page {
    display: grid;
    gap: 3rem;
  }

  .pricing-page__hero {
    display: grid;
    gap: 0.85rem;
    padding: 2rem;
    border-radius: 28px;
    background: linear-gradient(
      180deg,
      rgba(38, 33, 29, 0.9),
      rgba(20, 17, 14, 0.88)
    );
    border: 1px solid rgba(253, 230, 138, 0.08);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(10px);
  }

  .pricing-page__eyebrow {
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .pricing-page h1 {
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    line-height: 0.95;
    background: linear-gradient(135deg, var(--orange), var(--cream));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .pricing-page__lead {
    max-width: 60ch;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .pricing-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    align-items: start;
  }

  .pricing-page__footer {
    margin-top: 2rem;
    padding: 2rem;
    border-radius: 20px;
    background: rgba(38, 33, 29, 0.5);
    border: 1px solid rgba(251, 146, 60, 0.12);
    text-align: center;
  }

  .pricing-page__footer-text {
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .pricing-page__grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .pricing-page {
      gap: 2.5rem;
    }

    .pricing-page__hero {
      padding: 1.4rem;
      border-radius: 22px;
    }

    .pricing-page__grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .pricing-page__footer {
      padding: 1.5rem;
    }
  }
</style>
