---
const { user } = Astro.locals;
---

<section class="hero">
  <div class="hero__content">
    <p class="hero__eyebrow">Astro 6 + Firebase</p>
    <h1 class="hero__title title-gradient">Firebase Authentication</h1>
    <p class="hero__lead">
      Exemplo prático de autenticação moderna utilizando
      <strong>Firebase Authentication</strong>,
      <strong>Session Cookies</strong>,
      <strong>Middleware</strong> e
      <strong>Firebase Admin SDK</strong>.
    </p>

    <div class="hero__actions">
      {
        user ? (
          <a href="/dashboard" class="btn-primary">
            <i class="fa-solid fa-gauge-high" />
            <span>Acessar Dashboard</span>
          </a>
        ) : (
          <>
            <a href="/signin" class="btn-primary">
              <i class="fa-solid fa-right-to-bracket" />
              <span>Entrar no Sistema</span>
            </a>
            <a href="/register" class="btn-secondary">
              <span>Criar Conta</span>
            </a>
          </>
        )
      }
    </div>
  </div>

  <div class="hero__features">
    <div class="feature-card surface-card">
      <i class="fa-solid fa-cookie-bite"></i>
      <h3>SSR Auth</h3>
      <p>Validação de identidade no servidor via HttpOnly Cookies.</p>
    </div>
    <div class="feature-card surface-card">
      <i class="fa-solid fa-shield-halved"></i>
      <h3>Middleware</h3>
      <p>Proteção de rotas resiliente que barra acessos antes do render.</p>
    </div>
    <div class="feature-card surface-card">
      <i class="fa-solid fa-bolt"></i>
      <h3>Astro Actions</h3>
      <p>Comunicação tipada e segura entre o formulário e o servidor.</p>
    </div>
  </div>
</section>

<style lang="scss">
  .hero {
    display: grid;
    gap: 5rem;
    padding: 4rem 0;
    text-align: center;

    &__content {
      max-width: 800px;
      margin-inline: auto;
      display: grid;
      gap: 1.5rem;
    }

    &__eyebrow {
      color: var(--primary);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.25em;
      font-size: 0.75rem;
    }

    &__title {
      font-size: clamp(2.5rem, 8vw, 4.5rem);
      line-height: 1.1;
      margin: 0;
      letter-spacing: -0.02em;
    }

    &__lead {
      font-size: 1.15rem;
      color: var(--subtext-1);
      max-width: 55ch;
      margin-inline: auto;
      line-height: 1.6;

      strong {
        color: var(--text);
        font-weight: 600;
      }
    }

    &__actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 1.5rem;
    }

    .btn-primary,
    .btn-secondary {
      text-decoration: none;
      padding: 0.85rem 2rem;
      border-radius: 0.75rem;
      font-weight: 700;
      font-size: 0.95rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.65rem;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      border: 1px solid transparent;

      span {
        line-height: 1;
      }

      i {
        font-size: 1rem;
      }
    }

    .btn-primary {
      background-color: var(--primary);
      color: var(--crust);
      box-shadow: 0 1px 6px rgba(203, 166, 247, 0.08);

      &:hover {
        filter: brightness(1.1);
        transform: translateY(-2px);
        box-shadow: 0 3px 10px rgba(203, 166, 247, 0.12);
      }
    }

    .btn-secondary {
      background-color: var(--surface-0);
      color: var(--text);
      border-color: var(--border);

      &:hover {
        background-color: var(--surface-1);
        border-color: var(--primary);
        transform: translateY(-2px);
      }
    }

    .hero__features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      text-align: left;
    }

    .feature-card {
      display: grid;
      gap: 1rem;
      padding: 2rem;

      i {
        font-size: 1.75rem;
        color: var(--accent);
      }

      h3 {
        color: var(--text);
        font-size: 1.25rem;
        margin: 0;
      }

      p {
        color: var(--subtext-0);
        font-size: 0.95rem;
        margin: 0;
        line-height: 1.5;
      }
    }
  }

  @media (max-width: 640px) {
    .hero__actions {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
      margin-inline: auto;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
    }

    .hero {
      padding: 3rem 0;
      gap: 3rem;
    }
  }
</style>
