---
const { user } = Astro.locals;
---

<section class="hero">
  <div class="hero__content">
    <p class="hero__eyebrow">Enterprise Identity & Access Management</p>
    <h1 class="hero__title title-gradient">
      Autenticação de Segurança Avançada
    </h1>
    <p class="hero__lead">
      Infraestrutura robusta de gerenciamento de usuários implementada com
      <strong>Astro 6</strong>, <strong>Firebase Admin</strong> e proteção baseada
      em <strong>HttpOnly Session Cookies</strong>.
    </p>

    <div class="hero__actions">
      {
        user ? (
          <a href="/dashboard" class="btn-primary">
            <i class="fa-solid fa-gauge-high" />
            <span>Ir para o Painel de Controle</span>
          </a>
        ) : (
          <>
            <a href="/signin" class="btn-primary">
              <i class="fa-solid fa-shield-halved" />
              <span>Entrar no Sistema</span>
            </a>
            <a href="/register" class="btn-secondary">
              <span>Registrar Novo Acesso</span>
            </a>
          </>
        )
      }
    </div>
  </div>

  <div class="hero__features">
    <div class="feature-card surface-card">
      <i class="fa-solid fa-server"></i>
      <h3>SSR Validation</h3>
      <p>Verificação de sessão executada no lado do servidor.</p>
    </div>
    <div class="feature-card surface-card">
      <i class="fa-solid fa-lock"></i>
      <h3>HttpOnly Cookies</h3>
      <p>Tokens protegidos contra ataques de scripts (XSS).</p>
    </div>
    <div class="feature-card surface-card">
      <i class="fa-solid fa-code"></i>
      <h3>Astro Actions</h3>
      <p>Endpoints tipados que garantem a integridade dos dados.</p>
    </div>
  </div>
</section>

<style lang="scss">
  .hero {
    display: flex;
    flex-direction: column;
    gap: 5rem;
    padding: 4rem 0;
    text-align: center;
    align-items: center;

    &__content {
      max-width: 800px;
      display: grid;
      gap: 1.5rem;
    }

    &__eyebrow {
      color: var(--primary);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.25em;
      font-size: 0.75rem;
    }

    &__title {
      font-size: clamp(2.5rem, 8vw, 4.5rem);
      line-height: 1.1;
      margin: 0;
      letter-spacing: -0.02em;
    }

    &__lead {
      font-size: 1.15rem;
      color: var(--subtext-1);
      max-width: 55ch;
      margin-inline: auto;
      line-height: 1.6;

      strong {
        color: var(--text);
        font-weight: 600;
      }
    }

    &__actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 1.5rem;
    }

    .btn-primary,
    .btn-secondary {
      text-decoration: none;
      padding: 0.85rem 2rem;
      border-radius: 0.75rem;
      font-weight: 700;
      font-size: 0.95rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.65rem;
      transition: all 0.25s ease;
      border: 1px solid transparent;
      span {
        line-height: 1;
      }
    }

    .btn-primary {
      background-color: var(--primary);
      color: var(--crust);
      &:hover {
        filter: brightness(1.1);
        transform: translateY(-2px);
      }
    }

    .btn-secondary {
      background-color: var(--surface-0);
      color: var(--text);
      border-color: var(--border);
      &:hover {
        background-color: var(--surface-1);
        border-color: var(--primary);
        transform: translateY(-2px);
      }
    }

    .hero__features {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      text-align: left;
      width: 100%;
      max-width: 1100px;
    }

    .feature-card {
      display: grid;
      gap: 1rem;
      padding: 2rem;
      height: 100%;

      i {
        font-size: 1.75rem;
        color: var(--accent);
      }
      h3 {
        color: var(--text);
        font-size: 1.15rem;
        margin: 0;
      }
      p {
        color: var(--subtext-0);
        font-size: 0.875rem;
        margin: 0;
        line-height: 1.5;
      }
    }
  }

  @media (max-width: 1024px) {
    .hero__features {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .hero {
      gap: 3rem;
    }
    .hero__actions {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }
    .hero__features {
      grid-template-columns: 1fr;
    }
  }
</style>
