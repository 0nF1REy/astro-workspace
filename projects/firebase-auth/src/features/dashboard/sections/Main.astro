---
const { user } = Astro.locals;
---

<div class="dashboard">
  <header class="dashboard__header">
    <div class="dashboard__welcome">
      <p class="eyebrow">Área Restrita</p>
      <h1 class="title-gradient">Painel de Controle</h1>
      <p class="welcome-text">Bem-vindo, <strong>{user?.email}</strong></p>
    </div>
  </header>

  <div class="dashboard__grid">
    <article class="surface-card status-card">
      <div class="status-card__icon">
        <i class="fa-solid fa-user-shield"></i>
      </div>
      <div class="status-card__content">
        <h3>Sessão Segura</h3>
        <p>Sua identidade foi validada via Firebase Admin SDK.</p>
        <span class="badge">Ativa</span>
      </div>
    </article>

    <article class="surface-card info-card">
      <h3>Detalhes do Acesso</h3>
      <div class="info-list">
        <div class="info-item">
          <span>ID do Usuário</span>
          <code>{user?.uid}</code>
        </div>
        <div class="info-item">
          <span>Tipo de Token</span>
          <p>Session Cookie (HttpOnly)</p>
        </div>
      </div>
    </article>
  </div>

  <footer class="dashboard__actions">
    <button id="logout-btn" class="btn-logout">
      <i class="fa-solid fa-right-from-bracket"></i>
      Encerrar Sessão
    </button>
  </footer>
</div>

<script>
  import { actions } from "astro:actions";

  const logoutBtn = document.getElementById("logout-btn");

  logoutBtn?.addEventListener("click", async () => {
    const { error } = await actions.signOut();
    if (!error) {
      window.location.href = "/signin";
    } else {
      console.error("Falha ao encerrar sessão:", error);
    }
  });
</script>

<style lang="scss">
  .dashboard {
    display: grid;
    gap: 2.5rem;
    padding: 2rem 0;

    &__header {
      .eyebrow {
        color: var(--primary);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
      }
      h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      .welcome-text {
        color: var(--subtext-0);
        strong {
          color: var(--text);
        }
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }

    .status-card {
      display: flex;
      gap: 1.5rem;
      align-items: center;

      &__icon {
        width: 3.5rem;
        height: 3.5rem;
        background: rgba(203, 166, 247, 0.1);
        color: var(--primary);
        border-radius: 0.75rem;
        display: grid;
        place-items: center;
        font-size: 1.5rem;
      }

      h3 {
        margin-bottom: 0.25rem;
      }
      p {
        font-size: 0.9rem;
        color: var(--subtext-0);
        margin-bottom: 0.75rem;
      }

      .badge {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        padding: 0.2rem 0.6rem;
        background: var(--green);
        color: var(--crust);
        border-radius: 4px;
      }
    }

    .info-card {
      h3 {
        margin-bottom: 1.5rem;
      }

      .info-list {
        display: grid;
        gap: 1rem;
      }

      .info-item {
        display: grid;
        gap: 0.25rem;
        span {
          font-size: 0.75rem;
          color: var(--subtext-1);
          font-weight: 600;
        }
        code {
          font-family: monospace;
          background: var(--base);
          padding: 0.4rem;
          border-radius: 4px;
          font-size: 0.85rem;
          word-break: break-all;
        }
        p {
          font-size: 0.95rem;
        }
      }
    }

    .btn-logout {
      width: fit-content;
      margin-inline: auto;
      padding: 0.75rem 2rem;
      background-color: transparent;
      color: var(--red);
      border: 1px solid var(--red);
      border-radius: 0.75rem;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      transition: all 0.2s;

      &:hover {
        background-color: var(--red);
        color: var(--crust);
        transform: translateY(-2px);
      }
    }
  }
</style>
