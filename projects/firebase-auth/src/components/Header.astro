<header class="site-header">
  <div class="site-shell">
    <div class="site-header__inner">
      <a href="/" class="site-header__title">Firebase Auth</a>
      <nav class="site-header__nav">
        {
          Astro.locals.user ? (
            <>
              <a href="/dashboard" class="site-header__nav-link">
                Dashboard
              </a>
              <button
                id="logout-trigger"
                class="site-header__nav-link site-header__logout-btn"
              >
                Sair
              </button>
            </>
          ) : (
            <>
              <a href="/signin" class="site-header__nav-link">
                Login
              </a>
              <a href="/register" class="site-header__nav-link">
                Cadastro
              </a>
            </>
          )
        }
      </nav>
    </div>
  </div>
</header>

<script>
  import { actions } from "astro:actions";

  const logoutBtn = document.getElementById("logout-trigger");

  logoutBtn?.addEventListener("click", async () => {
    const { error } = await actions.signOut();
    if (!error) {
      window.location.href = "/signin";
    } else {
      console.error("Erro ao encerrar sessão:", error);
    }
  });
</script>

