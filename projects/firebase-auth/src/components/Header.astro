---
const { user } = Astro.locals;
---

<header class="site-header">
  <div class="site-shell">
    <div class="site-header__inner">
      <a href="/" class="site-header__title">
        <i class="fa-solid fa-shield-halved"></i>
        <span>Firebase Auth</span>
      </a>
      <nav class="site-header__nav">
        {
          user && (
            <button
              id="logout-trigger"
              class="site-header__nav-link site-header__logout-btn"
            >
              <i class="fa-solid fa-right-from-bracket" />
              <span>Sair</span>
            </button>
          )
        }
      </nav>
    </div>
  </div>
</header>

<script>
  import { actions } from "astro:actions";

  const logoutBtn = document.getElementById("logout-trigger");

  logoutBtn?.addEventListener("click", async () => {
    const { error } = await actions.signOut();
    if (!error) {
      window.location.href = "/signin";
    } else {
      console.error("Erro ao encerrar sessão:", error);
    }
  });
</script>

<style lang="scss">
  .site-header {
    background: var(--mantle);
    border-bottom: 1px solid var(--surface-2);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 4.5rem;
      gap: 1rem;
    }

    &__title {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      color: var(--text);
      font-size: 1.125rem;
      font-weight: 700;
      text-decoration: none;
      letter-spacing: -0.025em;
      transition: color 0.2s ease;

      i {
        color: var(--mauve);
        font-size: 1.25rem;
        display: flex;
        align-items: center;
      }

      &:hover {
        color: var(--mauve);
      }
    }

    &__nav {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    &__nav-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      color: var(--subtext-0);
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 500;
      padding: 0.625rem 1rem;
      border-radius: 0.75rem;
      border: none;
      background: transparent;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s ease;

      i {
        font-size: 0.95rem;
        opacity: 0.8;
        display: flex;
        align-items: center;
        line-height: 1;
      }

      span {
        line-height: 1;
      }

      &:hover {
        background: var(--surface-0);
        color: var(--text);
        transform: translateY(-1px);

        i {
          opacity: 1;
        }
      }

      &:active {
        transform: translateY(0);
      }
    }

    &__logout-btn {
      &:hover {
        color: var(--red);
        background: rgba(243, 139, 168, 0.1);
      }
    }
  }

  @media (max-width: 640px) {
    .site-header__nav-link span {
      display: none;
    }
    .site-header__nav-link {
      padding: 0.75rem;
      i {
        font-size: 1.1rem;
      }
    }
  }
</style>
