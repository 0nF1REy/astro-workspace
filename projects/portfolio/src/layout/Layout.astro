---
import SpeedInsights from "@vercel/speed-insights/astro";
// @ts-ignore
import "@fontsource/poppins";
import "@fortawesome/fontawesome-free/css/fontawesome.min.css";
import "@fortawesome/fontawesome-free/css/brands.min.css";
import "@fortawesome/fontawesome-free/css/solid.min.css";
import "../styles/global.css";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alan Ryan | Desenvolvimento de Sistemas e Soluções Web",
  description = "Portfólio profissional de Alan Ryan da Silva Domingues — criação e desenvolvimento de soluções digitais sob medida, com foco em performance e tecnologia web",
} = Astro.props;

const isHomePage = Astro.url.pathname === "/";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="pt-BR">
  <head>
    <title>{title}</title>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/brand-kit/favicon/favicon.png" />
    <link rel="apple-touch-icon" href="/brand-kit/favicon/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <meta
      name="google-site-verification"
      content="TlXMudbKhw88D-cKvOqZIYsuBvy2Mr-kzBlOL5DQ-k4"
    />

    <link rel="canonical" href={canonicalURL} />
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/favicon.png", Astro.url)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta
      property="twitter:image"
      content={new URL("/favicon.png", Astro.url)}
    />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Alan Ryan da Silva Domingues",
        "url": "https://alan-ryan.vercel.app",
        "jobTitle": "Desenvolvedor Full Stack",
        "sameAs": [
          "https://github.com/0nF1REy",
          "https://www.linkedin.com/in/alan-ryan-b115ba228/"
        ],
        "description": "Desenvolvedor de sistemas focado em criar soluções que unem performance técnica e usabilidade."
      }
    </script>

    <ClientRouter />
  </head>
  <body>
    <canvas id="bg-canvas"></canvas>

    <Header
      client:load
      showNav={isHomePage}
      backHref="/"
      backLabel="Voltar para a home"
    />
    <main>
      <slot />
    </main>
    <Footer />

    <SpeedInsights />

    <style is:global>
      #bg-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        z-index: -1;
        background: #050505;
        pointer-events: none;
      }

      section {
        position: relative;
        background: transparent !important;
      }
    </style>

    <script>
      import {
        destroyLayoutParticles,
        initLayoutParticles,
      } from "./layout-particles";

      document.addEventListener("astro:page-load", initLayoutParticles);
      document.addEventListener("astro:before-swap", destroyLayoutParticles);
    </script>
  </body>
</html>
