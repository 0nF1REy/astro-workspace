---
const email = "alanryan619@gmail.com";

const socials = [
  {
    href: "https://www.linkedin.com/in/alan-ryan-b115ba228/",
    label: "LinkedIn",
    icon: "fa-linkedin",
  },
  {
    href: "https://gitlab.com/alanryan619",
    label: "GitLab",
    icon: "fa-gitlab",
  },
  { href: "https://github.com/0nF1REy", label: "GitHub", icon: "fa-github" },
];
---

<footer id="contact">
  <div class="content-wrapper">
    <div class="contact__content">
      <div class="title">
        <h3>Entre em Contato Comigo</h3>
        <a class="mail" href={`mailto:${email}`} target="_blank">
          <i class="fa-solid fa-envelope"></i>
          <span>{email}</span>
        </a>
      </div>

      <div class="address-info">
        <img
          src="/brand-kit/logo/sm-logo.png"
          alt="isotipo"
          class="logo-footer-sm"
        />

        <img
          src="/brand-kit/logo/md-logo.png"
          alt="Alan Ryan"
          class="logo-footer-md"
        />

        <div class="contact-details">
          <a class="phone" href="tel:+5515996209364">+55 15 99620-9364</a>

          <ul class="social-links" role="list">
            {
              socials.map((s) => (
                <li>
                  <a
                    href={s.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={s.label}
                  >
                    <i class={`fa-brands ${s.icon}`} aria-hidden="true" />
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <p class="copyright">
      &copy; {new Date().getFullYear()} Alan Ryan da Silva Domingues. Todos os direitos
      reservados.
    </p>
  </div>
</footer>

<style>
  footer {
    position: relative;
    padding-top: 6rem;
    background: linear-gradient(10deg, #152037 0%, #0b2666 50%, #1e71b7 100%);
  }

  footer::before {
    content: "";
    position: absolute;
    top: -2rem;
    left: 0;
    width: 100%;
    height: 2rem;
    background: linear-gradient(
      190deg,
      #ff4d6d 0%,
      #ff7a59 8%,
      #ffb347 16%,
      #ffe066 24%,
      #8ac926 32%,
      #2ec4b6 40%,
      #00bbf9 48%,
      #3a86ff 56%,
      #4361ee 64%,
      #8338ec 72%,
      #ff006e 80%,
      #ff4d6d 88%,
      #1e71b7 100%
    );
    pointer-events: none;
  }

  .contact__content {
    padding-bottom: 0.75rem;
  }

  .title {
    margin-bottom: 3rem;
    text-align: center;
  }

  h3 {
    font-size: 1.3rem;
    margin: 0 0 0.75rem;
    color: #fff;
    font-weight: 700;
  }

  .mail {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent-clr-400);
    text-decoration: none;
    transition: filter 0.3s ease;
  }

  .mail:hover {
    filter: brightness(1.2);
  }

  .mail span {
    text-decoration: underline;
  }

  .logo-footer-sm {
    height: 80px;
    width: auto;
    filter: drop-shadow(0 0 10px rgba(30, 113, 183, 0.1));
  }

  .logo-footer-md {
    height: 80px;
    width: auto;
    filter: drop-shadow(0 0 10px rgba(30, 113, 183, 0.1));
  }

  .address-info {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .phone {
    color: var(--secondary-clr-100);
    font-size: 1.05rem;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .phone:hover {
    color: var(--accent-clr-400);
  }

  .social-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.5rem;
  }

  .social-links a {
    font-size: 1.7rem;
    color: var(--secondary-clr-100);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      color 0.3s ease;
  }

  .social-links a:hover {
    color: var(--accent-clr-400);
    transform: translateY(-5px);
  }

  .copyright {
    padding: 4rem 0 2.5rem;
    text-align: center;
    color: var(--secondary-clr-300);
    font-size: 0.9rem;
    letter-spacing: 0.5px;
  }

  @media (width >= 768px) {
    .title {
      text-align: left;
    }

    .address-info {
      flex-direction: row;
      justify-content: space-between;
    }

    .contact-details {
      align-items: flex-end;
    }

    .logo-footer-md {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>
