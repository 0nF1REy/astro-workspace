---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layout/Layout.astro";
import { Image } from "astro:assets";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project: CollectionEntry<"projects">) => ({
    params: { id: project.id },
    props: {
      project,
      otherProjects: projects.filter(
        (item: CollectionEntry<"projects">) => item.id !== project.id,
      ),
    },
  }));
}

const { project, otherProjects } = Astro.props as {
  project: CollectionEntry<"projects">;
  otherProjects: CollectionEntry<"projects">[];
};

type ProjectData = CollectionEntry<"projects">["data"] & {
  mainImageRemote?: string;
  videoUrl?: string;
  videoFallback?: string;
  liveProjectUrl?: string;
  repositoryUrl?: string;
};

const {
  title,
  mainImage,
  mainImageRemote,
  otherImages = [],
  storyTitle,
  storyContent,
  videoUrl,
  videoFallback,
  liveProjectUrl,
  repositoryUrl,
} = project.data as ProjectData;

const relatedProjects = otherProjects.slice(0, 3);

const initialImage = mainImageRemote || mainImage.src;
const isHttpUrl = (value?: string) =>
  Boolean(value && /^https?:\/\//.test(value));

const liveProjectHref = isHttpUrl(liveProjectUrl) ? liveProjectUrl : undefined;
const repositoryHref = isHttpUrl(repositoryUrl) ? repositoryUrl : undefined;
const previewVideoSrc = videoFallback || videoUrl || "";
const hasPreviewVideo = previewVideoSrc.length > 0;
const hasFullVideo = Boolean(videoUrl);
---

<Layout {title}>
  <section class="project-detail pt-section">
    <div class="content-wrapper">
      <header class="project-detail__header">
        <h1>{title}</h1>

        <div class="project-detail__actions" aria-label="Links do projeto">
          {
            liveProjectHref && (
              <a
                class="project-action project-action--primary"
                href={liveProjectHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                <i class="fa-solid fa-arrow-up-right-from-square" />
                Ver projeto no ar
              </a>
            )
          }

          {
            repositoryHref && (
              <a
                class="project-action project-action--secondary"
                href={repositoryHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                <i class="fa-brands fa-github" />
                Ver repositório
              </a>
            )
          }

          <a
            class="project-action project-action--ghost"
            href="#project-anchor"
          >
            <i class="fa-solid fa-book-open"></i>
            Ler conteúdo
          </a>
        </div>
      </header>

      <div class="project-detail__media-grid">
        <div
          class="project-detail__media-panel project-detail__media-panel--image"
        >
          <a name="project-anchor"></a>
          <img
            src={initialImage}
            alt={title}
            class="project-detail__main-image"
            loading="eager"
            onerror={`this.onerror=null;this.src='${mainImage.src}';`}
          />
        </div>

        {
          hasPreviewVideo && (
            <div class="project-detail__media-panel project-detail__media-panel--video">
              <div class="video-container">
                <video
                  data-role="project-video"
                  muted
                  loop
                  autoplay
                  playsinline
                  poster={initialImage}
                  preload="metadata"
                  class="video-element"
                >
                  <source src={previewVideoSrc} type="video/mp4" />
                </video>

                {hasFullVideo && (
                  <div class="video-controls-overlay">
                    <button
                      class="btn-play"
                      data-role="load-full-video"
                      data-full-url={videoUrl}
                    >
                      <i class="fa-solid fa-play" />
                      Assistir Vídeo Completo
                    </button>
                  </div>
                )}
              </div>
            </div>
          )
        }
      </div>

      <div class="project-detail__section-divider"></div>

      <div class="project-detail__story" id="project-story">
        <h3>{storyTitle}</h3>
        <p>{storyContent}</p>
      </div>

      {
        otherImages.length > 0 && (
          <div class="project-detail__gallery">
            {otherImages.map((image: any) => (
              <Image
                src={image}
                alt={title}
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
                class="project-detail__gallery-image"
                loading="lazy"
              />
            ))}
          </div>
        )
      }

      {
        relatedProjects.length > 0 && (
          <div class="project-detail__related pb-section">
            <h2>Outros projetos</h2>

            <div class="project-detail__related-grid">
              {relatedProjects.map((item: CollectionEntry<"projects">) => (
                <a
                  class="project-detail__related-card"
                  href={`/project/${item.id}`}
                >
                  <Image
                    src={item.data.mainImage}
                    alt={item.data.title}
                    widths={[400, 800]}
                    sizes="(max-width: 768px) 100vw, 33vw"
                    loading="lazy"
                  />
                  <h3>{item.data.title}</h3>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>
</Layout>

<script>
  type NavigatorWithConnection = Navigator & {
    connection?: {
      saveData?: boolean;
    };
  };

  const playBtn = document.querySelector<HTMLButtonElement>(
    '[data-role="load-full-video"]',
  );
  const videoPlayer = document.querySelector<HTMLVideoElement>(
    '[data-role="project-video"]',
  );
  const videoSource = videoPlayer?.querySelector<HTMLSourceElement>("source");

  if (videoPlayer) {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const saveData = (navigator as NavigatorWithConnection).connection
      ?.saveData;

    if (prefersReducedMotion || saveData) {
      videoPlayer.autoplay = false;
      videoPlayer.loop = false;
      videoPlayer.controls = true;
      videoPlayer.pause();
    }
  }

  if (playBtn && videoPlayer && videoSource) {
    playBtn.addEventListener("click", () => {
      const fullUrl = playBtn.dataset.fullUrl;
      if (!fullUrl) {
        return;
      }

      videoSource.src = fullUrl;
      videoPlayer.controls = true;
      videoPlayer.loop = false;
      videoPlayer.muted = false;
      videoPlayer.load();
      void videoPlayer.play();

      const overlay = playBtn.closest(".video-controls-overlay");
      if (overlay instanceof HTMLElement) {
        overlay.style.display = "none";
      }
    });
  }
</script>

<style>
  .pb-section {
    padding-bottom: 5rem;
  }

  .project-detail {
    padding-bottom: clamp(1.25rem, 3vw, 2.5rem);
  }

  .project-detail__header {
    padding-top: clamp(1rem, 2vw, 1.5rem);
    padding-bottom: 0;
    margin-bottom: 0;
    border-bottom: 0;
  }

  .project-detail__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
  }

  .project-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 2.75rem;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    line-height: 1;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .project-action:hover {
    transform: translateY(-2px);
  }

  .project-action:focus-visible {
    outline: 2px solid var(--primary-clr-400);
    outline-offset: 2px;
  }

  .project-action--primary {
    background: var(--primary-clr-400);
    color: #fff;
  }

  .project-action--primary:hover {
    background: var(--accent-clr-400);
  }

  .project-action--secondary {
    border: 1px solid var(--secondary-clr-400);
    color: var(--secondary-clr-100);
    background: rgba(17, 24, 39, 0.4);
  }

  .project-action--secondary:hover {
    border-color: var(--primary-clr-400);
    color: #fff;
  }

  .project-action--ghost {
    border: 1px solid transparent;
    color: var(--secondary-clr-200);
    background: transparent;
  }

  .project-action--ghost:hover {
    color: var(--secondary-clr-100);
    border-color: var(--secondary-clr-400);
    background: rgba(17, 24, 39, 0.3);
  }

  .project-detail h1 {
    text-align: left;
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.2;
  }

  .project-detail :global(img) {
    border-radius: 0.9rem;
    width: 100%;
    height: auto;
  }

  .project-detail__media-grid {
    display: grid;
    gap: 1.25rem;
    align-items: stretch;
    margin-bottom: clamp(1rem, 2.5vw, 1.75rem);
  }

  .project-detail__media-panel {
    min-width: 0;
  }

  .project-detail__media-panel--video {
    padding-top: 1.25rem;
    border-top: 1px solid var(--secondary-clr-400);
  }

  .project-detail__main-image {
    display: block;
    width: 100%;
    max-height: clamp(260px, 58vh, 560px);
    aspect-ratio: 16 / 9;
    object-fit: cover;
    margin: 0;
  }

  .project-detail__section-divider {
    width: 100%;
    height: 1px;
    background: var(--secondary-clr-400);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .project-detail__story {
    width: 100%;
    margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
    scroll-margin-top: clamp(1rem, 3vw, 2rem);
  }

  .project-detail__story h3 {
    margin-bottom: 0.9rem;
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
    line-height: 1.25;
  }

  .project-detail__story p {
    color: var(--secondary-clr-200);
    line-height: 1.8;
    font-size: clamp(1rem, 1.2vw, 1.05rem);
  }

  .project-detail__gallery {
    display: grid;
    gap: 1rem;
    max-width: min(100%, 900px);
    margin-inline: auto;
    margin-bottom: 0;
  }

  .project-detail__gallery-image {
    aspect-ratio: 16 / 9;
    max-height: clamp(180px, 30vw, 300px);
    object-fit: cover;
  }

  .project-detail__related {
    margin-top: clamp(2rem, 5vw, 3.5rem);
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
    border-top: 1px solid var(--secondary-clr-400);
  }

  .project-detail__related h2 {
    text-align: left;
    margin-bottom: clamp(1rem, 2.5vw, 1.8rem);
    font-size: clamp(1.4rem, 3vw, 2rem);
  }

  .project-detail__related-grid {
    display: grid;
    gap: 1rem;
  }

  .project-detail__related-card {
    display: block;
    color: var(--secondary-clr-100);
  }

  .project-detail__related-card h3 {
    margin-top: 0.75rem;
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    line-height: 1.35;
    transition: color 0.25s ease-in-out;
  }

  .project-detail__related-card:hover h3 {
    color: var(--primary-clr-400);
  }

  .project-detail__related-card :global(img) {
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .video-container {
    position: relative;
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
    background: #000;
  }

  .video-element {
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .video-controls-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    transition: opacity 0.3s;
  }

  .btn-play {
    background: var(--primary-clr-400);
    color: #fff;
    border: none;
    padding: 1rem 2rem;
    border-radius: 5rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  .btn-play:hover {
    background: var(--accent-clr-400);
    transform: scale(1.05);
  }

  @media (width >= 768px) {
    .project-detail__media-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 1.5rem;
    }

    .project-detail__media-panel--video {
      padding-top: 0;
      border-top: 0;
      padding-left: 1.5rem;
      border-left: 1px solid var(--secondary-clr-400);
    }

    .project-detail__section-divider {
      margin-bottom: clamp(2.25rem, 4vw, 3.25rem);
    }

    .project-detail__gallery {
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(1rem, 2vw, 1.5rem);
    }

    .project-detail__related-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(1rem, 2vw, 1.5rem);
    }
  }
</style>
