---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "@layout/Layout.astro";
import { Image } from "astro:assets";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project: CollectionEntry<"projects">) => ({
    params: { id: project.id },
    props: {
      project,
      otherProjects: projects.filter(
        (item: CollectionEntry<"projects">) => item.id !== project.id,
      ),
    },
  }));
}

const { project, otherProjects } = Astro.props as {
  project: CollectionEntry<"projects">;
  otherProjects: CollectionEntry<"projects">[];
};

type ProjectData = CollectionEntry<"projects">["data"] & {
  mainImageRemote?: string;
  videoUrl?: string;
  videoPreview?: string;
  videoPreviewRemote?: string;
  liveProjectUrl?: string;
  repositoryUrl?: string;
};

const {
  title,
  mainImage,
  mainImageRemote,
  otherImages = [],
  storyTitle,
  storyContent,
  videoUrl,
  videoPreview,
  videoPreviewRemote,
  liveProjectUrl,
  repositoryUrl,
} = project.data as ProjectData;

const relatedProjects = otherProjects.slice(0, 3);

const isHttpUrl = (value?: string) =>
  Boolean(value && /^https?:\/\//.test(value));

const initialPoster = mainImageRemote || mainImage.src;
const previewPrimary = videoPreviewRemote || videoPreview || "";
const previewFallback =
  previewPrimary === videoPreviewRemote ? videoPreview : videoPreviewRemote;

const liveProjectHref = isHttpUrl(liveProjectUrl) ? liveProjectUrl : undefined;
const repositoryHref = isHttpUrl(repositoryUrl) ? repositoryUrl : undefined;
const hasPreviewVideo = Boolean(previewPrimary);
const hasFullVideo = Boolean(videoUrl);
---

<Layout {title}>
  <section class="project-detail pt-section">
    <div class="content-wrapper">
      <header class="project-detail__header">
        <h1>{title}</h1>

        <div class="project-detail__actions" aria-label="Links do projeto">
          {
            liveProjectHref && (
              <a
                class="project-action project-action--primary"
                href={liveProjectHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                <i class="fa-solid fa-arrow-up-right-from-square" />
                Ver projeto no ar
              </a>
            )
          }

          {
            repositoryHref && (
              <a
                class="project-action project-action--secondary"
                href={repositoryHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                <i class="fa-brands fa-github" />
                Ver repositório
              </a>
            )
          }

          <a
            class="project-action project-action--ghost"
            href="#project-anchor"
          >
            <i class="fa-solid fa-book-open"></i>
            Ler conteúdo
          </a>
        </div>
      </header>

      <div
        class="project-detail__media-divider project-detail__media-divider--top"
      >
      </div>

      <div class="project-detail__media-grid">
        <div
          class="project-detail__media-panel project-detail__media-panel--image"
        >
          <a name="project-anchor" class="project-anchor-target"></a>
          <img
            src={initialPoster}
            alt={title}
            class="project-detail__main-image"
            loading="eager"
            crossorigin="anonymous"
            data-fallback-src={mainImage.src}
          />
        </div>

        {
          hasPreviewVideo && (
            <div class="project-detail__media-panel project-detail__media-panel--video">
              <div class="video-container">
                <video
                  data-role="project-video"
                  data-preview-fallback-src={previewFallback || ""}
                  muted
                  loop
                  autoplay
                  playsinline
                  poster={initialPoster}
                  preload="metadata"
                  class="video-element"
                  crossorigin="anonymous"
                >
                  <source src={previewPrimary} type="video/mp4" />
                </video>

                {hasFullVideo && (
                  <div class="video-overlay">
                    <button
                      class="btn-play"
                      data-role="load-full-video"
                      data-full-url={videoUrl}
                    >
                      <i class="fa-solid fa-play" />
                      Assistir Demonstração Completa
                    </button>
                  </div>
                )}
              </div>
            </div>
          )
        }
      </div>

      <div
        class="project-detail__media-divider project-detail__media-divider--bottom"
      >
      </div>

      <div class="project-detail__story" id="project-story">
        <h3>{storyTitle}</h3>
        <p>{storyContent}</p>
      </div>

      {
        otherImages.length > 0 && (
          <div class="project-detail__gallery">
            {otherImages.map((image: any) => (
              <Image
                src={image}
                alt={title}
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
                class="project-detail__gallery-image"
                loading="lazy"
              />
            ))}
          </div>
        )
      }

      {
        relatedProjects.length > 0 && (
          <div class="project-detail__related pb-section">
            <h2>Outros projetos</h2>

            <div class="project-detail__related-grid">
              {relatedProjects.map((item: CollectionEntry<"projects">) => (
                <a
                  class="project-detail__related-card"
                  href={`/project/${item.id}`}
                >
                  <Image
                    src={item.data.mainImage}
                    alt={item.data.title}
                    widths={[400, 800]}
                    sizes="(max-width: 768px) 100vw, 33vw"
                    loading="lazy"
                  />
                  <h3>{item.data.title}</h3>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>
</Layout>

<script>
  type NavigatorWithConnection = Navigator & {
    connection?: {
      saveData?: boolean;
    };
  };

  const playBtn = document.querySelector<HTMLButtonElement>(
    '[data-role="load-full-video"]',
  );
  const videoPlayer = document.querySelector<HTMLVideoElement>(
    '[data-role="project-video"]',
  );

  if (videoPlayer) {
    videoPlayer.addEventListener("error", () => {
      const fallback = videoPlayer.dataset.previewFallbackSrc;
      const fallbackAlreadyApplied =
        videoPlayer.dataset.previewFallbackApplied === "1";

      if (
        fallback &&
        !fallbackAlreadyApplied &&
        videoPlayer.dataset.state !== "full"
      ) {
        videoPlayer.dataset.previewFallbackApplied = "1";
        videoPlayer.src = fallback;
        videoPlayer.load();
        void videoPlayer.play();
      }
    });

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const saveData = (navigator as NavigatorWithConnection).connection
      ?.saveData;

    if (prefersReducedMotion || saveData) {
      videoPlayer.autoplay = false;
      videoPlayer.loop = false;
      videoPlayer.controls = true;
      videoPlayer.pause();
    }
  }

  if (playBtn && videoPlayer) {
    playBtn.addEventListener("click", () => {
      const fullUrl = playBtn.dataset.fullUrl;
      if (fullUrl) {
        videoPlayer.dataset.state = "full";
        videoPlayer.src = fullUrl;
        videoPlayer.loop = false;
        videoPlayer.muted = false;
        videoPlayer.controls = true;
        videoPlayer.load();
        void videoPlayer.play();

        const overlay = playBtn.closest(".video-overlay");
        if (overlay instanceof HTMLElement) {
          overlay.style.opacity = "0";
          overlay.style.pointerEvents = "none";
        }
      }
    });
  }
</script>

<style>
  .pb-section {
    padding-bottom: 5rem;
  }

  .project-detail {
    padding-bottom: clamp(1.25rem, 3vw, 2.5rem);
  }

  .project-detail__header {
    padding-top: clamp(1rem, 2vw, 1.5rem);
  }

  .project-detail__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
  }

  .project-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 2.75rem;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.2s ease;
  }

  .project-action:hover {
    transform: translateY(-2px);
  }

  .project-action--primary {
    background: var(--primary-clr-400);
    color: #fff;
  }

  .project-action--primary:hover {
    background: var(--accent-clr-400);
  }

  .project-action--secondary {
    border: 1px solid var(--secondary-clr-400);
    color: var(--secondary-clr-100);
    background: rgba(17, 24, 39, 0.4);
  }

  .project-action--secondary:hover {
    border-color: var(--primary-clr-400);
  }

  .project-action--ghost {
    color: var(--secondary-clr-200);
  }

  .project-action--ghost:hover {
    color: var(--secondary-clr-100);
    background: rgba(17, 24, 39, 0.3);
  }

  .project-anchor-target {
    display: block;
    width: 0;
    height: 0;
    margin: 0;
    padding: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .project-detail__media-grid {
    display: grid;
    gap: 1.25rem;
    align-items: stretch;
    position: relative;
    margin-top: 2rem;
    margin-bottom: clamp(1rem, 2.5vw, 1.75rem);
  }

  .project-detail__media-divider {
    width: 100%;
    height: 1px;
    background: var(--secondary-clr-400);
  }

  .project-detail__media-divider--top {
    margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
  }

  .project-detail__media-divider--bottom {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .project-detail__media-panel {
    min-width: 0;
  }

  .project-detail__media-panel--video {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .project-detail__media-panel--image {
    padding-top: 0;
    border-top: 0;
  }

  .project-detail__main-image {
    width: 100%;
    max-height: clamp(260px, 58vh, 560px);
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    border-radius: 1rem;
  }

  .video-container {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
  }

  .video-element {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.5s ease;
    z-index: 2;
  }

  .btn-play {
    background: var(--primary-clr-400);
    color: white;
    border: none;
    padding: 1.2rem 2.5rem;
    border-radius: 5rem;
    font-weight: 800;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease;
  }

  .btn-play:hover {
    transform: scale(1.08);
    background: var(--accent-clr-400);
  }

  .project-detail h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.2;
    margin: 0;
  }

  .project-detail__story {
    width: 100%;
    max-width: none;
    margin: 0 0 4rem;
    scroll-margin-top: 100px;
  }

  .project-detail__story h3 {
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .project-detail__story p {
    color: var(--secondary-clr-200);
    line-height: 1.8;
    font-size: 1.1rem;
    text-align: justify;
    text-justify: inter-word;
    hyphens: auto;
  }

  .project-detail__gallery {
    display: grid;
    gap: 1rem;
    margin-bottom: 5rem;
  }

  .project-detail__related-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }

  @media (width >= 768px) {
    .project-detail__media-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 1.5rem;
    }

    .project-detail__media-panel--video {
      padding-bottom: 0;
      border-bottom: 0;
      padding-left: 0.75rem;
      border-left: 0;
    }

    .project-detail__media-panel--image {
      padding-top: 0;
      border-top: 0;
      padding-right: 0.75rem;
      border-right: 0;
    }

    .project-detail__media-grid::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 1px;
      transform: translateX(-50%);
      background: var(--secondary-clr-400);
      pointer-events: none;
    }

    .project-detail__gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
