---
import ErrorPage from "../components/ErrorPage.astro";

interface Props {
  error: unknown;
}

const { error } = Astro.props as Props;
const safeDetails =
  import.meta.env.DEV && error instanceof Error
    ? error.message
    : "Tente novamente em alguns instantes.";
---

<ErrorPage
  code="Erro 500"
  heading="Algo deu errado!"
  message={safeDetails}
  description="Ocorreu um erro inesperado ao processar sua solicitação."
  pageTitle="500 | Erro interno"
/>
