---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "@layout/Layout.astro";
import Section from "@components/Section.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { id: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, tags, heroImage } = post.data;

type SimilarPost = {
  entry: CollectionEntry<"blog">;
  sharedTags: string[];
  score: number;
};

const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const rankedPosts: SimilarPost[] = allPosts
  .filter((entry) => entry.id !== post.id)
  .map((entry) => {
    const sharedTags = entry.data.tags.filter((tag: string) =>
      tags.includes(tag),
    );
    return {
      entry,
      sharedTags,
      score: sharedTags.length,
    };
  })
  .sort(
    (a, b) =>
      b.score - a.score ||
      b.entry.data.date.getTime() - a.entry.data.date.getTime(),
  );
const similarPosts: SimilarPost[] = rankedPosts.slice(0, 3);
---

<Layout title={title}>
  <div class="reading-progress" aria-hidden="true"></div>

  <Section id="blog-content">
    <article class="post-container">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={date.toISOString()} class="post-date">
            {
              date.toLocaleDateString("pt-BR", {
                day: "2-digit",
                month: "long",
                year: "numeric",
                timeZone: "UTC",
              })
            }
          </time>
          <span class="post-author">por Alan Ryan da Silva Domingues</span>
        </div>

        <h1>{title}</h1>

        <div class="tags">
          {tags.map((tag: string) => <span>#{tag}</span>)}
        </div>
      </header>

      {
        heroImage && (
          <Image
            src={heroImage}
            alt={title}
            class="main-banner"
            width={1200}
            height={600}
            loading="eager"
          />
        )
      }

      <div class="mdx-content">
        <Content />
      </div>

      <footer class="post-footer">
        <p class="post-footer-text">
          Curtiu este conteúdo? Continue explorando mais textos e projetos.
        </p>
        <div class="post-actions">
          <a href="/blog" class="post-action">Ver mais artigos</a>
          <a href="/" class="post-action post-action-secondary"
            >Ir para a home</a
          >
        </div>

        {
          similarPosts.length > 0 && (
            <section class="related-posts" aria-label="Outros artigos">
              <h2>Outros artigos</h2>
              <div class="related-posts-grid">
                {similarPosts.map((item) => (
                  <a href={`/blog/${item.entry.id}`} class="related-post-card">
                    <p class="related-post-date">
                      {item.entry.data.date.toLocaleDateString("pt-BR", {
                        day: "2-digit",
                        month: "short",
                        year: "numeric",
                      })}
                    </p>
                    <h3>{item.entry.data.title}</h3>
                    <p class="related-post-link">Ler artigo</p>

                    {item.sharedTags.length > 0 && (
                      <div class="related-post-tags">
                        {item.sharedTags.slice(0, 3).map((tag: string) => (
                          <span>#{tag}</span>
                        ))}
                      </div>
                    )}
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </footer>
    </article>
  </Section>
</Layout>

<script is:inline>
  const updateReadingProgress = () => {
    const scrollTop = window.scrollY;
    const documentHeight =
      document.documentElement.scrollHeight - window.innerHeight;
    const progress =
      documentHeight > 0 ? (scrollTop / documentHeight) * 100 : 0;

    document.documentElement.style.setProperty(
      "--reading-progress",
      `${Math.min(100, Math.max(0, progress))}%`,
    );
  };

  updateReadingProgress();
  window.addEventListener("scroll", updateReadingProgress, { passive: true });
</script>

<style>
  :global(html) {
    --reading-progress: 0%;
  }

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--reading-progress);
    height: 4px;
    background: linear-gradient(
      90deg,
      var(--primary-clr-400) 0%,
      var(--accent-clr-400) 100%
    );
    z-index: 80;
    box-shadow: 0 0 16px rgba(30, 113, 183, 0.45);
    transition: width 120ms linear;
  }

  .post-container {
    max-width: 850px;
    margin: 0 auto;
    position: relative;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--secondary-clr-400);
    position: relative;
  }

  .post-header::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    width: min(180px, 40%);
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--primary-clr-400) 0%,
      var(--accent-clr-400) 100%
    );
  }

  .post-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .post-date {
    color: var(--accent-clr-400);
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .post-author {
    color: var(--secondary-clr-300);
    font-size: 1rem;
    font-weight: 500;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    text-align: left;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: #fff;
  }

  .tags {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .tags span {
    color: var(--primary-clr-400);
    font-weight: 600;
    font-size: 0.82rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--secondary-clr-400);
    background: rgba(30, 113, 183, 0.08);
  }

  .main-banner {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    margin-bottom: 4rem;
    border: 1px solid var(--secondary-clr-400);
    object-fit: cover;
  }

  .mdx-content {
    color: var(--secondary-clr-100);
    line-height: 1.8;
    font-size: 1.15rem;
  }

  .mdx-content :global(p:first-of-type)::first-letter {
    font-size: 3.2rem;
    line-height: 0.95;
    float: left;
    margin: 0.2rem 0.5rem 0 0;
    color: var(--accent-clr-400);
    font-weight: 700;
  }

  .mdx-content :global(h2) {
    color: #fff;
    margin: 3rem 0 1.5rem;
    text-align: left;
  }

  .mdx-content :global(.article-toc) {
    margin: 1.25rem 0 2.2rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--secondary-clr-400);
    border-radius: 0.8rem;
    background: rgba(30, 113, 183, 0.06);
  }

  .mdx-content :global(.article-toc ul) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .mdx-content :global(.article-toc li) {
    margin: 0;
  }

  .mdx-content :global(.article-toc a) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--primary-clr-400);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px dashed rgba(30, 113, 183, 0.45);
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .mdx-content :global(.article-toc a)::before {
    content: "#";
    color: var(--accent-clr-400);
    font-size: 0.9em;
    line-height: 1;
  }

  .mdx-content :global(.article-toc a:hover) {
    color: #fff;
    border-color: var(--accent-clr-400);
    transform: translateX(2px);
  }

  .mdx-content :global(.article-toc a:focus-visible) {
    outline: 2px solid var(--accent-clr-400);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .mdx-content :global(p) {
    margin-bottom: 1.5rem;
    color: var(--secondary-clr-200);
  }

  .mdx-content :global(blockquote) {
    border-left: 4px solid var(--primary-clr-400);
    padding: 1rem 2rem;
    background: rgba(30, 113, 183, 0.05);
    margin: 2rem 0;
    font-style: italic;
  }

  .mdx-content :global(pre) {
    padding: 1.5rem;
    border-radius: 0.75rem;
    background: #0d0d0d !important;
    border: 1px solid var(--secondary-clr-400);
    margin: 2rem 0;
    overflow-x: auto;
  }

  .mdx-content :global(code) {
    font-family: monospace;
    color: var(--accent-clr-400);
  }

  .mdx-content :global(img) {
    display: block;
    max-width: min(100%, 720px);
    margin: 4rem auto;
    border-radius: 0.75rem;
    border: 1px solid var(--secondary-clr-400);
    height: auto;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--secondary-clr-400);
  }

  .post-footer-text {
    margin-bottom: 1rem;
    color: var(--secondary-clr-200);
  }

  .post-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-action {
    text-decoration: none;
    font-weight: 600;
    color: #fff;
    background: var(--primary-clr-400);
    border: 1px solid var(--primary-clr-400);
    padding: 0.65rem 1rem;
    border-radius: 0.6rem;
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .post-action:hover {
    transform: translateY(-2px);
    filter: brightness(1.07);
  }

  .post-action-secondary {
    background: transparent;
    color: var(--primary-clr-400);
    border-color: var(--secondary-clr-400);
  }

  .related-posts {
    margin-top: 2.5rem;
    padding-top: 1.8rem;
    border-top: 1px solid var(--secondary-clr-400);
  }

  .related-posts h2 {
    margin-bottom: 1.1rem;
    text-align: left;
    font-size: clamp(1.4rem, 3vw, 1.8rem);
  }

  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .related-post-card {
    text-decoration: none;
    padding: 1rem;
    border-radius: 0.8rem;
    border: 1px solid var(--secondary-clr-400);
    background: rgba(13, 13, 13, 0.45);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .related-post-card:hover {
    transform: translateY(-2px);
    border-color: var(--primary-clr-400);
    background: rgba(30, 113, 183, 0.08);
  }

  .related-post-date {
    color: var(--secondary-clr-300);
    font-size: 0.8rem;
    margin-bottom: 0.45rem;
  }

  .related-post-card h3 {
    margin: 0;
    color: #fff;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .related-post-link {
    margin: 0.7rem 0 0;
    color: var(--primary-clr-400);
    font-weight: 600;
    font-size: 0.92rem;
  }

  .related-post-tags {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    margin-top: 0.65rem;
  }

  .related-post-tags span {
    font-size: 0.75rem;
    color: var(--secondary-clr-200);
    border: 1px solid var(--secondary-clr-400);
    border-radius: 999px;
    padding: 0.2rem 0.5rem;
  }

  @media (max-width: 768px) {
    .mdx-content {
      font-size: 1.05rem;
    }

    .related-posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
