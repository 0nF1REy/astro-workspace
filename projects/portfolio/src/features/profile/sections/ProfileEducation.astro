---
const education = [
  {
    title: "Técnico em Desenvolvimento de Sistemas",
    institution: "Etec Dr Demetrio Azevedo Jr — Itapeva (SP)",
    type: "Formação Técnica",
    icon: "fa-laptop",
  },
];
---

<div class="education-header">
  <i class="fa-solid fa-user-graduate"></i>
  <h2>Formação Acadêmica</h2>
</div>

<div class="education-grid">
  {
    education.map((item) => (
      <div class="edu-card">
        <div class="edu-icon">
          <i class={`fa-solid ${item.icon}`} />
        </div>
        <div class="edu-info">
          <h3>{item.title}</h3>
          <p>{item.institution}</p>
          <span class="edu-type">{item.type}</span>
        </div>
      </div>
    ))
  }
</div>

<style>
  .education-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3rem;
    color: #fff;
  }
  .education-header i {
    color: var(--primary-clr-400);
    font-size: 1.8rem;
  }
  .education-header h2 {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 700;
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .edu-card {
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid var(--secondary-clr-400);
    border-radius: 0.75rem;
    padding: 1.75rem;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    transition:
      border-color 0.3s ease,
      transform 0.3s ease;
  }

  .edu-card:hover {
    border-color: var(--primary-clr-400);
    transform: translateY(-2px);
  }

  .edu-icon {
    min-width: 54px;
    height: 54px;
    background: rgba(30, 113, 183, 0.1);
    border-radius: 0.6rem;
    display: grid;
    place-items: center;
    color: var(--primary-clr-400);
    font-size: 1.4rem;
    border: 1px solid rgba(30, 113, 183, 0.2);
  }

  .edu-info h3 {
    font-size: 1.15rem;
    margin-bottom: 0.4rem;
    color: #fff;
    line-height: 1.3;
  }
  .edu-info p {
    font-size: 0.9rem;
    color: var(--secondary-clr-200);
    margin-bottom: 0.5rem;
  }
  .edu-type {
    font-size: 0.8rem;
    color: var(--primary-clr-400);
    font-weight: 700;
    text-transform: uppercase;
  }
</style>
