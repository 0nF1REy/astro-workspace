---
import Section from "../../components/Section.astro";
import Hero from "./sections/hero/Hero.astro";
import About from "./sections/About.astro";
import Projects from "./sections/Projects.astro";
import Testimonial from "./sections/Testimonial.astro";
import GithubStats from "./sections/GithubStats.astro";
import TechGalaxy from "./sections/tech-galaxy/TechGalaxy.astro";
---

<Hero />

<Section id="about" isZebra={true}>
  <About />
</Section>

<Section id="stack">
  <TechGalaxy />
</Section>

<Section id="work" isZebra={true}>
  <Projects />
</Section>

<Section id="github">
  <GithubStats />
</Section>

<Section id="testimonials" isZebra={true}>
  <Testimonial />
</Section>
