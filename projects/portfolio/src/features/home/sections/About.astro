---
import Button from "@components/Button.astro";
import AboutImage from "@assets/images/about/alan-ryan-03.jpg";

const IMAGEKIT_BASE_URL =
  "https://ik.imagekit.io/0nF1REy/projects/portfolio/features/home/sections/about";

const resolveLocalAssetSrc = (asset: string | { src: string }) =>
  typeof asset === "string" ? asset : asset.src;

const buildImageKitUrl = (relativePath: string) =>
  `${IMAGEKIT_BASE_URL}/${relativePath}`;

const aboutImage = {
  src: buildImageKitUrl("alan-ryan-03.jpg"),
  fallbackSrc: resolveLocalAssetSrc(AboutImage),
  width: AboutImage.width,
  height: AboutImage.height,
};
---

<div class="about">
  <div class="about__grid">
    <div class="about__content">
      <h2 class="title">Sobre mim</h2>
      <p class="subtitle about__subtitle">
        Desenvolvedor focado em performance, clareza e experiências digitais com
        propósito.
      </p>
      <p class="about__description">
        Olá, sou Alan Ryan — desenvolvedor de sistemas, natural de Itapeva-SP.
        Tenho interesse por tecnologia e design, buscando sempre unir o lado
        técnico e humano em meus projetos. Gosto de criar soluções práticas,
        organizadas e com propósito, explorando o aprendizado constante em
        programação e inovação digital.
      </p>
      <Button text="Conhecer minha trajetória" href="/perfil" />
    </div>

    <div class="about__image">
      <img
        src={aboutImage.src}
        alt="Foto de Alan Ryan"
        width={aboutImage.width}
        height={aboutImage.height}
        loading="lazy"
        decoding="async"
        crossorigin="anonymous"
        data-fallback-src={aboutImage.fallbackSrc}
      />
    </div>
  </div>
</div>

<style>
  h2 {
    margin-bottom: 0.65rem;
  }

  .about__content {
    margin-bottom: 2rem;
    text-align: center;
  }

  .about__subtitle {
    margin-bottom: 1rem;
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    font-weight: 500;
    line-height: 1.5;
    opacity: 0.95;
    max-width: 54ch;
  }

  .about__description {
    margin-bottom: 2rem;
    color: var(--secondary-clr-100);
    line-height: 1.7;
    max-width: 62ch;
  }

  .about__image {
    position: relative;
    width: min(100%, 460px);
  }

  .about__image::before {
    content: "";
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    left: -0.5rem;
    width: 25px;
    height: 100px;
    border: 1.5px solid var(--primary-clr-400);
    border-radius: 5rem;
  }

  .about__image::after {
    content: "";
    position: absolute;
    top: -2.5rem;
    right: 2rem;
    width: 20px;
    height: 80px;
    border: 1.5px solid var(--primary-clr-400);
    border-radius: 5rem;
    rotate: 90deg;
  }

  .about__image img {
    width: 100%;
    border-radius: 0.5rem;
  }

  @media (width >= 768px) {
    h2 {
      text-align: left;
    }

    .about__content {
      order: 2;
      text-align: left;
      align-self: center;
      padding-top: clamp(1rem, 2.5vw, 2rem);
    }

    .about__image {
      order: 1;
      width: min(100%, 430px);
      aspect-ratio: 4 / 5;
      max-height: 520px;
      justify-self: center;
    }

    .about__image img {
      height: 100%;
      object-fit: cover;
    }

    .about__subtitle,
    .about__description {
      font-size: 1.1rem;
    }

    .about__grid {
      display: grid;
      grid-template-columns: minmax(0, 0.96fr) minmax(0, 1.04fr);
      gap: clamp(1rem, 2.5vw, 2rem);
      align-items: center;
    }
  }
</style>
