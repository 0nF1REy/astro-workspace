---
import { getCollection } from "astro:content";
import ArticleListing from "../../../components/ArticleListing.astro";
import Button from "../../../components/Button.astro";

const allArticles = await getCollection("blog");
const featuredArticles = allArticles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<div class="featured-articles">
  <div class="section-header">
    <h2 class="title">Artigos em Destaque</h2>
    <p class="subtitle">
      Compartilhando insights sobre desenvolvimento, Linux e tecnologia.
    </p>
  </div>

  <div class="articles-grid">
    {featuredArticles.map((article) => <ArticleListing article={article} />)}
  </div>

  <div class="section-actions">
    <Button text="Ver todos os artigos" href="/blog" />
  </div>
</div>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .title {
    color: var(--primary-clr-400)
  }

  .subtitle {
    color: var(--secondary-clr-200);
    margin-top: -1rem;
    font-size: 1.1rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 360px), 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
    justify-content: center;
  }

  .section-actions {
    display: flex;
    justify-content: center;
  }

  @media (width >= 1200px) {
    .articles-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .articles-grid:has(> :last-child:nth-child(1)) {
      grid-template-columns: repeat(1, 400px);
    }
  }
</style>
