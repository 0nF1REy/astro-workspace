  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.14.0"
  },
  "description": "Personal portfolio built with Astro and TypeScript, using Astro Collections for project content and optimized images with astro:assets",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:secure": "npm run build && npm run csp:sync",
    "csp:sync": "node ./configs/sync-csp.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "lint:css": "stylelint \"src/**/*.{css,astro,html,scss}\" --allow-empty-input",
    "lint:css:fix": "stylelint --fix \"src/**/*.{css,astro,html,scss}\""
  },
  "keywords": [
    "astro",
    "portfolio",
    "typescript",
    "astro-collections",
    "static-site",
    "web-design",
    "projects",
    "responsive-images"
  ],
