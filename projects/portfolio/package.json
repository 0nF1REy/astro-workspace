{
  "name": "portfolio",
  "type": "module",
  "version": "8.3.0",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "description": "Personal portfolio built with Astro and TypeScript, using Astro Collections for project content and optimized images with astro:assets",
  "keywords": [
    "astro",
    "portfolio",
    "typescript",
    "astro-collections",
    "static-site",
    "web-design",
    "projects",
    "responsive-images"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:secure": "npm run build && npm run csp:sync",
    "csp:sync": "node ./configs/sync-csp.mjs",
    "preview": "astro preview",
    "clean": "rimraf dist",
    "check": "astro check",
    "sync": "astro sync",
    "info": "astro info",
    "upgrade": "npx @astrojs/upgrade",
    "astro": "astro",
    "lint:css": "stylelint \"src/**/*.{css,astro,html,scss}\" --allow-empty-input",
    "lint:css:fix": "stylelint --fix \"src/**/*.{css,astro,html,scss}\""
  },
  "author": {
    "name": "Alan Ryan da Silva Domingues",
    "email": "alanryan619@gmail.com",
    "url": "https://github.com/0nF1REy"
  },
  "license": "MIT",
  "homepage": "https://alan-ryan.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/0nF1REy/astro-workspace.git"
  },
  "bugs": {
    "url": "https://github.com/0nF1REy/astro-workspace/issues"
  },
  "dependencies": {
    "@astrojs/vercel": "^11.0.0",
    "@fontsource/poppins": "^5.2.7",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^7.0.0",
    "gsap": "^3.13.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "baseline-browser-mapping": "^2.10.0",
    "postcss-html": "^1.8.0",
    "rimraf": "^6.1.3",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^7.0.0",
    "typescript": "^6.0.3"
  }
}
